<!-- pet-package/weight-records/weight-records.wxml -->
<view class="container {{themeClass}}">
  <include src="../../templates/offline-tip.wxml" />

  <view class="ui-compact-hero weight-hero">
    <image class="ui-compact-hero-img" src="/assets/illustrations/profile-mascot.webp" mode="aspectFit" />
    <view class="ui-compact-hero-body">
      <text class="ui-compact-kicker">WEIGHT TRACKER</text>
      <text class="ui-compact-title">体重成长趋势</text>
      <text class="ui-compact-desc">持续记录体重变化，更早发现成长和健康信号。</text>
    </view>
  </view>

  <view class="weight-filter-panel">
    <view class="filter-heading">
      <text class="filter-heading-title">筛选记录</text>
      <text class="add-btn" catchtap="openQuickAdd" wx:if="{{currentCat !== 'all' && filteredRecords.length > 0 && !isCurrentCatPassed}}">录入体重</text>
    </view>

    <!-- 宠物筛选标签（横向滚动） -->
    <view class="filter-block">
      <text class="filter-label">查看宠物</text>
      <scroll-view class="cat-tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="cat-tabs">
          <view
            wx:for="{{catOptions}}"
            wx:key="key"
            class="cat-tab {{currentCat === item.key ? 'active' : ''}}"
            bindtap="setCatFilter"
            data-cat="{{item.key}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 时间段筛选标签 -->
    <view class="filter-block period-filter-block">
      <text class="filter-label">时间范围</text>
      <scroll-view class="period-tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="period-tabs">
          <view
            wx:for="{{periodOptions}}"
            wx:key="key"
            class="period-tab {{currentPeriod === item.key ? 'active' : ''}}"
            bindtap="setPeriodFilter"
            data-period="{{item.key}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </scroll-view>

      <!-- 自定义时间范围（仅当选择「自定义」时显示） -->
      <view wx:if="{{currentPeriod === 'custom'}}" class="custom-date-range">
        <picker mode="date" value="{{customStartDate}}" end="{{customEndDate || ''}}" bindchange="onCustomStartChange">
          <view class="date-range-picker">
            <text class="date-range-label">起</text>
            <text class="date-range-value">{{customStartDate || '选择起始'}}</text>
          </view>
        </picker>
        <text class="date-range-sep">—</text>
        <picker mode="date" value="{{customEndDate}}" start="{{customStartDate || ''}}" bindchange="onCustomEndChange">
          <view class="date-range-picker">
            <text class="date-range-label">止</text>
            <text class="date-range-value">{{customEndDate || '选择结束'}}</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <view wx:if="{{loadError && loadedRecordCount === 0}}" class="load-error-state">
    <image class="load-error-icon ui-icon-lg" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
    <text class="load-error-title">体重记录加载失败</text>
    <text class="load-error-desc">请检查网络连接后重新加载</text>
    <button class="load-retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{filteredRecords.length === 0}}" class="empty">
    <image class="ui-empty-img" src="/assets/illustrations/empty-reminder.webp" mode="aspectFill" />
    <text class="empty-text">暂无体重记录</text>
    <text class="empty-hint" wx:if="{{currentCat === 'all'}}">选择上方宠物后，点击「录入体重」添加记录</text>
    <text class="empty-hint" wx:else>还没有这只猫的体重记录</text>
    <view wx:if="{{currentCat !== 'all' && !isCurrentCatPassed}}" class="empty-cta" hover-class="btn-hover" catchtap="openQuickAdd">去录入 ›</view>
  </view>

  <!-- 记录列表 -->
  <view wx:else class="record-list">
    <!-- 顶部汇总信息（当筛选单只猫时显示） -->
    <view wx:if="{{currentCat !== 'all' && filteredRecords.length > 0}}" class="summary-card">
      <view class="summary-items-row">
        <view class="summary-item">
          <text class="summary-label">最新体重</text>
          <text class="summary-value">{{summaryLatest}} kg</text>
        </view>
        <view class="summary-divider"></view>
        <view class="summary-item">
          <text class="summary-label">记录次数</text>
          <text class="summary-value">{{summaryCount}} 次</text>
        </view>
        <view class="summary-divider" wx:if="{{summaryCount >= 2}}"></view>
        <view class="summary-item" wx:if="{{summaryCount >= 2}}">
          <text class="summary-label">累计变化</text>
          <text class="summary-value {{summaryChangeClass}}">{{summaryChangeText}}</text>
        </view>
      </view>
      <view wx:if="{{trendSummaryText}}" class="trend-summary {{trendSummaryClass}}">
        <image class="trend-summary-icon ui-icon-sm" src="/assets/icons/ui/chart.png" mode="aspectFit" />
        <text>{{trendSummaryText}}</text>
      </view>
      <view class="summary-add-row" catchtap="openQuickAdd" wx:if="{{!isCurrentCatPassed}}">+ 录入新体重</view>
    </view>

    <!-- 体重趋势折线图（仅单只猫 + ≥2条记录时显示） -->
    <canvas type="2d" id="weightChart" class="chart-canvas" wx:if="{{currentCat !== 'all' && filteredRecords.length >= 2 && !showAddModal && !showEditModal}}"></canvas>

    <!-- 体重卡片列表 -->
    <view wx:for="{{filteredRecords}}" wx:key="_id" class="record-card">
      <!-- 全部宠物视图下显示宠物名+头像 -->
      <view wx:if="{{currentCat === 'all'}}" class="record-cat-row">
        <image wx:if="{{item._catAvatar}}" class="cat-avatar-sm" src="{{item._catAvatar}}" mode="aspectFill" lazy-load></image>
        <image wx:else class="cat-avatar-placeholder ui-icon-sm" src="/assets/icons/ui/cat.png" mode="aspectFit" />
        <text class="cat-name-label">{{item._catName}}</text>
      </view>

      <view class="record-main">
        <view class="record-weight-block">
          <text class="record-weight">{{item.weight}}</text>
          <text class="record-unit">kg</text>
        </view>
        <view class="record-meta">
          <text class="record-date">{{item.date}}</text>
          <text class="record-ago">{{item._ago}}</text>
          <text class="record-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
      </view>

      <view class="record-actions">
        <view class="action-btn edit" data-id="{{item._id}}" bindtap="openEdit">编辑</view>
        <view class="action-btn delete" data-id="{{item._id}}" bindtap="deleteRecord">删除</view>
      </view>
    </view>
  </view>

  <!-- 底部分页状态 -->
  <view wx:if="{{loadedRecordCount > 0}}" class="list-footer">
    <text wx:if="{{recordsLoading}}" class="list-footer-text">加载中...</text>
    <text wx:elif="{{!hasMoreRecords}}" class="list-footer-text">— 没有更多了 —</text>
  </view>

  <!-- ─── 新增体重弹窗 ─── -->
  <view wx:if="{{showAddModal}}" class="modal-mask">
    <view class="modal-dialog" catchtap="">
      <text class="modal-kicker">WEIGHT RECORD</text>
      <text class="modal-title">录入体重</text>
      <text class="modal-subtitle">记录测量时间、体重和必要备注</text>

      <!-- 日期 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">日期</text>
        <picker mode="date" value="{{addDate}}" bindchange="onAddDateChange">
          <view class="date-picker-row">
            <text class="date-picker-value">{{addDate}}</text>
            <view class="date-picker-arrow"></view>
          </view>
        </picker>
      </view>

      <!-- 时间 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">时间</text>
        <picker mode="time" value="{{addTime}}" bindchange="onAddTimeChange">
          <view class="date-picker-row">
            <text class="date-picker-value">{{addTime}}</text>
            <view class="date-picker-arrow"></view>
          </view>
        </picker>
      </view>

      <!-- 体重 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">体重 (kg)</text>
        <input
          class="edit-input weight-input"
          type="digit"
          value="{{addWeight}}"
          bindinput="onAddWeightInput"
          placeholder="如：4.25"
          placeholder-style="color:#ccc;"
        />
      </view>

      <!-- 备注 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">备注</text>
        <input
          class="edit-input"
          value="{{addNote}}"
          bindinput="onAddNoteInput"
          placeholder="选填，如：空腹/餐后"
          placeholder-style="color:#ccc;"
        />
      </view>

      <view class="modal-btns" catchtap="">
        <view class="modal-btn cancel" hover-class="btn-hover" bindtap="cancelModal">取消</view>
        <view class="modal-btn confirm {{savingRecord ? 'disabled' : ''}}" hover-class="btn-hover" bindtap="saveAdd">{{savingRecord ? '保存中...' : '保存'}}</view>
      </view>
    </view>
  </view>

  <!-- ─── 编辑体重弹窗 ─── -->
  <view wx:if="{{showEditModal && !showAddModal}}" class="modal-mask">
    <view class="modal-dialog" catchtap="">
      <text class="modal-kicker">WEIGHT RECORD</text>
      <text class="modal-title">编辑体重记录</text>
      <text class="modal-subtitle">调整测量时间、体重或备注信息</text>

      <!-- 日期 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">日期</text>
        <picker mode="date" value="{{editDate}}" bindchange="onEditDateChange">
          <view class="date-picker-row">
            <text class="date-picker-value">{{editDate}}</text>
            <view class="date-picker-arrow"></view>
          </view>
        </picker>
      </view>

      <!-- 时间 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">时间</text>
        <picker mode="time" value="{{editTime}}" bindchange="onEditTimeChange">
          <view class="date-picker-row">
            <text class="date-picker-value">{{editTime}}</text>
            <view class="date-picker-arrow"></view>
          </view>
        </picker>
      </view>

      <!-- 体重 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">体重 (kg)</text>
        <input
          class="edit-input weight-input"
          type="digit"
          value="{{editWeight}}"
          bindinput="onEditWeightInput"
          placeholder="如：4.25"
          placeholder-style="color:#ccc;"
        />
      </view>

      <!-- 备注 -->
      <view class="edit-field" catchtap="">
        <text class="edit-label">备注</text>
        <input
          class="edit-input"
          value="{{editNote}}"
          bindinput="onEditNoteInput"
          placeholder="选填"
          placeholder-style="color:#ccc;"
        />
      </view>

      <view class="modal-btns" catchtap="">
        <view class="modal-btn cancel" hover-class="btn-hover" bindtap="cancelModal">取消</view>
        <view class="modal-btn confirm {{savingRecord ? 'disabled' : ''}}" hover-class="btn-hover" bindtap="saveEdit">{{savingRecord ? '保存中...' : '保存'}}</view>
      </view>
    </view>
  </view>

</view>
