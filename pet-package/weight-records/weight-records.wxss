/* pet-package/weight-records/weight-records.wxss */

.container {
  min-height: 100vh;
  background:
    linear-gradient(180deg, var(--theme-bg-strong, #CDEAE5) 0%, var(--theme-secondary-soft, #EAF7F5) 310rpx, var(--theme-bg, #F7F9FB) 650rpx),
    var(--theme-bg, #F7F9FB);
  padding: 24rpx 24rpx 64rpx;
  box-sizing: border-box;
}

/* ─── 页面头部 ─── */
.weight-hero {
  min-height: 180rpx;
  margin: 0 -4rpx 18rpx;
  padding: 4rpx 12rpx 8rpx;
  box-sizing: border-box;
}

.weight-hero .ui-compact-hero-img {
  width: 176rpx;
  height: 150rpx;
  margin-right: 16rpx;
}

.weight-hero .ui-compact-title {
  color: #243044;
  font-size: 34rpx;
}

.weight-hero .ui-compact-desc {
  color: #536579;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}

.weight-filter-panel {
  margin-bottom: 26rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), 0.12);
  box-shadow: 0 12rpx 32rpx rgba(68, 92, 120, 0.08);
}

.filter-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-heading-title {
  color: #243044;
  font-size: 29rpx;
  font-weight: 900;
}

.add-btn {
  padding: 9rpx 20rpx;
  border-radius: 999rpx;
  color: var(--theme-primary-deep, #2F8DB8);
  background: var(--theme-primary-soft, #EAF4FB);
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), 0.28);
  font-size: 23rpx;
  font-weight: 900;
}

.filter-block + .filter-block {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #E8EEF4;
}

.filter-label {
  display: block;
  margin-bottom: 14rpx;
  color: #6E7A8A;
  font-size: 22rpx;
  font-weight: 800;
}

/* ─── 宠物筛选标签 ─── */
.cat-tabs-scroll {
  width: 100%;
  white-space: nowrap;
}

.cat-tabs {
  display: inline-flex;
  min-width: 100%;
  gap: 12rpx;
}

.cat-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 118rpx;
  height: 66rpx;
  padding: 0 24rpx;
  background: #F5F9FC;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #536579;
  border: 2rpx solid transparent;
  flex-shrink: 0;
  box-sizing: border-box;
}

.cat-tab.active {
  color: #FFFFFF !important;
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486)) !important;
  border-color: transparent !important;
  box-shadow: 0 8rpx 20rpx rgba(var(--theme-primary-rgb, 91, 167, 216), 0.24) !important;
}

/* ─── 时间段筛选标签 ─── */
.period-tabs-scroll {
  width: 100%;
  white-space: nowrap;
}

.period-tabs {
  display: inline-flex;
  gap: 10rpx;
}

.period-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  padding: 0 22rpx;
  background: #F5F9FC;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #536579;
  border: 2rpx solid transparent;
  flex-shrink: 0;
  box-sizing: border-box;
}

.weight-filter-panel .period-tab.active {
  color: var(--theme-primary-deep, #2F8DB8) !important;
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5)) !important;
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), 0.42) !important;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.75) !important;
  font-weight: 900;
}

/* ─── 自定义时间范围 ─── */
.custom-date-range {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 18rpx 24rpx;
  background: #F5F9FC;
  border-radius: 20rpx;
  border: 1rpx solid #E8EEF4;
}
.date-range-picker {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
}
.date-range-label {
  font-size: 24rpx;
  color: var(--theme-primary, #5BA7D8);
  font-weight: 700;
}
.date-range-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.date-range-sep {
  font-size: 28rpx;
  color: #999;
  font-weight: 600;
}

.load-error-state {
  min-height: 460rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
  box-sizing: border-box;
}
.load-error-icon { width: 90rpx; height: 90rpx; margin-bottom: 18rpx; }
.load-error-title { color: #243044; font-size: 31rpx; font-weight: 900; }
.load-error-desc { margin: 10rpx 0 26rpx; color: #6E7A8A; font-size: 24rpx; }
.load-retry-btn {
  min-width: 220rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
  font-size: 27rpx;
  font-weight: 900;
}

/* ─── 空状态 ─── */
.empty { display: flex; flex-direction: column; align-items: center; padding-top: 80rpx; }
.empty-illustration {
  width: 200rpx; height: 200rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(76,175,80,0.2);
}
.empty-emoji { font-size: 96rpx; }
.empty-text { font-size: 32rpx; color: #333; font-weight: 700; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: #999; margin-bottom: 48rpx; text-align: center; max-width: 420rpx; line-height: 1.6; }
.empty-cta {
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
  color: #fff; font-size: 28rpx; font-weight: 600;
  border-radius: 48rpx; padding: 24rpx 60rpx;
  box-shadow: 0 8rpx 30rpx rgba(74,144,217,0.35);
}

/* ─── 汇总卡片 ─── */
.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.summary-items-row {
  display: flex;
  align-items: center;
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}
.summary-label { font-size: 22rpx; color: #999; white-space: nowrap; }
.summary-value { font-size: 34rpx; font-weight: 800; color: #333; white-space: nowrap; }
.summary-value.up { color: #f57c00; }
.summary-value.down { color: #43a047; }
.summary-divider {
  width: 1rpx; height: 60rpx;
  background: #eee;
  flex-shrink: 0;
}
.trend-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #F5F9FC;
  color: #536579;
  font-size: 23rpx;
  font-weight: 700;
}
.trend-summary.up { color: #B66A15; background: #FFF8EE; }
.trend-summary.down { color: var(--theme-primary-deep, #2F8DB8); background: var(--theme-primary-soft, #EAF4FB); }
.trend-summary.stable { color: #2F7F72; background: var(--theme-secondary-soft, #EAF7F5); }
.trend-summary-icon { width: 34rpx; height: 34rpx; flex-shrink: 0; }
.summary-add-row {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
  font-size: 26rpx;
  color: var(--theme-primary, #5BA7D8);
  font-weight: 600;
}

/* ─── 记录列表 ─── */
.record-list { display: flex; flex-direction: column; gap: 16rpx; }

.record-cat-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 16rpx;
}
.cat-avatar-sm {
  width: 40rpx; height: 40rpx; border-radius: 50%; overflow: hidden;
}
.cat-avatar-placeholder { font-size: 32rpx; }
.cat-name-label { font-size: 26rpx; color: #666; font-weight: 600; }

.record-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.record-main {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.record-weight-block {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  min-width: 0;
  flex-shrink: 0;
}
.record-weight {
  font-size: 46rpx;
  font-weight: 900;
  color: #333;
  line-height: 1;
}
.record-unit {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

.record-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.record-date { font-size: 26rpx; color: #333; font-weight: 600; }
.record-ago  { font-size: 22rpx; color: #999; }
.record-note { font-size: 24rpx; color: #888; }

.record-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: center;
  flex-shrink: 0;
}
.action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 600;
}
.action-btn.edit {
  background: #e3f2fd;
  color: #1976d2;
}
.action-btn.delete {
  background: #fce4ec;
  color: #c62828;
}

/* ─── 弹窗 ─── */
.modal-mask {
  position: fixed;
  inset: 0;
  padding: 48rpx 32rpx;
  background: rgba(36, 48, 68, 0.46);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  box-sizing: border-box;
}
.modal-dialog {
  width: 100%;
  max-height: 86vh;
  overflow-y: auto;
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, var(--theme-secondary-soft, #F2FBFA), #FFFFFF);
  box-shadow: 0 28rpx 70rpx rgba(24, 76, 108, 0.20);
  box-sizing: border-box;
}
.modal-kicker { display: block; color: var(--theme-primary, #5BA7D8); font-size: 20rpx; font-weight: 900; }
.modal-title { display: block; margin-top: 4rpx; color: #243044; font-size: 35rpx; font-weight: 900; }
.modal-subtitle { display: block; margin: 8rpx 0 26rpx; color: #6E7A8A; font-size: 23rpx; }

.edit-field {
  margin-bottom: 22rpx;
}
.edit-label { display: block; margin-bottom: 10rpx; color: #3F5268; font-size: 25rpx; font-weight: 900; }
.date-picker-row {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #F5F9FC;
  border: 1rpx solid #E8EEF4;
  box-sizing: border-box;
}
.date-picker-value { font-size: 28rpx; color: #243044; font-weight: 800; }
.date-picker-arrow {
  width: 11rpx; height: 11rpx;
  margin: -5rpx 4rpx 0 12rpx;
  border-right: 3rpx solid var(--theme-primary, #5BA7D8);
  border-bottom: 3rpx solid var(--theme-primary, #5BA7D8);
  transform: rotate(45deg);
  flex-shrink: 0;
}
.edit-input {
  min-height: 86rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #F5F9FC;
  border: 1rpx solid #E8EEF4;
  font-size: 28rpx;
  color: #243044;
  box-sizing: border-box;
}
.weight-input { font-size: 36rpx !important; font-weight: 700; }

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
}
.modal-btn.cancel {
  background: #FFFFFF;
  color: #6E7A8A;
  border: 1rpx solid #E8EEF4;
}
.modal-btn.confirm {
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
  color: #fff;
  box-shadow: 0 12rpx 28rpx rgba(var(--theme-primary-rgb, 91, 167, 216), 0.22);
}
.modal-btn.disabled { opacity: .58; pointer-events: none; }

/* ─── 折线图 ─── */
.chart-canvas {
  width: 100%;
  height: 440rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.btn-hover { opacity: 0.75; }
.list-footer { padding: 24rpx; text-align: center; }
.list-footer-text { font-size: 24rpx; color: #999; }

/* ─── 主题中性色收口 ─── */
.empty-illustration {
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
  box-shadow: 0 8rpx 32rpx rgba(var(--theme-primary-rgb, 91, 167, 216), .16);
}

.summary-card,
.record-card,
.chart-canvas,
.modal-btn.cancel {
  background: var(--theme-card, #FFFFFF);
}

.empty-text,
.summary-value,
.record-weight,
.record-date,
.modal-title,
.date-picker-value,
.edit-input {
  color: var(--theme-text, #243044);
}

.empty-hint,
.summary-label,
.record-unit,
.record-ago,
.list-footer-text {
  color: var(--theme-text-muted, #A5AFBC);
}

.cat-name-label,
.record-note,
.modal-subtitle,
.modal-btn.cancel {
  color: var(--theme-text-secondary, #6E7A8A);
}

.summary-divider {
  background-color: var(--theme-divider, #E8EEF4);
}

.summary-add-row {
  border-color: var(--theme-divider, #E8EEF4);
}

.trend-summary,
.date-picker-row,
.edit-input {
  background: var(--theme-surface-muted, #F5F9FC);
  border-color: var(--theme-divider, #E8EEF4);
}

.modal-dialog {
  background: linear-gradient(180deg, var(--theme-secondary-soft, #EAF7F5), var(--theme-card, #FFFFFF));
}
