<!-- account-package/bind-phone/bind-phone.wxml -->
<view class="page {{themeClass}}">
  <view class="card">
    <view class="bind-hero-icon">
      <image class="bind-hero-img" src="/assets/icons/ui/phone.png" mode="aspectFit" />
    </view>
    <view class="card-title">绑定手机号</view>
    <view class="card-desc">绑定后可使用手机号登录小程序</view>

    <!-- 手机号 -->
    <view class="input-row">
      <input type="number" placeholder="请输入手机号" bindinput="onPhoneInput" maxlength="11"
        style="font-size:30rpx;color:#333;width:100%;height:48rpx;line-height:48rpx;" />
    </view>

    <!-- 密码 -->
    <view class="input-row">
      <input password type="text" placeholder="{{needPassword ? '设置密码（至少6位）' : '新密码（选填，至少6位）'}}" bindinput="onPasswordInput"
        style="font-size:30rpx;color:#333;width:100%;height:48rpx;line-height:48rpx;" />
    </view>
    <view class="input-row">
      <input password type="text" placeholder="确认密码" bindinput="onConfirmInput"
        style="font-size:30rpx;color:#333;width:100%;height:48rpx;line-height:48rpx;" />
    </view>

    <view class="btn-confirm {{submitting ? 'disabled' : ''}}" bindtap="submit">{{submitting ? '绑定中...' : '确认绑定'}}</view>
    <view wx:if="{{mode === 'login'}}" class="btn-skip" bindtap="skip">暂不绑定 ›</view>
  </view>
</view>
