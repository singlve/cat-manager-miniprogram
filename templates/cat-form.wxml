<!-- templates/cat-form.wxml -->
<!-- cat-add 和 cat-edit 共享的宠物表单模板 -->

  <view class="form-card">

    <view class="ui-compact-hero">
      <image class="ui-compact-hero-img" src="/assets/illustrations/pet-profile-clean.png" mode="aspectFit" />
      <view class="ui-compact-hero-body">
        <text class="ui-compact-kicker">PET PROFILE</text>
        <text class="ui-compact-title">{{isEdit ? '更新宠物档案' : '创建宠物档案'}}</text>
        <text class="ui-compact-desc">把基础信息整理好，后续健康记录和提醒会更清晰。</text>
      </view>
    </view>

    <!-- 头像区域 -->
    <view class="avatar-section">
      <view wx:if="{{tempAvatarPath}}" class="avatar-wrap avatar-selected" bindtap="chooseAvatar">
        <image src="{{tempAvatarPath}}" mode="aspectFill" class="avatar-img" />
        <view class="avatar-overlay">
          <image class="ui-icon-sm" src="/assets/icons/ui/camera.png" mode="aspectFit" />
        </view>
        <view class="remove-btn" catchtap="removeAvatar">✕</view>
      </view>
      <view wx:else class="avatar-wrap avatar-placeholder-state" bindtap="chooseAvatar">
        <image class="placeholder-emoji ui-icon-lg" src="{{species === 'dog' ? '/assets/icons/ui/dog.png' : '/assets/icons/ui/cat.png'}}" mode="aspectFit" />
        <text class="placeholder-text">点击上传头像</text>
      </view>
      <text class="avatar-hint">{{tempAvatarPath ? '点击可更换头像' : '建议尺寸 200×200，支持 JPG/PNG'}}</text>
    </view>

    <!-- 宠物类型 -->
    <view class="form-group">
      <text class="label">宠物类型 <text class="required">*</text></text>
      <radio-group bindchange="speciesChange" class="gender-group">
        <label class="gender-option {{species === 'cat' ? 'active' : ''}}">
          <radio value="cat" checked="{{species === 'cat'}}" />
          <image class="ui-inline-icon" src="/assets/icons/ui/cat.png" mode="aspectFit" />
          <text>猫咪</text>
        </label>
        <label class="gender-option {{species === 'dog' ? 'active' : ''}}">
          <radio value="dog" checked="{{species === 'dog'}}" />
          <image class="ui-inline-icon" src="/assets/icons/ui/dog.png" mode="aspectFit" />
          <text>狗狗</text>
        </label>
      </radio-group>
    </view>

    <!-- 基本信息 -->
    <view class="form-group">
      <text class="label">宠物名字 <text class="required">*</text></text>
      <input
        class="input {{nameError ? 'input-error' : ''}}"
        placeholder="请输入宠物名字"
        value="{{name}}"
        bindinput="nameInput"
        bindblur="validateName"
        maxlength="20"
      />
      <text wx:if="{{nameError}}" class="error-msg">{{nameError}}</text>
    </view>

    <view class="form-group">
      <text class="label">性别</text>
      <radio-group bindchange="genderChange" class="gender-group">
        <label class="gender-option {{gender === 'male' ? 'active' : ''}}">
          <radio value="male" checked="{{gender === 'male'}}" />
          <text>弟弟</text>
        </label>
        <label class="gender-option {{gender === 'female' ? 'active' : ''}}">
          <radio value="female" checked="{{gender === 'female'}}" />
          <text>妹妹</text>
        </label>
      </radio-group>
    </view>

    <view class="form-group">
      <text class="label">是否已绝育</text>
      <view class="switch-row">
        <text class="switch-label">{{neutered ? '已绝育' : '未绝育'}}</text>
        <switch checked="{{neutered}}" bindchange="onNeuteredChange" color="{{themePrimary || '#5BA7D8'}}" />
      </view>
    </view>

    <view class="form-group">
      <text class="label">宠物状态</text>
      <radio-group bindchange="onStatusChange" class="gender-group">
        <label class="gender-option {{status === 'with_me' ? 'active' : ''}}">
          <radio value="with_me" checked="{{status === 'with_me'}}" />
          <image class="ui-inline-icon" src="/assets/icons/ui/pet.png" mode="aspectFit" />
          <text>在身边</text>
        </label>
        <label class="gender-option {{status === 'passed_away' ? 'active' : ''}}">
          <radio value="passed_away" checked="{{status === 'passed_away'}}" />
          <image class="ui-inline-icon" src="/assets/icons/ui/heart.png" mode="aspectFit" />
          <text>已离世</text>
        </label>
      </radio-group>
    </view>

    <view class="form-group" wx:if="{{status === 'passed_away'}}">
      <text class="label">离世日期 <text class="required">*</text></text>
      <picker mode="date" value="{{passedDate}}" bindchange="onPassedDateChange" class="picker" end="{{nowDate}}" start="{{birthday || '2010-01-01'}}">
        <view class="picker-value {{passedDate ? '' : 'placeholder'}}">
          {{passedDate || '请选择日期'}}
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="label">品种</text>
      <view class="picker" bindtap="showBreedPicker">
        <view class="picker-value {{breed ? '' : 'placeholder'}}">
          {{breed || '请选择品种'}}
        </view>
      </view>
    </view>

    <!-- 品种搜索选择弹窗 -->
    <view class="breed-modal-mask" wx:if="{{breedPickerVisible}}" bindtap="hideBreedPicker">
      <view class="breed-modal" catchtap>
        <view class="breed-modal-header">
          <text class="breed-modal-title">选择品种</text>
          <text class="breed-modal-close" bindtap="hideBreedPicker">✕</text>
        </view>
        <view class="breed-search-wrap">
          <input
            class="breed-search-input"
            placeholder="搜索品种..."
            value="{{breedKeyword}}"
            bindinput="onBreedSearch"
            focus="{{breedPickerVisible}}"
            confirm-type="search"
          />
          <text wx:if="{{breedKeyword}}" class="breed-search-clear" bindtap="clearBreedSearch">✕</text>
        </view>
        <scroll-view scroll-y class="breed-list">
          <view wx:if="{{filteredBreeds.length === 0}}" class="breed-empty">
            <text>没有匹配的品种</text>
          </view>
          <view
            wx:for="{{filteredBreeds}}"
            wx:key="*this"
            class="breed-item {{breed === item ? 'breed-item-active' : ''}}"
            bindtap="selectBreed"
            data-breed="{{item}}"
          >
            <text>{{item}}</text>
            <text wx:if="{{breed === item}}" class="breed-check">✓</text>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="form-group">
      <text class="label">生日</text>
      <picker mode="date" value="{{birthday}}" bindchange="bindBirthdayChange" class="picker">
        <view class="picker-value {{birthday ? '' : 'placeholder'}} {{birthdayError ? 'picker-error' : ''}}">
          {{birthday || '请选择生日'}}
        </view>
      </picker>
      <text wx:if="{{birthdayError}}" class="error-msg">{{birthdayError}}</text>
    </view>

    <view class="form-group">
      <text class="label">领养日期</text>
      <picker mode="date" value="{{adoptedDate}}" bindchange="bindAdoptedDateChange" class="picker">
        <view class="picker-value {{adoptedDate ? '' : 'placeholder'}}">
          {{adoptedDate || '请选择领养日期'}}
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="label">备注</text>
      <textarea
        class="textarea"
        placeholder="记录一些关于这只毛孩子的小日常~"
        value="{{note}}"
        bindinput="noteInput"
        maxlength="200"
        auto-height
      />
    </view>

  </view>

  <view class="btn-section">
    <button
      class="save-btn {{saving ? 'saving' : ''}}"
      bindtap="saveCat"
      disabled="{{saving}}"
    >
      <text wx:if="{{!saving && !isEdit}}">保存</text>
      <text wx:elif="{{!saving && isEdit}}">保存修改</text>
      <text wx:else>保存中...</text>
    </button>
  </view>
