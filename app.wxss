/* 全局色调
 * 背景 #F7F9FB / 卡片 #FFFFFF / 主蓝 #5BA7D8 / 辅绿 #6BC6B3
 * 浅蓝 #EAF4FB / 浅绿 #EAF7F5 / 暖橙 #FFB86B / 危险 #F36B6B
 * 主文字 #243044 / 次文字 #6E7A8A / 弱文字 #A5AFBC / 分割线 #E8EEF4
 */
page {
  min-height: 100%;
  background: #F7F9FB;
  color: #243044;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.theme-default,
.theme-peach,
.theme-forest,
.theme-night,
.theme-lunar,
.theme-birthday,
.theme-christmas {
  --theme-card: #FFFFFF;
  --theme-text: #243044;
  --theme-text-secondary: #6E7A8A;
  --theme-text-muted: #A5AFBC;
  --theme-divider: #E8EEF4;
  --theme-danger: #F36B6B;
  --theme-warning: #FFB86B;
  --theme-surface: #FFFFFF;
  --theme-surface-muted: #F5F9FC;
  --theme-surface-tint: #F2F8FB;
}

.theme-default {
  --theme-primary: #5BA7D8;
  --theme-primary-rgb: 91, 167, 216;
  --theme-primary-deep: #2F8DB8;
  --theme-secondary: #6BC6B3;
  --theme-secondary-rgb: 107, 198, 179;
  --theme-secondary-deep: #3F9486;
  --theme-action-start: #25779C;
  --theme-action-end: #327A70;
  --theme-primary-soft: #EAF4FB;
  --theme-secondary-soft: #EAF7F5;
  --theme-bg: #F7F9FB;
  --theme-bg-strong: #CDEAE5;
}

.theme-peach {
  --theme-primary: #E9857B;
  --theme-primary-rgb: 233, 133, 123;
  --theme-primary-deep: #C7635B;
  --theme-secondary: #F4B06A;
  --theme-secondary-rgb: 244, 176, 106;
  --theme-secondary-deep: #B97835;
  --theme-action-start: #A94F48;
  --theme-action-end: #9A5C25;
  --theme-primary-soft: #FDEDEA;
  --theme-secondary-soft: #FFF1DF;
  --theme-bg: #FFF8F5;
  --theme-bg-strong: #F8D8D2;
  --theme-surface-muted: #FFF5F1;
  --theme-surface-tint: #FEF0EA;
}

.theme-forest {
  --theme-primary: #5F9F7B;
  --theme-primary-rgb: 95, 159, 123;
  --theme-primary-deep: #477F61;
  --theme-secondary: #72B7C8;
  --theme-secondary-rgb: 114, 183, 200;
  --theme-secondary-deep: #4F8795;
  --theme-action-start: #477F61;
  --theme-action-end: #3F7180;
  --theme-primary-soft: #E7F3EB;
  --theme-secondary-soft: #E7F3F6;
  --theme-bg: #F5FAF7;
  --theme-bg-strong: #D7E9DE;
  --theme-surface-muted: #F1F8F3;
  --theme-surface-tint: #EAF5EE;
}

.theme-night {
  --theme-primary: #526D96;
  --theme-primary-rgb: 82, 109, 150;
  --theme-primary-deep: #445E87;
  --theme-secondary: #63A6A4;
  --theme-secondary-rgb: 99, 166, 164;
  --theme-secondary-deep: #477E7C;
  --theme-action-start: #445E87;
  --theme-action-end: #477E7C;
  --theme-primary-soft: #E7EDF6;
  --theme-secondary-soft: #E4F1F0;
  --theme-bg: #F3F6FA;
  --theme-bg-strong: #D7E0EC;
  --theme-surface-muted: #EEF2F8;
  --theme-surface-tint: #E8EEF6;
}

.theme-lunar {
  --theme-primary: #C85250;
  --theme-primary-rgb: 200, 82, 80;
  --theme-primary-deep: #983B3A;
  --theme-secondary: #D7A64A;
  --theme-secondary-rgb: 215, 166, 74;
  --theme-secondary-deep: #8A6320;
  --theme-action-start: #8F3434;
  --theme-action-end: #7A571B;
  --theme-primary-soft: #FBE9E7;
  --theme-secondary-soft: #FFF2D8;
  --theme-bg: #FFF8F3;
  --theme-bg-strong: #F5D7D1;
  --theme-surface-muted: #FFF3EC;
  --theme-surface-tint: #FCECE5;
}

.theme-birthday {
  --theme-primary: #B56FC5;
  --theme-primary-rgb: 181, 111, 197;
  --theme-primary-deep: #824A94;
  --theme-secondary: #F08E9B;
  --theme-secondary-rgb: 240, 142, 155;
  --theme-secondary-deep: #A94C5C;
  --theme-action-start: #744085;
  --theme-action-end: #983F52;
  --theme-primary-soft: #F3E8F7;
  --theme-secondary-soft: #FCE9EE;
  --theme-bg: #FCF8FF;
  --theme-bg-strong: #EADAF1;
  --theme-surface-muted: #F9F1FB;
  --theme-surface-tint: #F5EAF8;
}

.theme-christmas {
  --theme-primary: #477C63;
  --theme-primary-rgb: 71, 124, 99;
  --theme-primary-deep: #315B47;
  --theme-secondary: #B64F55;
  --theme-secondary-rgb: 182, 79, 85;
  --theme-secondary-deep: #84363B;
  --theme-action-start: #315B47;
  --theme-action-end: #763238;
  --theme-primary-soft: #E5F0E9;
  --theme-secondary-soft: #F6E5E6;
  --theme-bg: #F7FAF8;
  --theme-bg-strong: #D8E7DE;
  --theme-surface-muted: #EFF6F1;
  --theme-surface-tint: #E8F2EC;
}

/* 主题业务图标：保留图形含义，只调整色相、饱和度和承载底色 */
.theme-business-icon {
  transition: filter .18s ease, opacity .18s ease, transform .18s ease;
}

.theme-peach .theme-business-icon {
  filter: sepia(.18) saturate(1.08) hue-rotate(318deg) brightness(1.03);
  transform: scale(.96) rotate(-2deg);
}

.theme-forest .theme-business-icon {
  filter: sepia(.12) saturate(.92) hue-rotate(58deg) brightness(.98);
  transform: scale(.98);
}

.theme-night .theme-business-icon {
  filter: saturate(.82) hue-rotate(168deg) brightness(.94);
  transform: scale(.94);
}

.theme-lunar .theme-business-icon {
  filter: sepia(.2) saturate(1.16) hue-rotate(328deg) brightness(.98);
  transform: scale(.96) rotate(1deg);
}

.theme-birthday .theme-business-icon {
  filter: sepia(.12) saturate(1.08) hue-rotate(246deg) brightness(1.02);
  transform: scale(.96) rotate(-2deg);
}

.theme-christmas .theme-business-icon {
  filter: sepia(.14) saturate(.92) hue-rotate(76deg) brightness(.94);
  transform: scale(.95);
}

.theme-peach .banner-icon-wrap,
.theme-peach .record-icon,
.theme-peach .category-icon-wrap,
.theme-peach .desktop-icon,
.theme-peach .quick-icon-wrap,
.theme-peach .smart-plan-icon {
  border-radius: 42% 58% 48% 52% !important;
  box-shadow: inset 0 0 0 1rpx rgba(233,133,123,.12), 0 8rpx 18rpx rgba(233,133,123,.10);
}

.theme-forest .banner-icon-wrap,
.theme-forest .record-icon,
.theme-forest .category-icon-wrap,
.theme-forest .desktop-icon,
.theme-forest .quick-icon-wrap,
.theme-forest .smart-plan-icon {
  border-radius: 52% 48% 62% 38% !important;
  box-shadow: inset 0 0 0 1rpx rgba(95,159,123,.14), 0 8rpx 18rpx rgba(95,159,123,.10);
}

.theme-night .banner-icon-wrap,
.theme-night .record-icon,
.theme-night .category-icon-wrap,
.theme-night .desktop-icon,
.theme-night .quick-icon-wrap,
.theme-night .smart-plan-icon {
  border-radius: 20rpx !important;
  box-shadow: inset 0 0 0 1rpx rgba(82,109,150,.18), 0 8rpx 18rpx rgba(82,109,150,.12);
}

.theme-lunar .banner-icon-wrap,
.theme-lunar .record-icon,
.theme-lunar .category-icon-wrap,
.theme-lunar .desktop-icon,
.theme-lunar .quick-icon-wrap,
.theme-lunar .smart-plan-icon {
  border-radius: 24rpx 24rpx 34rpx 34rpx !important;
  box-shadow: inset 0 0 0 1rpx rgba(200,82,80,.16), 0 8rpx 18rpx rgba(215,166,74,.13);
}

.theme-birthday .banner-icon-wrap,
.theme-birthday .record-icon,
.theme-birthday .category-icon-wrap,
.theme-birthday .desktop-icon,
.theme-birthday .quick-icon-wrap,
.theme-birthday .smart-plan-icon {
  border-radius: 50% 50% 42% 42% !important;
  box-shadow: inset 0 0 0 1rpx rgba(181,111,197,.15), 0 8rpx 18rpx rgba(240,142,155,.13);
}

.theme-christmas .banner-icon-wrap,
.theme-christmas .record-icon,
.theme-christmas .category-icon-wrap,
.theme-christmas .desktop-icon,
.theme-christmas .quick-icon-wrap,
.theme-christmas .smart-plan-icon {
  border-radius: 18rpx 30rpx 18rpx 30rpx !important;
  box-shadow: inset 0 0 0 1rpx rgba(71,124,99,.17), 0 8rpx 18rpx rgba(182,79,85,.11);
}

.theme-icon-tile,
.record-icon,
.category-icon-wrap,
.banner-icon-wrap,
.announce-icon-wrap,
.quick-icon-wrap {
  background: linear-gradient(
    135deg,
    var(--theme-primary-soft, #EAF4FB),
    var(--theme-secondary-soft, #EAF7F5)
  ) !important;
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), .14) !important;
}

.page,
.container {
  background:
    linear-gradient(180deg, var(--theme-secondary-soft, #EAF7F5) 0%, rgba(247,249,251,0) 360rpx),
    var(--theme-bg, #F7F9FB) !important;
  box-sizing: border-box;
  transition: background .2s ease, background-color .2s ease, color .2s ease;
}

/* 限定主题使用纯 CSS 纹理，保持轻量且不增加包体。 */
.theme-lunar.page,
.theme-lunar.container {
  background:
    radial-gradient(circle at 92% 72rpx, rgba(215,166,74,.18) 0 7rpx, transparent 8rpx),
    radial-gradient(circle at 84% 118rpx, rgba(200,82,80,.10) 0 5rpx, transparent 6rpx),
    linear-gradient(180deg, var(--theme-secondary-soft) 0%, transparent 360rpx),
    var(--theme-bg) !important;
}

.theme-birthday.page,
.theme-birthday.container {
  background:
    radial-gradient(circle at 90% 88rpx, rgba(240,142,155,.17) 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 82% 132rpx, rgba(181,111,197,.13) 0 5rpx, transparent 6rpx),
    radial-gradient(circle at 95% 158rpx, rgba(244,176,106,.14) 0 4rpx, transparent 5rpx),
    linear-gradient(180deg, var(--theme-secondary-soft) 0%, transparent 360rpx),
    var(--theme-bg) !important;
}

.theme-christmas.page,
.theme-christmas.container {
  background:
    linear-gradient(150deg, transparent 0 88%, rgba(71,124,99,.08) 88% 91%, transparent 91%) 100% 0 / 170rpx 150rpx no-repeat,
    linear-gradient(30deg, transparent 0 88%, rgba(182,79,85,.07) 88% 91%, transparent 91%) 100% 30rpx / 150rpx 140rpx no-repeat,
    linear-gradient(180deg, var(--theme-secondary-soft) 0%, transparent 360rpx),
    var(--theme-bg) !important;
}

.card,
.form-card,
.section,
.modal-content,
.sheet-panel,
.ui-compact-hero,
.desktop-icon,
.theme-icon-tile,
button,
input,
textarea {
  transition:
    background .2s ease,
    background-color .2s ease,
    border-color .2s ease,
    color .2s ease,
    box-shadow .2s ease;
}

.empty-illustration,
.empty-icon-wrap,
.empty-img-wrap,
.empty-image-wrap,
.load-error-icon-wrap {
  background: linear-gradient(
    145deg,
    var(--theme-primary-soft, #EAF4FB),
    var(--theme-secondary-soft, #EAF7F5)
  ) !important;
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), .14) !important;
  box-shadow: 0 12rpx 28rpx rgba(var(--theme-primary-rgb, 91, 167, 216), .12) !important;
}

.empty-desc,
.empty-hint,
.loading-box,
.loading,
.load-error-desc,
.error-desc {
  color: var(--theme-text-secondary, #6E7A8A) !important;
}

.load-error-title,
.error-title {
  color: var(--theme-text, #243044) !important;
}

.load-error-state {
  margin: 28rpx 0;
  padding: 64rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 24rpx;
  background: rgba(255,255,255,.92);
  border: 1rpx dashed rgba(var(--theme-primary-rgb, 91, 167, 216), .28);
}
.load-error-icon { width: 88rpx; height: 88rpx; margin-bottom: 18rpx; }
.load-error-title { font-size: 30rpx; font-weight: 900; }
.load-error-desc { margin: 10rpx 0 24rpx; font-size: 23rpx; text-align: center; line-height: 1.55; }
.load-retry-btn {
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0 32rpx;
  font-size: 25rpx;
}

.ui-loading-state {
  min-height: 260rpx;
  padding: 52rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--theme-text-secondary, #6E7A8A);
}

.ui-loading-mark {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 18rpx;
  border: 7rpx solid var(--theme-primary-soft, #EAF4FB);
  border-top-color: var(--theme-primary, #5BA7D8);
  border-radius: 50%;
  box-sizing: border-box;
  animation: ui-loading-spin .85s linear infinite;
}

.ui-loading-text {
  font-size: 24rpx;
  font-weight: 700;
}

@keyframes ui-loading-spin {
  to { transform: rotate(360deg); }
}

.modal-content,
.sheet-panel,
.picker-modal,
.custom-picker-panel,
.filter-modal {
  background-color: var(--theme-card, #FFFFFF) !important;
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), .16) !important;
}

/* 全局设计系统：可爱治愈 + 成熟产品感 */
.form-card,
.section,
.card,
.post-box,
.fb-card,
.addr-card,
.summary-card,
.month-card,
.year-summary-card,
.chart-card,
.expense-item,
.item-row,
.shipment-card,
.user-card,
.menu-card,
.stats-card,
.points-card,
.profile-card,
.weight-summary-card,
.record-card,
.address-card,
.item-card,
.feedback-card,
.post-card,
.admin-card,
.panel,
.list-card {
  border-radius: 24rpx !important;
  background: rgba(255,255,255,0.96) !important;
  box-shadow: 0 10rpx 30rpx rgba(68, 92, 120, 0.08) !important;
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), 0.08);
}

button,
.save-btn,
.add-btn,
.fab-btn,
.empty-cta,
.empty-btn,
.guest-login-btn,
.login-main-btn,
.checkin-btn,
.wm-btn.confirm,
.sheet-btn.confirm,
.modal-btn.confirm,
.quick-btn-confirm,
.cb-btn.primary,
.s-btn.confirm,
.e-btn.confirm,
.confirm {
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486)) !important;
  color: #fff !important;
  border-radius: 999rpx !important;
  border: none !important;
  box-shadow: 0 12rpx 28rpx rgba(var(--theme-primary-rgb, 91, 167, 216), 0.26) !important;
}

button::after,
.save-btn::after,
.add-btn::after,
.fab-btn::after,
.empty-cta::after,
.empty-btn::after,
.guest-login-btn::after,
.login-main-btn::after,
.cb-btn::after {
  border: none !important;
}

button[disabled],
.save-btn.disabled,
.add-btn.disabled,
.confirm.disabled {
  background: var(--theme-divider, #E8EEF4) !important;
  color: var(--theme-text-muted, #A5AFBC) !important;
  box-shadow: none !important;
  opacity: 1 !important;
}

.input,
.textarea,
.picker,
.picker-value,
.wm-input,
.wm-picker,
.edit-input,
.interval-input,
input,
textarea {
  border-radius: 18rpx !important;
  background: var(--theme-surface-muted, #F5F9FC) !important;
  border-color: var(--theme-divider, #E8EEF4) !important;
  color: var(--theme-text, #243044) !important;
}

.placeholder,
.input-placeholder,
.textarea-placeholder {
  color: var(--theme-text-muted, #A5AFBC) !important;
}

.label,
.section-title,
.cat-name,
.nickname,
.empty-title,
.menu-text,
.record-type-label,
.card-title {
  color: var(--theme-text, #243044) !important;
}

.filter-row,
.filter-bar,
.segment-control,
.segmented-control,
.cat-filter,
.tabs-wrap {
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), .14) !important;
}

.filter-item,
.filter-tag,
.seg-item,
.tab {
  color: var(--theme-text-secondary, #6E7A8A);
}

.tag,
.cat-filter-tab,
.seg-item,
.preset-btn,
.gender-option,
.type-btn,
.badge,
.status-tag {
  border-radius: 999rpx !important;
}

.seg-active,
.cat-filter-tab.active,
.preset-btn.active,
.type-btn.active,
.gender-option.active {
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5)) !important;
  color: var(--theme-primary-deep, #2F8DB8) !important;
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), 0.45) !important;
  box-shadow: none !important;
}

.modal-mask,
.sheet-mask,
.quick-modal-mask,
.breed-modal-mask,
.card-preview-wrap {
  background: rgba(36, 48, 68, 0.42) !important;
  backdrop-filter: blur(6rpx);
}

.modal-dialog,
.weight-modal,
.sheet-content,
.quick-modal,
.breed-modal,
.card-preview {
  border-radius: 28rpx !important;
  background: #fff !important;
  box-shadow: 0 24rpx 60rpx rgba(36, 48, 68, 0.18) !important;
}

.empty,
.empty-state,
.empty-records,
.empty-cats,
.not-logged-in,
.guest-banner {
  color: #7B8798;
}

.empty-illustration,
.guest-illustration,
.stat-icon-wrap,
.menu-icon-wrap,
.avatar-placeholder,
.cat-avatar-placeholder {
  background: linear-gradient(135deg, var(--theme-secondary-soft, #EAF7F5), #FFF2E3) !important;
  box-shadow: 0 12rpx 28rpx rgba(var(--theme-primary-rgb, 91, 167, 216), 0.14) !important;
}

.danger,
.delete,
.tag-danger,
.card-danger {
  color: #F36B6B !important;
}

.edit-record,
.action-btn.edit,
.record-status.status-shipped {
  color: var(--theme-primary-deep, #2F8DB8) !important;
  background: var(--theme-primary-soft, #EAF4FB) !important;
}

.admin-act,
.tracking-no {
  color: var(--theme-primary-deep, #2F8DB8) !important;
}

.warning,
.urgent,
.tag-warning,
.tag-urgent {
  color: #E39138 !important;
}

.fab-wrap,
.add-section,
.btn-section {
  background: transparent !important;
  box-shadow: none !important;
}

.footer-hint {
  color: #A5AFBC !important;
}

.ui-hero-card {
  margin: 0 -8rpx 28rpx;
  padding: 0 8rpx 4rpx;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  border: none;
  overflow: visible;
}

.ui-hero-img {
  width: 100%;
  height: 280rpx;
  border-radius: 0;
  display: block;
  margin-bottom: 8rpx;
  opacity: 0.98;
  filter: saturate(1.04);
}

.ui-hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
  color: #172235;
  line-height: 1.25;
  margin-bottom: 10rpx;
}

.ui-hero-subtitle {
  display: block;
  font-size: 27rpx;
  color: #3F5268;
  line-height: 1.65;
  font-weight: 600;
}

.ui-empty-img {
  width: 260rpx;
  height: 180rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.ui-compact-hero {
  margin: 0 -8rpx 26rpx;
  padding: 0 8rpx 4rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  display: flex;
  align-items: center;
  gap: 20rpx;
  overflow: visible;
}

.ui-compact-hero-img {
  width: 190rpx;
  height: 150rpx;
  border-radius: 0;
  flex-shrink: 0;
  margin-right: 12rpx;
  opacity: 0.98;
  filter: saturate(1.04);
}

.ui-compact-hero-body {
  flex: 1;
  min-width: 0;
}

.ui-tab-hero {
  width: 100%;
  min-height: 168rpx;
  margin: 0 0 20rpx;
  padding: 24rpx;
  gap: 20rpx;
  box-sizing: border-box;
}

.ui-tab-hero .ui-compact-hero-img {
  width: 150rpx;
  height: 120rpx;
  margin-right: 0;
  border-radius: 22rpx;
}

.ui-compact-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0;
  color: #5BA7D8;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.ui-compact-title {
  display: block;
  font-size: 34rpx;
  color: #172235;
  font-weight: 900;
  line-height: 1.25;
  margin-bottom: 8rpx;
}

.ui-compact-desc {
  display: block;
  font-size: 25rpx;
  color: #3F5268;
  line-height: 1.6;
  font-weight: 600;
}

.ui-admin-hero {
  background: transparent;
  color: #243044;
  border: none;
}

.ui-admin-hero .ui-compact-kicker,
.ui-admin-hero .ui-compact-desc {
  color: #3F5268;
}

.ui-admin-hero .ui-compact-title {
  color: #172235;
}

/* 服务功能页 Hero：沿用主题装扮页的卡片、构图和主题融合方式 */
.service-feature-hero-shell {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.service-feature-hero {
  min-height: 210rpx;
  margin: 0 0 24rpx;
  padding: 28rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 26rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .12);
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.94), var(--theme-primary-soft, #EAF4FB));
  box-shadow: 0 14rpx 34rpx rgba(68, 92, 120, .08);
}

.service-feature-art {
  position: relative;
  width: 176rpx;
  height: 142rpx;
  flex: 0 0 176rpx;
}

.service-feature-art-back,
.service-feature-art-mid,
.service-feature-art-front {
  position: absolute;
  box-sizing: border-box;
  border: 7rpx solid rgba(255,255,255,.88);
  box-shadow: 0 10rpx 22rpx rgba(68,92,120,.11);
}

.service-feature-art-back {
  left: 4rpx;
  top: 34rpx;
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, var(--theme-primary, #5BA7D8), var(--theme-secondary, #6BC6B3));
  transform: rotate(-8deg);
  opacity: .88;
}

.service-feature-art-mid {
  right: 2rpx;
  top: 18rpx;
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, var(--theme-secondary-soft, #EAF7F5), var(--theme-primary-soft, #EAF4FB));
  transform: rotate(9deg);
}

.service-feature-art-front {
  left: 55rpx;
  top: 39rpx;
  width: 78rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: rgba(255,255,255,.96);
}

.service-feature-art-icon {
  width: 46rpx;
  height: 46rpx;
}

.service-feature-art-dot {
  position: absolute;
  right: 18rpx;
  bottom: 9rpx;
  width: 24rpx;
  height: 24rpx;
  border: 6rpx solid rgba(255,255,255,.9);
  border-radius: 50%;
  background: var(--theme-warning, #FFB86B);
  box-shadow: 0 6rpx 14rpx rgba(68,92,120,.10);
}

.service-feature-copy {
  flex: 1;
  min-width: 0;
}

.service-feature-kicker,
.service-feature-title,
.service-feature-desc {
  display: block;
}

.service-feature-kicker {
  color: var(--theme-primary-deep, #2F8DB8);
  font-size: 20rpx;
  font-weight: 900;
}

.service-feature-title {
  margin-top: 5rpx;
  color: var(--theme-text, #243044);
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.25;
}

.service-feature-desc {
  margin-top: 8rpx;
  color: var(--theme-text-secondary, #6E7A8A);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}

.service-feature-hero.admin .service-feature-art-back {
  background: linear-gradient(135deg, var(--theme-primary-deep, #2F8DB8), var(--theme-secondary-deep, #3F9486));
}

.service-feature-hero.admin .service-feature-art-mid {
  background: linear-gradient(135deg, #FFF4E6, var(--theme-primary-soft, #EAF4FB));
}

@media (max-width: 340px) {
  .service-feature-hero {
    min-height: 190rpx;
    padding: 24rpx;
    gap: 18rpx;
  }

  .service-feature-art {
    width: 140rpx;
    height: 122rpx;
    flex-basis: 140rpx;
    transform: scale(.86);
    transform-origin: center;
  }

  .service-feature-title { font-size: 32rpx; }
  .service-feature-desc { font-size: 22rpx; }
}

.ui-empty-panel {
  min-height: 360rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(145deg, rgba(255,255,255,.86), var(--theme-primary-soft, #EAF4FB));
  border: 1rpx dashed rgba(var(--theme-primary-rgb, 91, 167, 216), .28);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44rpx 32rpx;
  text-align: center;
}

.empty-state .ui-empty-img,
.empty-tip .ui-empty-img,
.empty-records .ui-empty-img,
.empty-cats .ui-empty-img,
.empty-state .reminder-empty-img,
.guest-banner .reminder-empty-img,
.empty-img {
  padding: 12rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 50% 44%, rgba(255,255,255,.94) 0 38%, transparent 70%),
    linear-gradient(145deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .10);
}

.ui-soft-divider {
  height: 1rpx;
  background: #EEF2F6;
  margin: 24rpx 0;
}

.ui-icon {
  width: 44rpx;
  height: 44rpx;
  display: inline-block;
  vertical-align: middle;
  flex-shrink: 0;
}

.ui-icon-sm {
  width: 32rpx;
  height: 32rpx;
}

.ui-icon-md {
  width: 52rpx;
  height: 52rpx;
}

.ui-icon-lg {
  width: 72rpx;
  height: 72rpx;
}

.ui-icon-xl {
  width: 96rpx;
  height: 96rpx;
}

.ui-inline-icon {
  width: 30rpx;
  height: 30rpx;
  display: inline-block;
  vertical-align: -5rpx;
  margin-right: 6rpx;
}

.menu-icon-img,
.stat-icon-img,
.login-feature-img,
.type-icon-img,
.record-icon-img,
.quick-icon-img,
.section-icon-img,
.placeholder-icon-img,
.banner-icon-img {
  display: block;
  width: 100%;
  height: 100%;
}

.menu-icon-wrap,
.stat-icon-wrap,
.exp-icon-wrap,
.record-icon,
.timeline-dot {
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-wrap .ui-icon,
.stat-icon-wrap .ui-icon {
  width: 44rpx;
  height: 44rpx;
}

.type-btn .ui-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.quick-btn .ui-icon,
.timeline-dot .ui-icon,
.record-icon .ui-icon {
  width: 46rpx;
  height: 46rpx;
}

.page-header,
.nav-bar,
.cat-filter-tabs,
.status-segment,
.tab-bar,
.search-bar,
.cat-tabs-scroll,
.period-tabs-scroll,
.filter-row {
  border-radius: 22rpx !important;
  background: rgba(255,255,255,0.72) !important;
  border: 1rpx solid rgba(91, 167, 216, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(68, 92, 120, 0.06) !important;
}

.page-title,
.app-name,
.sheet-title,
.modal-title,
.modal-title-text,
.editor-title,
.mc-total,
.ys-total,
.balance-num,
.points-num-big,
.weight-number {
  color: #243044 !important;
  letter-spacing: 0 !important;
}

.empty-tip,
.empty-state,
.empty,
.empty-records,
.empty-cats {
  border-radius: 28rpx !important;
  background:
    linear-gradient(145deg, rgba(255,255,255,.82), var(--theme-primary-soft, #EAF4FB)) !important;
  border: 1rpx dashed rgba(var(--theme-primary-rgb, 91, 167, 216), .22);
  box-shadow: none !important;
}

.submit-btn,
.register-btn,
.btn-confirm,
.post-btn,
.search-btn,
.back-btn,
.abtn-main,
.s-confirm,
.e-btn.confirm,
.add-btn {
  background: linear-gradient(135deg, var(--theme-primary-deep, #2F8DB8), var(--theme-primary, #5BA7D8)) !important;
  color: #fff !important;
  border-radius: 999rpx !important;
}

.cancel,
.quick-btn-cancel,
.s-btn.cancel,
.s-cancel,
.e-btn.cancel,
.modal-btn.cancel,
.wm-btn.cancel {
  background: #F2F6FA !important;
  color: #7B8798 !important;
  border-radius: 999rpx !important;
}

.delete,
.delete-record,
.delete-act,
.act-btn.danger,
.addr-act-btn.danger,
.fb-act.delete-act {
  color: #F36B6B !important;
}

.item-badge,
.default-tag,
.record-type-tag,
.qty-badge,
.section-badge,
.fb-cat,
.st {
  border-radius: 999rpx !important;
}

.offline-tip {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  background: #FFF4DF;
  border-bottom: 2rpx solid rgba(255,184,107,0.36);
}
.offline-tip__icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.offline-tip__text {
  font-size: 24rpx;
  color: #8B5A20;
}

