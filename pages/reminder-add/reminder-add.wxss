/* pages/reminder-add/reminder-add.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx 24rpx 24rpx;
  box-sizing: border-box;
  padding-bottom: 180rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
}

.form-group { margin-bottom: 36rpx; }

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.required { color: #ff4d4f; }

.picker {
  background: #f8f9fc;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.picker-value {
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-value.placeholder { color: #bbb; }

.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.type-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  background: #f8f9fc;
  border: 2rpx solid transparent;
  color: #666;
}

.type-icon { font-size: 44rpx; margin-bottom: 8rpx; }
.type-label { font-size: 24rpx; }

.type-btn.active {
  background: #e8f4ff;
  border-color: #4A90D9;
  color: #4A90D9;
}

.interval-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.interval-text { font-size: 30rpx; color: #333; }

.interval-input {
  width: 120rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  text-align: center;
  border: 2rpx solid transparent;
  color: #333;
}

.interval-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preset-btn {
  padding: 10rpx 24rpx;
  background: #f0f4ff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.preset-btn.active {
  background: #4A90D9;
  color: #fff;
  border-color: #4A90D9;
}

.textarea {
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  min-height: 140rpx;
  border: 2rpx solid transparent;
}

.next-preview {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fffbf0;
  border: 2rpx solid #ffe58f;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}

.preview-icon { font-size: 32rpx; }
.preview-text { font-size: 28rpx; color: #d48806; font-weight: 600; }

.field-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  padding-left: 4rpx;
}

.btn-section {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom));
  bottom: calc(constant(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 999;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.save-btn {
  width: 100%;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 48rpx;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.35);
}

.save-btn::after { border: none; }

/* 无可用宠物空状态 */
.empty-cats {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-cats-icon { font-size: 100rpx; margin-bottom: 24rpx; }

.empty-cats-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-cats-desc {
  font-size: 26rpx;
  color: #999;
}
