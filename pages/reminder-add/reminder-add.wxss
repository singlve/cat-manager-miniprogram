/* pages/reminder-add/reminder-add.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx 24rpx 24rpx;
  box-sizing: border-box;
  padding-bottom: 180rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
}

.form-group { margin-bottom: 36rpx; }

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.required { color: #ff4d4f; }

.picker {
  background: #f8f9fc;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.custom-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  background: #F7F9FB;
  border-color: #E8EEF4;
  box-shadow: inset 0 0 0 1rpx rgba(91, 167, 216, 0.02);
  box-sizing: border-box;
  overflow: hidden;
}

.picker-value {
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-value.placeholder { color: #bbb; }

.custom-picker .picker-value {
  height: 92rpx;
  line-height: 92rpx;
  padding: 0 0 0 28rpx;
  background: transparent !important;
  border-radius: 0 !important;
  box-sizing: border-box;
}

.picker-arrow {
  width: 72rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-chevron {
  width: 12rpx;
  height: 12rpx;
  margin-top: -6rpx;
  border-right: 4rpx solid #5BA7D8;
  border-bottom: 4rpx solid #5BA7D8;
  transform: rotate(45deg);
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.type-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  background: #f8f9fc;
  border: 2rpx solid transparent;
  color: #666;
}

.type-icon { font-size: 44rpx; margin-bottom: 8rpx; }
.type-label { font-size: 24rpx; }

.type-btn.active {
  background: #e8f4ff;
  border-color: #5BA7D8;
  color: #5BA7D8;
}

.interval-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.interval-text { font-size: 30rpx; color: #333; }

.interval-input {
  width: 120rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  text-align: center;
  border: 2rpx solid transparent;
  color: #333;
}

.interval-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preset-btn {
  padding: 10rpx 24rpx;
  background: #f0f4ff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.preset-btn.active {
  background: #5BA7D8;
  color: #fff;
  border-color: #5BA7D8;
}

.textarea {
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  min-height: 140rpx;
  border: 2rpx solid transparent;
}

.next-preview {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fffbf0;
  border: 2rpx solid #ffe58f;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}

.preview-icon { font-size: 32rpx; }
.preview-text { font-size: 28rpx; color: #d48806; font-weight: 600; }

.field-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  padding-left: 4rpx;
}

.btn-section {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom));
  bottom: calc(constant(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 999;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: transparent;
  pointer-events: none;
}

.save-btn {
  width: 100%;
  max-width: 686rpx;
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 48rpx;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.35);
  pointer-events: auto;
}

.save-btn::after { border: none; }

/* 无可用宠物空状态 */
.empty-cats {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-cats-icon { font-size: 100rpx; margin-bottom: 24rpx; }

.empty-cats-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-cats-desc {
  font-size: 26rpx;
  color: #999;
}

.cat-picker-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1200;
  background: rgba(26, 39, 58, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.cat-picker-panel {
  width: 100%;
  max-height: 76vh;
  border-radius: 36rpx;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F2FBFA 0%, #F7FAFD 46%, #FFFFFF 100%);
  border: 1rpx solid rgba(91, 167, 216, 0.16);
  box-shadow: 0 28rpx 70rpx rgba(24, 76, 108, 0.2);
}

.cat-picker-head {
  padding: 8rpx 8rpx 22rpx;
}

.cat-picker-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #243044;
  line-height: 1.3;
}

.cat-picker-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6E7A8A;
  line-height: 1.4;
}

.cat-picker-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 520rpx;
  overflow-y: auto;
}

.cat-picker-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 104rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid transparent;
  box-shadow: 0 10rpx 28rpx rgba(43, 103, 139, 0.07);
  box-sizing: border-box;
}

.cat-picker-item.active {
  border-color: rgba(91, 167, 216, 0.5);
  background: #EAF4FB;
}

.cat-picker-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #EAF4FB, #EAF7F5);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.cat-picker-avatar image {
  width: 100%;
  height: 100%;
}

.cat-picker-icon {
  width: 38rpx !important;
  height: 38rpx !important;
}

.cat-picker-info {
  flex: 1;
  min-width: 0;
}

.cat-picker-name {
  display: block;
  font-size: 29rpx;
  font-weight: 800;
  color: #243044;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cat-picker-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #6E7A8A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cat-picker-check {
  width: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  flex-shrink: 0;
}

.cat-picker-cancel {
  margin-top: 18rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.9);
  color: #6E7A8A;
  font-size: 28rpx;
  font-weight: 700;
}
