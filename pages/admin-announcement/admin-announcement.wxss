page { background: #f5f6fa; }

.post-box { background: #fff; padding: 24rpx 32rpx; margin-bottom: 16rpx; }
.post-input { width: 100%; min-height: 120rpx; padding: 16rpx; background: #f5f6fa; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; }
.post-btn { width: 100%; height: 80rpx; line-height: 80rpx; margin-top: 16rpx; background: #4A90D9; color: #fff; font-size: 30rpx; font-weight: 600; border-radius: 12rpx; padding: 0; }
.post-btn::after { border: none; }
.post-btn.disabled { opacity: .5; }

.list { padding: 0 24rpx; }
.card { background: #fff; padding: 24rpx; border-radius: 12rpx; margin-bottom: 16rpx; }
.card-top { display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 16rpx; }
.status-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #ccc; margin-top: 8rpx; flex-shrink: 0; }
.status-dot.active { background: #4CAF50; }
.card-content { font-size: 28rpx; color: #333; flex: 1; line-height: 1.5; }
.card-actions { display: flex; gap: 24rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.act { font-size: 26rpx; color: #4A90D9; }
.act.danger { color: #e74c3c; }

.loading-box, .empty-state { text-align: center; padding: 120rpx 0; color: #999; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; margin-top: 16rpx; display: block; }
