<view class="page">
  <view wx:if="{{!isAdmin}}" class="empty-state"><image class="ui-empty-img" src="/assets/illustrations/admin-dashboard-transparent.png" mode="aspectFill" /><text class="empty-text">无权访问</text></view>

  <block wx:else>
    <view class="ui-compact-hero ui-admin-hero">
      <image class="ui-compact-hero-img" src="/assets/illustrations/admin-dashboard-transparent.png" mode="aspectFit" />
      <view class="ui-compact-hero-body">
        <text class="ui-compact-kicker">ADMIN</text>
        <text class="ui-compact-title">公告管理</text>
        <text class="ui-compact-desc">发布、启用和撤回公告，前台展示会跟随当前有效公告同步。</text>
      </view>
    </view>

    <!-- 发布 -->
    <view class="post-box">
      <view class="post-head">
        <view>
          <text class="post-title">发布新公告</text>
          <text class="post-desc">启用后会同步展示在首页。</text>
        </view>
        <text class="post-count">{{content.length || 0}}/200</text>
      </view>
      <textarea class="post-input" placeholder="输入公告内容..." value="{{content}}" bindinput="onContentInput" maxlength="200" auto-height/>
      <button class="post-btn {{posting ? 'disabled' : ''}}" bindtap="doPost">{{posting ? '发布中...' : '发布公告'}}</button>
    </view>

    <!-- 列表 -->
    <view wx:if="{{loading}}" class="loading-box"><text>加载中...</text></view>
    <view wx:else class="list">
      <view wx:if="{{list.length === 0}}" class="empty-state"><image class="ui-empty-img" src="/assets/illustrations/admin-dashboard-transparent.png" mode="aspectFill" /><text class="empty-text">暂无公告</text></view>
      <view class="card" wx:for="{{list}}" wx:key="_id">
        <view class="card-top">
          <view class="status-chip {{item.isActive ? 'active' : ''}}">
            <view class="status-dot"></view>
            <text>{{item.isActive ? '展示中' : '已停用'}}</text>
          </view>
          <text class="card-content">{{item.content}}</text>
        </view>
        <view class="card-actions">
          <text class="act {{item.isActive ? 'danger' : ''}}" catchtap="toggle" data-id="{{item._id}}">{{item.isActive ? '停用' : '启用'}}</text>
          <text class="act danger" catchtap="doDelete" data-id="{{item._id}}">删除</text>
        </view>
      </view>
    </view>
  </block>
</view>
