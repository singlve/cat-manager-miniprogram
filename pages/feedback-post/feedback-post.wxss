page { background: var(--theme-bg, #F7F9FB); }
.page {
  min-height: 100vh;
  padding-bottom: 36rpx;
  background: linear-gradient(180deg, var(--theme-secondary-soft, #EAF7F5) 0%, rgba(247,249,251,0) 360rpx), var(--theme-bg, #F7F9FB) !important;
}

.section {
  margin: 0 24rpx 18rpx;
  padding: 26rpx;
  background: rgba(255,255,255,.96);
}
.section-label {
  font-size: 27rpx; font-weight: 900; color: #243044;
  display: block; margin-bottom: 16rpx;
}

.picker-val {
  min-height: 78rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F5F9FC;
  border: 1rpx solid #E8EEF4;
  border-radius: 18rpx;
  font-size: 29rpx;
  color: #243044;
  font-weight: 700;
}
.picker-chevron {
  width: 11rpx; height: 11rpx;
  margin-top: -5rpx;
  border-right: 3rpx solid var(--theme-primary, #5BA7D8);
  border-bottom: 3rpx solid var(--theme-primary, #5BA7D8);
  transform: rotate(45deg);
}

.content-input {
  width: 100%; min-height: 320rpx;
  font-size: 30rpx; line-height: 1.6;
  background: #F5F9FC; border-radius: 18rpx;
  border: 1rpx solid #E8EEF4;
  padding: 16rpx 20rpx; box-sizing: border-box;
}
.char-count {
  font-size: 24rpx; color: #A5AFBC;
  text-align: right; display: block; padding-top: 8rpx;
}

/* ── images ── */
.image-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
}
.img-item {
  position: relative;
  width: 160rpx; height: 160rpx;
  border-radius: 18rpx; overflow: hidden;
}
.img-preview {
  width: 100%; height: 100%;
}
.img-mask {
  position: absolute; inset: 0;
  background: rgba(0,0,0,.45);
  display: flex; align-items: center; justify-content: center;
}
.img-mask text { color: #fff; font-size: 22rpx; }
.img-error { background: rgba(231,76,60,.7); }
.img-del {
  position: absolute; top: 8rpx; right: 8rpx;
  width: 42rpx; height: 42rpx;
  background: rgba(36,48,68,.72); color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx;
}

.img-add {
  width: 160rpx; height: 160rpx;
  border: 2rpx dashed rgba(var(--theme-primary-rgb, 91, 167, 216), .42); border-radius: 18rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: linear-gradient(135deg, #F3F9FD, #F1FAF8);
}
.img-add-icon { font-size: 48rpx; color: var(--theme-primary, #5BA7D8); }
.img-add-text { font-size: 22rpx; color: #6E7A8A; margin-top: 4rpx; }

/* ── submit ── */
.btn-area { padding: 32rpx; }
.submit-btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
  color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 999rpx; text-align: center;
  padding: 0; margin: 0;
}
.submit-btn::after { border: none; }
.submit-btn.disabled { opacity: .5; }

.category-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
  background: rgba(36,48,68,.48);
}
.category-panel {
  width: 100%;
  padding: 32rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background: linear-gradient(180deg, var(--theme-secondary-soft, #F2FBFA), #FFFFFF);
  box-shadow: 0 28rpx 70rpx rgba(24,76,108,.22);
}
.category-accent {
  width: 64rpx; height: 7rpx; margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--theme-primary, #5BA7D8), var(--theme-secondary, #6BC6B3));
}
.category-title, .category-desc { display: block; text-align: center; }
.category-title { color: #243044; font-size: 32rpx; font-weight: 900; }
.category-desc { margin-top: 8rpx; color: #7B8798; font-size: 23rpx; }
.category-options { margin-top: 24rpx; display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; }
.category-option {
  height: 76rpx;
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  border: 1rpx solid #E8EEF4;
  border-radius: 18rpx;
  background: #FFFFFF;
  color: #536579;
  font-size: 27rpx;
  font-weight: 800;
}
.category-option.active { border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), .45); background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5)); color: var(--theme-primary-deep, #2F8DB8); }
.category-check {
  width: 12rpx; height: 7rpx;
  border-left: 3rpx solid var(--theme-primary, #5BA7D8);
  border-bottom: 3rpx solid var(--theme-primary, #5BA7D8);
  transform: rotate(-45deg);
}
.category-cancel {
  margin-top: 20rpx; padding: 18rpx 0;
  border-radius: 999rpx;
  background: #EEF4F8;
  color: #6E7A8A;
  font-size: 27rpx; font-weight: 800; text-align: center;
}
