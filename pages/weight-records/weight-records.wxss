/* pages/weight-records/weight-records.wxss */

.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* ─── 页面头部 ─── */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.page-title { font-size: 40rpx; font-weight: 800; color: #1a1a1a; }
.add-btn {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
}

/* ─── 宠物筛选标签 ─── */
.cat-tabs-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
}
.cat-tabs { display: inline-flex; gap: 16rpx; }
.cat-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #e8e8e8;
  flex-shrink: 0;
}
.cat-tab.active {
  background: #4A90D9;
  color: #fff;
  border-color: #4A90D9;
}

/* ─── 时间段筛选标签 ─── */
.period-tabs-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}
.period-tabs { display: inline-flex; gap: 16rpx; }
.period-tab {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #888;
  border: 2rpx solid #e8e8e8;
  flex-shrink: 0;
}
.period-tab.active {
  background: #43a047;
  color: #fff;
  border-color: #43a047;
}

/* ─── 自定义时间范围 ─── */
.custom-date-range {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 18rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.date-range-picker {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
}
.date-range-label {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 700;
}
.date-range-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.date-range-sep {
  font-size: 28rpx;
  color: #999;
  font-weight: 600;
}

/* ─── 空状态 ─── */
.empty { display: flex; flex-direction: column; align-items: center; padding-top: 80rpx; }
.empty-illustration {
  width: 200rpx; height: 200rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(76,175,80,0.2);
}
.empty-emoji { font-size: 96rpx; }
.empty-text { font-size: 32rpx; color: #333; font-weight: 700; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: #999; margin-bottom: 48rpx; text-align: center; max-width: 420rpx; line-height: 1.6; }
.empty-cta {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff; font-size: 28rpx; font-weight: 600;
  border-radius: 48rpx; padding: 24rpx 60rpx;
  box-shadow: 0 8rpx 30rpx rgba(74,144,217,0.35);
}

/* ─── 汇总卡片 ─── */
.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.summary-items-row {
  display: flex;
  align-items: center;
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}
.summary-label { font-size: 22rpx; color: #999; white-space: nowrap; }
.summary-value { font-size: 34rpx; font-weight: 800; color: #333; white-space: nowrap; }
.summary-value.up { color: #f57c00; }
.summary-value.down { color: #43a047; }
.summary-divider {
  width: 1rpx; height: 60rpx;
  background: #eee;
  flex-shrink: 0;
}
.summary-add-row {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
  font-size: 26rpx;
  color: #4A90D9;
  font-weight: 600;
}

/* ─── 记录列表 ─── */
.record-list { display: flex; flex-direction: column; gap: 16rpx; }

.record-cat-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 16rpx;
}
.cat-avatar-sm {
  width: 40rpx; height: 40rpx; border-radius: 50%; overflow: hidden;
}
.cat-avatar-placeholder { font-size: 32rpx; }
.cat-name-label { font-size: 26rpx; color: #666; font-weight: 600; }

.record-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.record-main {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.record-weight-block {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  min-width: 0;
  flex-shrink: 0;
}
.record-weight {
  font-size: 46rpx;
  font-weight: 900;
  color: #333;
  line-height: 1;
}
.record-unit {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

.record-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.record-date { font-size: 26rpx; color: #333; font-weight: 600; }
.record-ago  { font-size: 22rpx; color: #999; }
.record-note { font-size: 24rpx; color: #888; }

.record-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: center;
  flex-shrink: 0;
}
.action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 600;
}
.action-btn.edit {
  background: #e3f2fd;
  color: #1976d2;
}
.action-btn.delete {
  background: #fce4ec;
  color: #c62828;
}

/* ─── 弹窗 ─── */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-dialog {
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}
.modal-title { font-size: 36rpx; font-weight: 800; color: #333; display: block; margin-bottom: 36rpx; text-align: center; }

.edit-field {
  margin-bottom: 28rpx;
}
.edit-label { font-size: 26rpx; color: #666; font-weight: 600; display: block; margin-bottom: 12rpx; }
.date-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.date-picker-value { font-size: 28rpx; color: #333; }
.date-picker-arrow { font-size: 26rpx; color: #4A90D9; }
.edit-input {
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}
.weight-input { font-size: 36rpx !important; font-weight: 700; }

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
}
.modal-btn.cancel {
  background: #f5f6fa;
  color: #666;
}
.modal-btn.confirm {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(74,144,217,0.35);
}

/* ─── 折线图 ─── */
.chart-canvas {
  width: 100%;
  height: 440rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.btn-hover { opacity: 0.75; }
.list-footer { padding: 24rpx; text-align: center; }
.list-footer-text { font-size: 24rpx; color: #999; }
