/* pages/mine/mine.wxss */
page { background: #f0f2f7; }
.page { padding-bottom: 60rpx; }

/* ─── 未登录状态 ─── */
.not-logged-in { min-height: 100vh; }

.login-features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin: 60rpx 48rpx 48rpx;
}
.login-feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  width: calc(50% - 10rpx);
  box-sizing: border-box;
}
.login-feature-icon { font-size: 36rpx; }
.login-feature-text { font-size: 26rpx; color: #555; }

.login-main-btn {
  display: block;
  margin: 20rpx 60rpx 0;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 50rpx; padding: 28rpx 0;
  box-shadow: 0 12rpx 36rpx rgba(74,144,217,0.4);
  border: none;
}
.login-main-btn::after { border: none; }

/* ─── 头像卡片 ─── */
.profile-card {
  margin: 32rpx 32rpx 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(74, 144, 217, 0.18);
}

.profile-bg {
  background: #fff;
  padding: 40rpx 36rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
  border: 5rpx solid rgba(255,255,255,0.9);
}

.avatar-emoji { font-size: 64rpx; }
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.profile-info { flex: 1; }

.nickname {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.phone-hint {
  font-size: 24rpx;
  color: #ccc;
  display: block;
  margin-top: 4rpx;
}

/* ─── 积分签到卡片 ─── */
.points-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.points-header {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-bottom: 28rpx;
}

.points-header-left { display: flex; flex-direction: column; }

.points-balance-new {
  display: flex; align-items: baseline; gap: 6rpx;
}

.points-num-big {
  font-size: 52rpx; font-weight: 900; color: #1a1a1a;
  line-height: 1;
}

.points-unit {
  font-size: 24rpx; color: #999; font-weight: 600;
}

/* 积分 + 补签卡同行 */
.points-balance-row {
  display: flex; align-items: baseline; gap: 24rpx;
}

.makeup-badge-inline {
  display: flex; align-items: center; gap: 4rpx;
  background: #f5f7fc; border-radius: 20rpx;
  padding: 6rpx 16rpx;
}
.makeup-badge-inline:active { background: #e8edf5; }
.makeup-badge-icon { font-size: 24rpx; }
.makeup-badge-num { font-size: 22rpx; color: #4A90D9; font-weight: 700; }
.makeup-badge-arrow { font-size: 24rpx; color: #bbb; margin-left: 2rpx; }

/* 连签 + 抽奖提示同行 */
.streak-row {
  display: flex; align-items: center; margin-top: 8rpx;
}

.streak-text {
  font-size: 22rpx; color: #999;
}

.cumul-text {
  font-size: 22rpx; color: #999;
}

.days-until-text {
  font-size: 22rpx; color: #999;
}
.days-until-text.ready {
  color: #4A90D9; font-weight: 600;
}
.lottery-trigger {
  text-decoration: underline;
}

.checkin-btn {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff;
  font-size: 26rpx; font-weight: 600;
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
}
.checkin-btn.checked {
  background: #e8edf5;
  color: #999;
}

/* ─── 7日签到日历 ─── */
.calendar-row {
  display: flex; justify-content: space-between;
  padding: 20rpx 0 24rpx;
  border-top: 1rpx solid #f0f2f7;
  border-bottom: 1rpx solid #f0f2f7;
}

.cal-day {
  display: flex; flex-direction: column; align-items: center;
  gap: 10rpx;
  flex: 1;
}

.cal-weekday {
  font-size: 22rpx; color: #bbb;
}

.cal-circle {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: #f5f6fa;
  display: flex; align-items: center; justify-content: center;
}

.cal-date {
  font-size: 24rpx; color: #999;
}

.cal-check {
  font-size: 28rpx; color: #fff;
  font-weight: 700;
}

.cal-day.checked .cal-circle {
  background: #4A90D9;
}

.cal-day.today .cal-circle {
  box-shadow: 0 0 0 3rpx #4A90D9;
}

.cal-day.today.checked .cal-circle {
  box-shadow: 0 0 0 3rpx rgba(74,144,217,0.3);
}

/* 补签状态 */
.cal-day.can-makeup .cal-circle {
  border: 2rpx dashed #FF9500;
  background: #FFF8F0;
}
.cal-day.can-makeup:active .cal-circle {
  background: #FFE8CC;
  border-color: #E68600;
}

.cal-check.madeup { color: #FF9500; }

.cal-makeup-tag {
  font-size: 18rpx; color: #FF9500;
  height: 24rpx; line-height: 24rpx;
}
.cal-madeup-tag {
  font-size: 18rpx; color: #FF9500;
  height: 24rpx; line-height: 24rpx;
}
.cal-spacer { height: 24rpx; }

/* 满7天礼物盒 */
.gift-emoji {
  font-size: 40rpx; line-height: 1;
}

@keyframes bounceBox {
  0%, 100% { transform: translateY(0) scale(1); }
  20% { transform: translateY(-8rpx) scale(1.08); }
  40% { transform: translateY(2rpx) scale(0.96); }
  60% { transform: translateY(-5rpx) scale(1.04); }
  80% { transform: translateY(1rpx) scale(0.98); }
}

.bounce-anim {
  animation: bounceBox 1.2s ease-in-out infinite;
}

.cal-circle.gift-circle {
  background: linear-gradient(135deg, #ffeaa7, #fdcb6e) !important;
  box-shadow: 0 0 16rpx rgba(253,203,110,0.5);
}

/* ─── 展开/收起月历按钮 ─── */
.calendar-toggle {
  display: flex; align-items: center; justify-content: center;
  padding: 16rpx 0 8rpx;
  font-size: 24rpx; color: #4A90D9;
}
.calendar-toggle:active { opacity: 0.7; }

/* ─── 完整月历 ─── */
.month-calendar {
  border-top: 1rpx solid #f0f2f7;
  padding-top: 16rpx;
}

.month-weekday-row {
  display: flex; justify-content: space-around;
  margin-bottom: 12rpx;
}
.month-weekday {
  width: 56rpx; text-align: center;
  font-size: 22rpx; color: #bbb; font-weight: 600;
}

.month-week {
  display: flex; justify-content: space-around;
  margin-bottom: 8rpx;
}

.month-day {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: #f5f6fa;
  position: relative;
}
.month-day.empty { background: transparent; }
.month-day.checked { background: #4A90D9; }
.month-day.today {
  background: #f5f6fa;
  box-shadow: 0 0 0 3rpx #4A90D9;
}
.month-day.today.checked {
  background: #4A90D9;
  box-shadow: 0 0 0 3rpx rgba(74,144,217,0.3);
}
.month-day.can-makeup {
  background: #FFF8F0;
  border: 2rpx dashed #FF9500;
  box-sizing: border-box;
}
.month-day.can-makeup:active { background: #FFE8CC; }
.month-day.future { opacity: 0.35; }

.month-day-num {
  font-size: 22rpx; color: #999;
  line-height: 1;
}
.month-day.checked .month-day-num { color: #fff; font-weight: 600; }
.month-day.today .month-day-num { color: #4A90D9; font-weight: 700; }
.month-day.today.checked .month-day-num { color: #fff; font-weight: 700; }

.month-day-check {
  position: absolute; top: -4rpx; right: -4rpx;
  width: 28rpx; height: 28rpx;
  border-radius: 50%;
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 16rpx; color: #4A90D9; font-weight: 700;
}
.month-day-check.madeup { color: #FF9500; }

.month-day-gift {
  position: absolute; top: -6rpx; right: -6rpx;
  font-size: 24rpx;
}

/* ─── 抽奖转盘 ─── */
.wheel-container {
  position: relative; width: 520rpx; height: 520rpx;
  margin: 0 auto 24rpx;
}

.wheel-pointer {
  position: absolute; top: -32rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-top: 32rpx solid #e74c3c;
  z-index: 10;
  filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.2));
}

.wheel {
  position: relative;
  width: 100%; height: 100%;
  border-radius: 50%;
  overflow: hidden;
  background: conic-gradient(
    #FF6B6B 0deg 60deg,
    #4ECDC4 60deg 120deg,
    #FFE66D 120deg 180deg,
    #A8E6CF 180deg 240deg,
    #FF8B94 240deg 300deg,
    #B8A9C9 300deg 360deg
  );
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12), inset 0 0 0 12rpx #fff;
  transition: transform 4s cubic-bezier(0.17, 0.67, 0.12, 0.99);
}

.wheel-center {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff;
  font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(74,144,217,0.4);
  z-index: 5;
}
.wheel-center.disabled {
  background: #ccc;
  box-shadow: none;
  pointer-events: none;
}

/* 转盘文字标签（在 wheel 内部，跟随旋转） */
.wheel-labels {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
}
.wheel-label {
  position: absolute;
  top: 50%; left: 50%;
  transform-origin: 0 0;
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.4);
  white-space: nowrap;
  writing-mode: vertical-lr;
  text-orientation: upright;
  letter-spacing: 2rpx;
}

.lottery-result {
  text-align: center; padding: 20rpx 0 8rpx;
  font-size: 30rpx; font-weight: 700;
}

.lottery-result-label {
  display: block;
}

/* ─── 底部 ─── */
.points-footer {
  display: flex; align-items: center; justify-content: center;
  margin-top: 20rpx; gap: 24rpx;
}

.streak-text {
  font-size: 24rpx; color: #999;
}

.points-entry {
  display: flex; align-items: center; gap: 4rpx;
  padding: 16rpx 24rpx;
}

.points-entry-text { font-size: 26rpx; color: #4A90D9; }
.points-entry-arrow { font-size: 32rpx; color: #4A90D9; }

.points-divider {
  width: 1rpx; height: 28rpx;
  background: #d0d0d0;
}

/* ─── 分享任务弹窗 ─── */
.share-task-sheet {
  padding-bottom: 48rpx;
}

.share-task-btn {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff;
  font-size: 28rpx; font-weight: 600;
  padding: 20rpx 0;
  border-radius: 48rpx;
  text-align: center;
  width: 100%;
  border: none;
  line-height: 1.4;
}
.share-task-btn::after { border: none; }

/* ─── 数据统计区 ─── */
.stats-section { padding: 0 32rpx; margin-bottom: 24rpx; }

.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.stat-item:active { opacity: 0.75; }

.stat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}
.cat-icon { background: linear-gradient(135deg, #e8f0ff, #d4e4ff); }
.reminder-icon { background: linear-gradient(135deg, #fff4e5, #ffe8cc); }
.record-icon { background: linear-gradient(135deg, #e8faf0, #d4f5e4); }

.stat-icon { font-size: 40rpx; }

.stat-num {
  font-size: 48rpx;
  font-weight: 900;
  color: #1a1a1a;
  display: block;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #f0f0f0;
}

/* ─── 菜单列表 ─── */
.menu-card {
  margin: 0 32rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.06);
}

.menu-group-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
  padding: 24rpx 36rpx 12rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 2rpx solid #f8f9fc;
  position: relative;
}
.menu-item:last-of-type { border-bottom: none; }
.menu-item:active { background: #f8f9fc; }

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.icon-blue { background: linear-gradient(135deg, #e8f0ff, #d4e4ff); }
.icon-green { background: linear-gradient(135deg, #e8faf0, #d4f5e4); }
.icon-orange { background: linear-gradient(135deg, #fff4e5, #ffe8cc); }
.icon-purple { background: linear-gradient(135deg, #f5e8ff, #ead4ff); }
.icon-teal { background: linear-gradient(135deg, #e8faf5, #d4f5e8); }

.menu-icon-text { font-size: 36rpx; }

.menu-text-wrap { flex: 1; }

.menu-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #bbb;
  display: block;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ddd;
}
.notify-badge {
  background: #e74c3c; color: #fff;
  font-size: 20rpx; min-width: 32rpx; height: 32rpx;
  line-height: 32rpx; text-align: center;
  border-radius: 16rpx; padding: 0 8rpx;
  position: absolute; right: 64rpx; top: 50%;
  transform: translateY(-50%);
}

.menu-divider { height: 2rpx; background: #f5f5f5; margin: 0; }

/* 🛠 开发者重置签到 */
.dev-reset-bar {
  margin: 0 32rpx 16rpx;
}
.dev-reset-btn {
  width: 100%;
  background: #fff;
  color: #999;
  font-size: 24rpx;
  border-radius: 12rpx;
  padding: 20rpx 0;
  border: 1rpx dashed #ddd;
  text-align: center;
}
.dev-reset-btn::after { border: none; }
.dev-reset-btn:active { background: #f5f5f5; }

/* ─── 退出按钮 ─── */
.logout-btn {
  margin: 0 32rpx 16rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 28rpx 0;
  border: 2rpx solid #ffcdd0;
}
.logout-btn::after { border: none; }
.logout-btn:active { background: #fff1f0; }

.footer-hint {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
}

/* ─── 编辑资料底部弹窗 ─── */
.sheet-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 998;
}
.sheet-content {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 48rpx calc(60rpx + env(safe-area-inset-bottom));
  padding: 16rpx 48rpx calc(60rpx + constant(safe-area-inset-bottom));
  z-index: 999;
}
.sheet-handle {
  width: 80rpx; height: 8rpx;
  background: #ddd; border-radius: 4rpx;
  margin: 0 auto 24rpx;
}
.sheet-title {
  font-size: 34rpx; font-weight: 700; color: #1a1a1a;
  display: block; text-align: center; margin-bottom: 36rpx;
}

/* emoji 选择网格 */
.avatar-picker {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-bottom: 32rpx; justify-content: center;
}
.emoji-opt {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: #f5f6fa;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}
.emoji-opt.selected {
  background: #e8f0ff;
  border-color: #4A90D9;
  transform: scale(1.15);
}

/* 自定义头像上传按钮 */
.avatar-upload-btn {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 4rpx dashed #ccc;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
.avatar-upload-btn:active { opacity: 0.7; }
.avatar-upload-preview {
  width: 100%; height: 100%; position: absolute;
}
.avatar-upload-cover {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff; font-size: 18rpx; text-align: center;
  padding: 4rpx 0; line-height: 1;
}
.avatar-upload-plus { font-size: 36rpx; color: #999; line-height: 1; }
.avatar-upload-label { font-size: 18rpx; color: #999; margin-top: 2rpx; }

.edit-field {
  display: flex; align-items: center; gap: 20rpx; margin-bottom: 36rpx;
  background: #f5f6fa; border-radius: 16rpx; padding: 16rpx 24rpx;
}
.edit-label { font-size: 28rpx; color: #666; width: 72rpx; flex-shrink: 0; }
.edit-input {
  flex: 1; font-size: 28rpx; color: #333;
  background: transparent;
}

.sheet-btns { display: flex; gap: 24rpx; }
.sheet-btn {
  flex: 1; font-size: 30rpx; font-weight: 600;
  padding: 24rpx 0; border-radius: 50rpx; text-align: center;
}
.sheet-btn.cancel { color: #666; background: #f0f0f0; }
.sheet-btn.confirm { color: #fff; background: #4A90D9; }
.sheet-btn:active { opacity: 0.75; }

/* ─── 绑定手机号弹窗 ─── */
.bindphone-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 998;
}
.bindphone-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 48rpx calc(80rpx + env(safe-area-inset-bottom));
  padding: 16rpx 48rpx calc(80rpx + constant(safe-area-inset-bottom));
  z-index: 999;
  /* stopBubble 防止点击内容穿透到遮罩 */
}
