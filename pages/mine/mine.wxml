<!-- pages/mine/mine.wxml -->
<view class="page {{themeClass}}">
  <include src="../../templates/offline-tip.wxml" />

  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="not-logged-in">
    <view class="ui-hero-card mine-hero">
      <image class="ui-hero-img" src="/assets/illustrations/mine-hero-nest-transparent.png" mode="aspectFit" />
      <text class="ui-hero-title">欢迎回到宠物小窝</text>
      <text class="ui-hero-subtitle">登录后同步宠物档案、签到积分和提醒事项。</text>
    </view>
    <view class="profile-card" bindtap="goLogin">
      <view class="profile-bg">
        <view class="avatar-wrap">
          <image class="ui-icon-xl" src="/assets/icons/ui/pet.png" mode="aspectFit" />
        </view>
        <view class="profile-info">
          <text class="nickname">点击登录</text>
          <text class="phone-hint">登录后使用全部功能</text>
        </view>
      </view>
    </view>
    <view class="login-features">
      <view class="login-feature-item">
        <image class="login-feature-icon ui-icon-md" src="/assets/icons/ui/pet.png" mode="aspectFit" />
        <text class="login-feature-text">管理宠物档案</text>
      </view>
      <view class="login-feature-item">
        <image class="login-feature-icon ui-icon-md" src="/assets/icons/ui/record.png" mode="aspectFit" />
        <text class="login-feature-text">记录健康数据</text>
      </view>
      <view class="login-feature-item">
        <image class="login-feature-icon ui-icon-md" src="/assets/icons/ui/reminder.png" mode="aspectFit" />
        <text class="login-feature-text">设置智能提醒</text>
      </view>
      <view class="login-feature-item">
        <image class="login-feature-icon ui-icon-md" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
        <text class="login-feature-text">数据云端同步</text>
      </view>
    </view>
    <button class="login-main-btn" bindtap="goLogin">登录 / 注册</button>
    <view class="footer-hint">宠物小管家Plus v1.0</view>
  </view>

  <!-- 已登录状态 -->
  <view wx:else>
  <view class="ui-hero-card mine-hero">
    <image class="ui-hero-img" src="/assets/illustrations/mine-hero-nest-transparent.png" mode="aspectFit" />
    <text class="ui-hero-title">你的照护中心</text>
    <text class="ui-hero-subtitle">签到、积分和账号资料都在这里。</text>
  </view>

  <!-- 头像卡片 -->
  <view class="profile-card" bindtap="openEditProfile">
    <view class="profile-bg">
      <view class="avatar-wrap">
        <image wx:if="{{avatarType === 'image'}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
        <text wx:else class="avatar-emoji">{{avatarEmoji}}</text>
      </view>
      <view class="profile-info">
        <text class="nickname">{{nickname}}</text>
        <text class="phone" wx:if="{{phone}}">{{phone}}</text>
        <text class="phone-hint" wx:else>未绑定手机</text>
      </view>
    </view>
  </view>

  <!-- 积分签到卡片 -->
  <view class="points-card">
    <view class="points-header">
      <view class="points-header-left">
        <view class="points-balance-row">
          <view class="points-balance-new">
            <text class="points-num-big">{{points || 0}}</text>
            <text class="points-unit">积分</text>
          </view>
          <view class="makeup-badge-inline" bindtap="openShareTask">
            <image class="makeup-badge-icon ui-icon-sm" src="/assets/icons/ui/ticket.png" mode="aspectFit" />
            <text class="makeup-badge-num">{{makeUpCards || 0}}</text>
            <text class="makeup-badge-arrow">›</text>
          </view>
        </view>
        <view class="streak-row">
          <text class="streak-text" wx:if="{{checkInStreak > 0}}">🔥 连续{{checkInStreak}}天</text>
          <text class="streak-text" wx:else>开始签到累积积分吧</text>
          <block wx:if="{{totalCheckIns > 0}}">
            <text class="cumul-text"> · 累计{{totalCheckIns}}天</text>
            <text class="days-until-text ready lottery-trigger" wx:if="{{canLottery}}" bindtap="openLotteryIfAvailable"> · 可抽奖 x{{availableDraws}}次</text>
            <text class="days-until-text" wx:elif="{{streakReached7}}"> · {{daysUntilLottery}}天后可再抽奖</text>
            <text class="days-until-text" wx:else> · {{daysUntilLottery}}天后可抽奖</text>
          </block>
        </view>
      </view>
      <view class="checkin-btn {{checkedInToday ? 'checked' : ''}}" bindtap="doCheckIn">
        <text wx:if="{{!checkedInToday}}">签到</text>
        <text wx:else>✓ 已签到</text>
      </view>
    </view>

    <!-- 本周签到日历 -->
    <view class="calendar-row">
      <view class="cal-day {{item.checked ? 'checked' : ''}} {{item.isToday ? 'today' : ''}} {{item.canMakeUp ? 'can-makeup' : ''}}"
        wx:for="{{calendarWeek}}" wx:key="dateStr"
        bindtap="onTapCalDay"
        data-date="{{item.dateStr}}"
        data-label="{{item.date}}"
        data-canmakeup="{{item.canMakeUp}}"
        data-isjackpot="{{item.isDrawDay && !item.drawUsed}}"
        data-hasdrawn="{{item.isDrawDay && item.drawUsed}}"
        data-drawmilestone="{{item.drawMilestone}}"
        data-canmakeup="{{item.canMakeUp}}">
        <text class="cal-weekday">{{item.dayName}}</text>
        <view class="cal-circle {{item.isDrawDay && !item.drawUsed ? 'gift-circle' : (item.isDrawDay && item.drawUsed ? 'gift-circle-grey' : '')}}">
          <block wx:if="{{item.isDrawDay && !item.drawUsed}}">
            <image class="gift-emoji bounce-anim ui-icon-sm" src="/assets/icons/ui/gift.png" mode="aspectFit" />
          </block>
          <block wx:elif="{{item.isDrawDay && item.drawUsed}}">
            <image class="gift-emoji grey ui-icon-sm" src="/assets/icons/ui/gift.png" mode="aspectFit" />
          </block>
          <block wx:elif="{{item.checked}}">
            <text class="cal-check {{item.isMadeUp ? 'madeup' : ''}}">✓</text>
          </block>
          <block wx:else>
            <text class="cal-date">{{item.date}}</text>
          </block>
        </view>
        <text wx:if="{{item.canMakeUp}}" class="cal-makeup-tag">补</text>
        <text wx:elif="{{item.isMadeUp}}" class="cal-madeup-tag">补</text>
        <text wx:else class="cal-spacer"></text>
      </view>
    </view>

    <!-- 展开/收起月历 -->
    <view class="calendar-toggle" bindtap="toggleCalendar">
      <text>{{showFullCalendar ? '收起完整日历' : '展开完整日历'}}</text>
      <view class="calendar-toggle-icon {{showFullCalendar ? 'is-open' : ''}}">
        <view class="calendar-toggle-chevron"></view>
      </view>
    </view>

    <!-- 完整月历 -->
    <view wx:if="{{showFullCalendar}}" class="month-calendar">
      <view class="month-weekday-row">
        <text class="month-weekday" wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="month-week" wx:for="{{calendarMonth}}" wx:for-item="week" wx:key="index">
        <block wx:for="{{week}}" wx:for-item="d" wx:key="dateStr">
          <view wx:if="{{!d.empty}}"
            class="month-day {{d.checked ? 'checked' : ''}} {{d.isToday ? 'today' : ''}} {{d.canMakeUp ? 'can-makeup' : ''}} {{d.isFuture ? 'future' : ''}}"
            bindtap="onTapCalDay"
            data-date="{{d.dateStr}}"
            data-label="{{d.date}}"
            data-isjackpot="{{d.isDrawDay && !d.drawUsed}}"
            data-hasdrawn="{{d.isDrawDay && d.drawUsed}}"
            data-drawmilestone="{{d.drawMilestone}}"
            data-canmakeup="{{d.canMakeUp}}">
            <text class="month-day-num">{{d.date}}</text>
            <view wx:if="{{d.isDrawDay && !d.drawUsed}}" class="month-day-gift"><image class="ui-icon-sm" src="/assets/icons/ui/gift.png" mode="aspectFit" /></view>
            <view wx:elif="{{d.isDrawDay && d.drawUsed}}" class="month-day-gift grey"><image class="ui-icon-sm" src="/assets/icons/ui/gift.png" mode="aspectFit" /></view>
            <view wx:elif="{{d.checked}}" class="month-day-check {{d.isMadeUp ? 'madeup' : ''}}">✓</view>
          </view>
          <view wx:else class="month-day empty"></view>
        </block>
      </view>
    </view>

    <view class="points-footer">
      <view class="points-entry" bindtap="goPointsMall">
        <image class="ui-inline-icon" src="/assets/icons/ui/gift.png" mode="aspectFit" />
        <text class="points-entry-text">积分商城</text>
        <text class="points-entry-arrow">›</text>
      </view>
      <view class="points-divider"></view>
      <view class="points-entry" bindtap="goInventory">
        <image class="ui-inline-icon" src="/assets/icons/ui/backpack.png" mode="aspectFit" />
        <text class="points-entry-text">我的背包</text>
        <text class="points-entry-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-group-label">账号</view>
    <view class="menu-item" bindtap="openBindPhone">
      <view class="menu-icon-wrap icon-orange">
        <image class="ui-icon" src="/assets/icons/ui/phone.png" mode="aspectFit" />
      </view>
      <view class="menu-text-wrap">
        <text class="menu-text">绑定手机号</text>
        <text class="menu-desc" wx:if="{{!phone}}">未绑定，绑定后可手机号登录</text>
        <text class="menu-desc" wx:else>{{phone}} · 已绑定</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-divider"></view>
    <view class="menu-group-label">关于</view>
    <view class="menu-item" bindtap="goAbout">
      <view class="menu-icon-wrap icon-purple">
        <image class="ui-icon" src="/assets/icons/ui/about.png" mode="aspectFit" />
      </view>
      <view class="menu-text-wrap">
        <text class="menu-text">关于小程序</text>
        <text class="menu-desc">版本信息和使用说明</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 🛠 开发者调试按钮（已隐藏）
  <view wx:if="{{isAdmin}}" class="dev-reset-bar">
    <button class="dev-reset-btn" bindtap="devResetCheckIn">🛠 重置签到 + 20补签卡</button>
    <button class="dev-reset-btn" bindtap="devAddPoints" style="background:#e8f4ff;color:#2a80e8;border-color:#a8d3ff;">增加500积分</button>
    <button class="dev-reset-btn" bindtap="devClearBackpack" style="background:#fff0f0;color:#e74c3c;border-color:#f5c6cb;">清除背包和兑换记录</button>
  </view> -->

  <!-- 退出登录 -->
  <button class="logout-btn" bindtap="logout">退出登录</button>

  <!-- 编辑个人资料底部弹窗 -->
  <view wx:if="{{showEditModal}}" class="sheet-mask" bindtap="cancelEdit">
    <view class="sheet-content" catchtap="stopBubble">
      <view class="sheet-handle"></view>
      <text class="sheet-title">编辑资料</text>

      <!-- 头像选择 -->
      <view class="avatar-picker">
        <!-- 上传自定义头像 -->
        <view class="avatar-upload-btn" bindtap="chooseAvatar">
          <image wx:if="{{editAvatarUrl}}" class="avatar-upload-preview" src="{{editAvatarUrl}}" mode="aspectFill" />
          <view wx:if="{{editAvatarUrl}}" class="avatar-upload-cover">重新上传</view>
          <text wx:if="{{!editAvatarUrl}}" class="avatar-upload-plus">+</text>
          <text wx:if="{{!editAvatarUrl}}" class="avatar-upload-label">上传头像</text>
        </view>
        <!-- Emoji选择 -->
        <view wx:for="{{emojiList}}" wx:key="index"
          class="emoji-opt {{editEmoji === item && !editAvatarUrl ? 'selected' : ''}}"
          data-emoji="{{item}}"
          bindtap="selectEmoji">
          <text>{{item}}</text>
        </view>
      </view>

      <!-- 昵称输入 -->
      <view class="edit-field">
        <text class="edit-label">昵称</text>
        <input class="edit-input" value="{{editNickname}}" bindinput="onNicknameInput"
          placeholder="给自己起个名字" maxlength="20" confirm-type="done" />
      </view>

      <view class="sheet-btns">
        <view class="sheet-btn cancel" bindtap="cancelEdit">取消</view>
        <view class="sheet-btn confirm" bindtap="confirmEdit">保存</view>
      </view>
    </view>
  </view>

  <view class="footer-hint">宠物小管家Plus v1.0</view>

  <!-- ─── 补签确认弹窗 ─── -->
  <view wx:if="{{showMakeUpModal}}" class="bindphone-mask" bindtap="cancelMakeUp">
    <view class="bindphone-sheet" catchtap="stopBubble">
      <view style="width:80rpx;height:8rpx;background:#ddd;border-radius:4rpx;margin:0 auto 24rpx;"></view>
      <text style="font-size:36rpx;font-weight:700;color:#1a1a1a;display:block;text-align:center;margin-bottom:12rpx;">补签确认</text>
      <text style="font-size:28rpx;color:#666;display:block;text-align:center;margin-bottom:20rpx;">使用 <text style="color:#e74c3c;font-weight:700;">{{nextMakeUpCost}}</text> 张补签卡补签 {{makeUpTargetLabel}} 日？</text>
      <view style="display:flex;align-items:center;justify-content:center;gap:8rpx;margin-bottom:32rpx;">
        <text style="font-size:26rpx;color:#999;">剩余补签卡：</text>
        <image class="ui-icon-sm" src="/assets/icons/ui/ticket.png" mode="aspectFit" />
        <text style="font-size:30rpx;color:{{themePrimary || '#5BA7D8'}};font-weight:700;">{{makeUpCards}} 张</text>
      </view>
      <view class="sheet-btns">
        <view class="sheet-btn cancel" bindtap="cancelMakeUp">取消</view>
        <view class="sheet-btn confirm" bindtap="confirmMakeUp">确认补签</view>
      </view>
    </view>
  </view>

  <!-- ─── 抽奖转盘弹窗 ─── -->
  <view wx:if="{{showLottery}}" class="bindphone-mask" bindtap="closeLottery">
    <view class="bindphone-sheet" catchtap="stopBubble">
      <view style="width:80rpx;height:8rpx;background:#ddd;border-radius:4rpx;margin:0 auto 24rpx;"></view>
      <text style="font-size:34rpx;font-weight:700;color:#1a1a1a;display:block;text-align:center;margin-bottom:8rpx;">幸运大转盘</text>
      <text style="font-size:22rpx;color:#999;display:block;text-align:center;margin-bottom:28rpx;">每连续7天可抽一次，越签越多！</text>

      <view class="wheel-container">
        <view class="wheel-pointer"></view>
        <view class="wheel" style="transform: rotate({{wheelAngle}}deg);">
          <!-- 转盘文字标签（在 wheel 内部，跟随旋转） -->
          <view class="wheel-labels">
            <view class="wheel-label" wx:for="{{wheelLabels}}" wx:key="rotate"
              style="transform: rotate({{item.rotate}}deg) translateY(-170rpx);">
              {{item.name}}
            </view>
          </view>
        </view>
        <view class="wheel-center {{spinning || hasSpun ? 'disabled' : ''}}" bindtap="spinWheel">
          <text wx:if="{{!spinning && !hasSpun}}">抽奖</text>
          <text wx:elif="{{spinning}}">...</text>
          <text wx:else>已抽奖</text>
        </view>
      </view>

      <view class="lottery-result" wx:if="{{lotteryResult}}" style="color:{{lotteryResultColor}};">
        <text class="lottery-result-label">{{lotteryResult}}</text>
      </view>
    </view>
  </view>

  <!-- ─── 分享任务弹窗 ─── -->
  <view wx:if="{{showShareTask}}" class="bindphone-mask" bindtap="closeShareTask">
    <view class="bindphone-sheet share-task-sheet" catchtap="stopBubble">
      <view style="width:80rpx;height:8rpx;background:#ddd;border-radius:4rpx;margin:0 auto 32rpx;"></view>
      <view style="display:flex;align-items:center;justify-content:center;gap:16rpx;margin-bottom:16rpx;">
        <image class="ui-icon-md" src="/assets/icons/ui/ticket.png" mode="aspectFit" />
        <text style="font-size:36rpx;font-weight:700;color:#1a1a1a;">补签卡</text>
      </view>
      <view style="display:flex;align-items:center;justify-content:center;gap:8rpx;margin-bottom:36rpx;">
        <text style="font-size:52rpx;font-weight:700;color:{{themePrimary || '#5BA7D8'}};">{{makeUpCards}}</text>
        <text style="font-size:28rpx;color:#666;">张可用</text>
      </view>
      <text style="font-size:26rpx;color:#999;display:block;text-align:center;margin-bottom:40rpx;line-height:1.6;">每分享小程序到微信群或朋友圈
每日可获得 1 张补签卡</text>
      <button class="share-task-btn" open-type="share">去分享</button>
      <view class="sheet-btn cancel" bindtap="closeShareTask" style="margin-top:16rpx;">关闭</view>
    </view>
  </view>

  </view><!-- end 已登录 -->
</view>
