/* pages/login/login.wxss */

.login-page {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.22) 0, rgba(255, 255, 255, 0) 240rpx),
    linear-gradient(180deg, #5BA7D8 0%, #60B9CB 46%, #6BC6B3 100%);
}

.login-shell {
  min-height: 100vh;
  padding: 72rpx 54rpx 42rpx;
  box-sizing: border-box;
}

.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 46rpx;
}

.login-hero-img {
  width: 430rpx;
  height: 250rpx;
  margin: 0 0 2rpx;
}

.brand-kicker {
  margin-bottom: 18rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.86);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.brand-title {
  margin-bottom: 16rpx;
  color: #FFFFFF;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.28;
  text-shadow: 0 6rpx 22rpx rgba(36, 48, 68, 0.16);
  text-align: center;
  max-width: 100%;
}

.brand-subtitle {
  color: rgba(255, 255, 255, 0.84);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.6;
}

.wx-login-btn {
  width: 100% !important;
  background: #FFFFFF !important;
  color: #243044 !important;
  font-size: 34rpx !important;
  font-weight: 800 !important;
  border-radius: 24rpx !important;
  padding: 22rpx 0 !important;
  border: none !important;
  box-shadow: 0 18rpx 44rpx rgba(36, 48, 68, 0.16) !important;
  line-height: 1.5 !important;
  text-align: center !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.wx-login-content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-login-btn::after {
  border: none !important;
}

.other-login-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  font-weight: 700;
}

.toggle-arrow {
  width: 34rpx;
  height: 34rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  transition: transform .22s ease, background-color .22s ease;
}

.toggle-chevron {
  width: 10rpx;
  height: 10rpx;
  margin-top: -5rpx;
  border-right: 3rpx solid rgba(255, 255, 255, 0.88);
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.88);
  transform: rotate(45deg);
}

.toggle-arrow.is-open {
  transform: rotate(180deg);
  background: rgba(255, 255, 255, 0.18);
}

.phone-login-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(36, 48, 68, 0.14);
  animation: fadeIn .25s ease;
}

.phone-login-head {
  margin-bottom: 20rpx;
}

.phone-login-title {
  display: block;
  color: #243044;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
}

.phone-login-desc {
  display: block;
  margin-top: 4rpx;
  color: #6E7A8A;
  font-size: 24rpx;
  font-weight: 600;
}

.login-field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.login-field-label {
  color: #6E7A8A;
  font-size: 24rpx;
  font-weight: 800;
}

.login-input {
  width: 100%;
  height: 80rpx;
  padding: 0 26rpx;
  border-radius: 20rpx;
  background: #F7F9FB;
  border: 2rpx solid #E8EEF4;
  color: #243044;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.phone-login-btn {
  margin-top: 22rpx;
  width: 100%;
  padding: 22rpx 0;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #5BA7D8 0%, #6BC6B3 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.4;
  text-align: center;
  box-shadow: 0 14rpx 34rpx rgba(91, 167, 216, 0.24);
}

.register-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-top: 18rpx;
  color: #6E7A8A;
  font-size: 26rpx;
  font-weight: 600;
}

.register-link {
  color: #5BA7D8;
  font-weight: 900;
}

/* 折叠区淡入 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 完善资料 */
.profile-setup-mask {
  position: fixed;
  inset: 0;
  z-index: 9998;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
  background: rgba(24, 48, 66, 0.48);
  backdrop-filter: blur(8rpx);
}

.profile-setup-panel {
  position: relative;
  width: 100%;
  max-height: calc(100vh - 72rpx);
  overflow-y: auto;
  box-sizing: border-box;
  padding: 42rpx 42rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 32rpx;
  background: linear-gradient(180deg, #F2FBFA 0%, #FFFFFF 46%);
  box-shadow: 0 30rpx 80rpx rgba(24, 76, 108, 0.26);
}

.profile-setup-accent {
  width: 70rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #5BA7D8, #6BC6B3);
}

.profile-setup-kicker,
.profile-setup-title,
.profile-setup-desc {
  display: block;
  text-align: center;
}

.profile-setup-kicker {
  color: #5BA7D8;
  font-size: 20rpx;
  font-weight: 900;
}

.profile-setup-title {
  margin-top: 6rpx;
  color: #243044;
  font-size: 36rpx;
  font-weight: 900;
}

.profile-setup-desc {
  margin-top: 10rpx;
  color: #6E7A8A;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.55;
}

.profile-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 30rpx 0 26rpx;
}

.profile-avatar-wrap {
  position: relative;
  width: 176rpx;
  height: 176rpx;
}

.avatar-choose-btn {
  width: 176rpx !important;
  height: 176rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border-radius: 50% !important;
  border: none !important;
  line-height: 1 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  overflow: hidden !important;
  box-sizing: border-box !important;
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
}
.avatar-choose-btn::after { border: none !important; }

.avatar-preview {
  width: 176rpx !important;
  height: 176rpx !important;
  border-radius: 50% !important;
}

.avatar-ring {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  border: 4rpx dashed rgba(91, 167, 216, 0.38);
  box-sizing: border-box;
  pointer-events: none;
}

.profile-avatar-hint {
  margin-top: 14rpx;
  color: #438DBA;
  font-size: 24rpx;
  font-weight: 800;
}

.profile-nickname-field {
  padding: 0 24rpx;
  border: 2rpx solid #E8EEF4;
  border-radius: 20rpx;
  background: #F5F9FC;
}

.profile-nickname-input {
  width: 100%;
  height: 82rpx;
  color: #243044;
  font-size: 30rpx;
  font-weight: 700;
}

.profile-setup-confirm {
  width: 100%;
  margin-top: 24rpx;
  padding: 22rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  box-shadow: 0 14rpx 34rpx rgba(91, 167, 216, 0.24);
}

.profile-setup-skip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding-top: 22rpx;
  color: #7B8798;
  font-size: 25rpx;
  font-weight: 700;
}

.profile-skip-chevron {
  width: 10rpx;
  height: 10rpx;
  border-top: 3rpx solid #8E9AAA;
  border-right: 3rpx solid #8E9AAA;
  transform: rotate(45deg);
}
