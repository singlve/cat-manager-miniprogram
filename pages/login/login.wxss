/* pages/login/login.wxss */

.login-page {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.22) 0, rgba(255, 255, 255, 0) 240rpx),
    linear-gradient(180deg, #5BA7D8 0%, #60B9CB 46%, #6BC6B3 100%);
}

.login-shell {
  min-height: 100vh;
  padding: 72rpx 54rpx 42rpx;
  box-sizing: border-box;
}

.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 46rpx;
}

.login-hero-img {
  width: 430rpx;
  height: 250rpx;
  margin: 0 0 2rpx;
}

.brand-kicker {
  margin-bottom: 18rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.86);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.brand-title {
  margin-bottom: 16rpx;
  color: #FFFFFF;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.28;
  text-shadow: 0 6rpx 22rpx rgba(36, 48, 68, 0.16);
  text-align: center;
  max-width: 100%;
}

.brand-subtitle {
  color: rgba(255, 255, 255, 0.84);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.6;
}

/* 绑定手机号弹窗 */
.bind-sheet input {
  box-sizing: border-box;
}

.wx-login-btn {
  width: 100% !important;
  background: #FFFFFF !important;
  color: #243044 !important;
  font-size: 34rpx !important;
  font-weight: 800 !important;
  border-radius: 24rpx !important;
  padding: 22rpx 0 !important;
  border: none !important;
  box-shadow: 0 18rpx 44rpx rgba(36, 48, 68, 0.16) !important;
  line-height: 1.5 !important;
  text-align: center !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.wx-login-content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-login-btn::after {
  border: none !important;
}

.other-login-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  font-weight: 700;
}

.toggle-arrow {
  margin-left: 8rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 28rpx;
  line-height: 1;
  transition: transform .2s ease;
}

.toggle-arrow.is-open {
  transform: rotate(180deg);
}

.phone-login-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(36, 48, 68, 0.14);
  animation: fadeIn .25s ease;
}

.phone-login-head {
  margin-bottom: 20rpx;
}

.phone-login-title {
  display: block;
  color: #243044;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
}

.phone-login-desc {
  display: block;
  margin-top: 4rpx;
  color: #6E7A8A;
  font-size: 24rpx;
  font-weight: 600;
}

.login-field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.login-field-label {
  color: #6E7A8A;
  font-size: 24rpx;
  font-weight: 800;
}

.login-input {
  width: 100%;
  height: 80rpx;
  padding: 0 26rpx;
  border-radius: 20rpx;
  background: #F7F9FB;
  border: 2rpx solid #E8EEF4;
  color: #243044;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.phone-login-btn {
  margin-top: 22rpx;
  width: 100%;
  padding: 22rpx 0;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #5BA7D8 0%, #6BC6B3 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.4;
  text-align: center;
  box-shadow: 0 14rpx 34rpx rgba(91, 167, 216, 0.24);
}

.register-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-top: 18rpx;
  color: #6E7A8A;
  font-size: 26rpx;
  font-weight: 600;
}

.register-link {
  color: #5BA7D8;
  font-weight: 900;
}

/* 折叠区淡入 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 绑定手机弹窗 - 微信快速获取按钮 */
.bind-wechat-btn {
  width: 100% !important;
  background: #07C160 !important;
  color: #fff !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  border-radius: 50rpx !important;
  padding: 26rpx 0 !important;
  border: none !important;
  line-height: 1.5 !important;
}
.bind-wechat-btn::after { border: none !important; }

/* 完善资料 - 头像选择按钮 */
.profile-avatar-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.avatar-choose-btn {
  width: 200rpx !important;
  height: 200rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border-radius: 50% !important;
  border: none !important;
  line-height: 1 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  overflow: hidden !important;
  box-sizing: border-box !important;
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
}
.avatar-choose-btn::after { border: none !important; }
.avatar-preview {
  width: 200rpx !important;
  height: 200rpx !important;
  border-radius: 50% !important;
}
.avatar-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx dashed #ccc;
  box-sizing: border-box;
  pointer-events: none;
}
