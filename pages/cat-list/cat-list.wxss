/* ─── Demo 水印提示 ─── */
.demo-watermark {
  background: linear-gradient(135deg, #fffbe6, #fff7cc);
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #ffe58f;
  text-align: center;
}
.demo-watermark text {
  font-size: 24rpx;
  color: #d48806;
}

/* pages/cat-list/cat-list.wxss */
page { background: #f0f2f7; }
.container {
  min-height: 100vh;
  background: #f0f2f7;
  padding: 24rpx 24rpx 160rpx;
}

/* ─── 未登录引导 ─── */
.guest-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.guest-illustration {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #e8f0ff, #d4e4ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(74, 144, 217, 0.2);
}

.guest-emoji { font-size: 96rpx; }
.guest-title { font-size: 36rpx; color: #1a1a1a; font-weight: 700; margin-bottom: 16rpx; }
.guest-desc { font-size: 26rpx; color: #888; margin-bottom: 48rpx; text-align: center; max-width: 480rpx; line-height: 1.6; }

.guest-login-btn {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 50rpx; padding: 26rpx 72rpx;
  box-shadow: 0 12rpx 36rpx rgba(74, 144, 217, 0.4);
  border: none;
}
.guest-login-btn::after { border: none; }

.guest-browse-hint { font-size: 24rpx; color: #bbb; margin-top: 32rpx; }

/* ─── 加载状态 ─── */
.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx;
  color: #999;
}


/* ─── 空状态 ─── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-illustration {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #e8f0ff, #d4e4ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(74, 144, 217, 0.2);
}

.empty-emoji { font-size: 96rpx; }
.empty-text { font-size: 34rpx; color: #1a1a1a; font-weight: 700; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: #888; margin-bottom: 48rpx; text-align: center; max-width: 420rpx; }

.empty-cta {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 50rpx; padding: 26rpx 72rpx;
  box-shadow: 0 12rpx 36rpx rgba(74, 144, 217, 0.4);
  border: none;
}
.empty-cta::after { border: none; }

/* ─── 顶部滚动 Banner ─── */
.banner-wrap {
  margin-bottom: 24rpx;
  margin-top: 8rpx;
}
.banner-swiper {
  height: 160rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.banner-card {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}
.banner-emoji {
  font-size: 64rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.banner-body {
  flex: 1;
  min-width: 0;
}
.banner-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.banner-title {
  font-size: 28rpx;
  font-weight: 700;
}
.banner-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.banner-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ─── 顶部统计条 ─── */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  border-radius: 20rpx;
  padding: 24rpx 40rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.3);
}

.stats-item {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.stats-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.stats-sep {
  width: 2rpx;
  height: 36rpx;
  background: rgba(255,255,255,0.35);
}

/* ─── 猫咪卡片 ─── */
.cat-list { display: flex; flex-direction: column; gap: 20rpx; }

.cat-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 28rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s;
}
.cat-card:active { transform: scale(0.98); }

/* 左侧彩色竖条 */
.card-accent {
  width: 8rpx;
  align-self: stretch;
  border-radius: 0 4rpx 4rpx 0;
  background: linear-gradient(to bottom, #4A90D9, #6BA3E0);
  margin-right: 24rpx;
  flex-shrink: 0;
}

/* ─── 头像 ─── */
.cat-avatar-wrap {
  position: relative;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.cat-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #e8f0ff;
}

.cat-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f4ff, #e0eaff);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #e0eaff;
}
.avatar-emoji { font-size: 56rpx; }

/* 性别角标 */
.gender-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}
.gender-male { background: #4A90D9; color: #fff; }
.gender-female { background: #f06292; color: #fff; }

/* ─── 文字信息 ─── */
.cat-info { flex: 1; min-width: 0; }

.cat-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.cat-name { font-size: 36rpx; font-weight: 800; color: #1a1a1a; }

.cat-breed-tag {
  font-size: 22rpx;
  color: #4A90D9;
  background: #e8f4ff;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* ─── 生日行：日期 + 倒计时紧跟 ─── */
.cat-birthday-row {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}

.cat-birthday { font-size: 24rpx; color: #888; }

.birthday-hint-inline {
  font-size: 22rpx;
  color: #ff8c00;
  font-weight: 600;
}

/* ─── 年龄 + 相伴/离开 ─── */
.cat-age-row {
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.cat-age-detail { font-size: 24rpx; color: #666; font-weight: 500; line-height: 1; }

.cat-companion { font-size: 24rpx; color: #999; line-height: 1; margin-left: 12rpx; }

/* 健康状态徽章 */
.health-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 6rpx 14rpx;
}

.badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.badge-dot.green { background: #52c41a; box-shadow: 0 0 6rpx #52c41a; }
.badge-dot.yellow { background: #faad14; box-shadow: 0 0 6rpx #faad14; }
.badge-dot.red { background: #ff4d4f; box-shadow: 0 0 6rpx #ff4d4f; }

.badge-text { font-size: 22rpx; color: #888; }

/* ─── 右侧快捷操作 ─── */
.card-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 16rpx;
  border-left: 2rpx dashed #f0f0f0;
  margin-left: 12rpx;
  flex-shrink: 0;
  min-width: 80rpx;
}
.card-actions:active { opacity: 0.6; }

.quick-add-icon { font-size: 36rpx; margin-bottom: 4rpx; }
.quick-add-text { font-size: 20rpx; color: #999; }

/* ─── 底部添加按钮 ─── */
.add-section {
  position: fixed;
  bottom: 40rpx;
  left: 0; right: 0;
  display: flex;
  justify-content: center;
  padding: 0 40rpx;
}

.add-btn {
  width: 100%;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff; font-size: 34rpx; font-weight: 700;
  border-radius: 50rpx; padding: 28rpx 0;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(74, 144, 217, 0.45);
}
.add-btn::after { border: none; }
