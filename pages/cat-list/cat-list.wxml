<!-- pages/cat-list/cat-list.wxml -->
<view class="container {{themeClass}}">
  <include src="../../templates/offline-tip.wxml" />

  <view class="home-hero">
    <view class="home-hero-art">
      <image class="home-hero-img" src="/assets/illustrations/home-hero.webp" mode="aspectFit" />
      <view class="home-hero-fade fade-top"></view>
      <view class="home-hero-fade fade-bottom"></view>
    </view>
    <view class="home-hero-copy">
      <text class="home-hero-title">今天也在好好照顾它们</text>
      <text class="home-hero-subtitle">记录档案、健康动态和提醒事项，把每一次陪伴都收进小小日常。</text>
    </view>
  </view>

  <!-- 管理员公告 -->
  <view wx:if="{{announcement}}" class="announce-bar" bindtap="onAnnounceTap">
    <image class="announce-icon ui-icon-sm theme-business-icon" src="/assets/icons/ui/announce.png" mode="aspectFit" />
    <view class="announce-wrap">
      <text class="announce-text">{{announcement.content}}</text>
    </view>
  </view>

  <!-- 功能 Banner -->
  <view wx:if="{{banners.length > 0}}" class="banner-wrap">
    <swiper class="banner-swiper" autoplay interval="{{4000}}" circular indicator-dots indicator-color="rgba(110,122,138,0.18)" indicator-active-color="{{themePrimary || '#5BA7D8'}}">
      <swiper-item wx:for="{{banners}}" wx:key="title">
        <view class="banner-card">
          <view class="banner-icon-wrap">
            <image class="banner-emoji banner-icon-img theme-business-icon" src="{{item.iconPath}}" mode="aspectFit" />
          </view>
          <view class="banner-body">
            <view class="banner-header">
              <text class="banner-title">{{item.title}}</text>
              <text wx:if="{{item.tag}}" class="banner-tag">{{item.tag}}</text>
            </view>
            <text class="banner-desc">{{item.desc}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 未登录提示（独立显示，不影响列表） -->
  <view wx:if="{{!isLoggedIn}}" class="guest-banner">
    <view class="guest-illustration">
      <image class="ui-icon-xl" src="/assets/icons/ui/pet.png" mode="aspectFit" />
    </view>
    <text class="guest-title">欢迎使用宠物小管家Plus</text>
    <text class="guest-desc">登录后可以添加宠物、记录健康数据、设置提醒</text>
    <button class="guest-login-btn" bindtap="goLogin">登录 / 注册</button>
    <text class="guest-browse-hint">你可以先浏览体验，需要时再登录</text>
  </view>

  <!-- 加载状态（已登录、正在加载、且无缓存数据） -->
  <view wx:if="{{isLoggedIn && loading && cats.length === 0}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{isLoggedIn && loadError && cats.length === 0}}" class="load-error-state">
    <image class="load-error-icon ui-icon-lg" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
    <text class="load-error-title">暂时无法加载宠物档案</text>
    <text class="load-error-desc">请检查网络后重试，已有数据不会丢失</text>
    <button class="load-retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <!-- 空状态（已登录、加载完成、且无猫） -->
  <view wx:elif="{{isLoggedIn && !loading && !loadError && cats.length === 0}}" class="empty">
    <image class="empty-all-img" src="/assets/illustrations/home-hero.webp" mode="aspectFit" />
    <text class="empty-text">还没有添加宠物</text>
    <text class="empty-hint">添加你的第一只宠物，开始记录它的健康成长</text>
    <button class="empty-cta" bindtap="addCat">+ 添加宠物</button>
  </view>

  <!-- 物种筛选栏 -->
  <view wx:if="{{cats.length > 0}}" class="filter-bar">
    <view class="filter-tabs">
      <view class="filter-tab {{filterSpecies === 'all' ? 'active' : ''}}" bindtap="onFilterSpecies" data-species="all">
        <text class="filter-label">全部</text>
        <text class="filter-count">{{speciesCounts.all}}</text>
      </view>
      <view class="filter-tab {{filterSpecies === 'cat' ? 'active' : ''}}" bindtap="onFilterSpecies" data-species="cat">
        <text class="filter-label">猫</text>
        <text class="filter-count">{{speciesCounts.cat}}</text>
      </view>
      <view class="filter-tab {{filterSpecies === 'dog' ? 'active' : ''}}" bindtap="onFilterSpecies" data-species="dog">
        <text class="filter-label">狗</text>
        <text class="filter-count">{{speciesCounts.dog}}</text>
      </view>
    </view>
    <view class="sort-btn" bindtap="onShowSort">
      <view class="sort-icon">
        <view class="sort-arrow sort-arrow-up"></view>
        <view class="sort-arrow sort-arrow-down"></view>
      </view>
      <text class="sort-label">排序</text>
    </view>
  </view>

  <view wx:if="{{isLoggedIn && cats.length > 0 && recentActivities.length > 0}}" class="activity-panel {{recentActivitiesExpanded ? 'expanded' : 'collapsed'}}">
    <view class="activity-head" bindtap="toggleRecentActivities">
      <view class="activity-head-copy">
        <text class="activity-title">近期动态</text>
        <text wx:if="{{recentActivitiesExpanded}}" class="activity-subtitle">健康记录与待办提醒</text>
      </view>
      <view class="activity-head-action">
        <text class="activity-count">{{recentActivities.length}}</text>
        <view class="activity-toggle-btn {{recentActivitiesExpanded ? 'up' : ''}}">
          <view class="activity-toggle-chevron"></view>
        </view>
      </view>
    </view>
    <view wx:if="{{recentActivitiesExpanded}}" class="activity-list">
      <view
        wx:for="{{recentActivities}}"
        wx:key="id"
        class="activity-item {{item.tone}}"
        bindtap="goRecentActivity"
        data-kind="{{item.kind}}"
        data-catid="{{item.catId}}"
      >
        <view class="activity-icon-wrap">
          <image class="activity-icon ui-icon-sm theme-business-icon" src="{{item.iconPath}}" mode="aspectFit" />
        </view>
        <view class="activity-copy">
          <text class="activity-item-title">{{item.title}}</text>
          <text class="activity-item-desc">{{item.desc}}</text>
        </view>
        <text class="activity-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 筛选后空状态 -->
  <view wx:if="{{cats.length > 0 && displayCats.length === 0 && !loading}}" class="empty-filter">
    <image class="empty-filter-img" src="{{filterSpecies === 'dog' ? '/assets/illustrations/empty-dog.webp' : '/assets/illustrations/empty-cat.webp'}}" mode="aspectFit" />
    <text class="empty-filter-text">还没有添加{{filterSpecies === 'dog' ? '狗狗' : '猫咪'}}</text>
    <button class="empty-filter-btn" bindtap="addFilteredPet" data-species="{{filterSpecies}}">+ 添加{{filterSpecies === 'dog' ? '狗狗' : '猫咪'}}</button>
  </view>

  <!-- 宠物列表 -->
  <view wx:if="{{displayCats.length > 0}}" class="cat-list">
    <!-- Demo 水印提示（仅未登录且有 demo 数据时显示） -->
    <view wx:if="{{!isLoggedIn}}" class="demo-watermark">
      <image class="demo-watermark-icon ui-icon-sm" src="/assets/icons/ui/about.png" mode="aspectFit" />
      <text>以下为示例展示，登录后可管理自己的宠物</text>
    </view>
    <view wx:for="{{displayCats}}" wx:key="_id" class="cat-card type-{{item.avatar ? 'has-avatar' : 'no-avatar'}}" bindtap="goCatDetail" data-id="{{item._id}}">
      <!-- 左侧色条 -->
      <view class="card-accent"></view>
      <!-- 头像 -->
      <view class="cat-avatar-wrap">
        <image wx:if="{{item.avatar}}" src="{{item._displayAvatar || item.avatar}}" mode="aspectFill" class="cat-avatar" lazy-load />
        <view wx:else class="cat-avatar-placeholder">
          <image class="ui-icon-lg" src="{{item.species === 'dog' ? '/assets/icons/ui/dog.png' : '/assets/icons/ui/cat.png'}}" mode="aspectFit" />
        </view>
        <!-- 性别角标 -->
        <view wx:if="{{item.gender === 'male' || item.gender === 'female'}}" class="gender-badge gender-{{item.gender}}">
          <text class="gender-symbol">{{item.gender === 'male' ? '♂' : '♀'}}</text>
        </view>
      </view>
      <!-- 文字信息 -->
      <view class="cat-info">
        <view class="cat-name-row">
          <text class="cat-name">{{item.name}}</text>
          <text class="cat-breed-tag">{{item.breed || '品种未知'}}</text>
        </view>
        <view class="cat-birthday-row" wx:if="{{item.birthday}}">
          <text class="cat-birthday">{{item._birthdayText || item.birthday}}</text>
          <text wx:if="{{item._birthdayHint}}" class="birthday-hint-inline">{{item._birthdayHint}}</text>
        </view>
        <view class="cat-age-row" wx:if="{{item.birthday}}">
          <text class="cat-age-detail" wx:if="{{item._ageText}}">{{item._ageText}}</text>
          <text wx:if="{{item._companionText}}" class="cat-companion">{{item._companionText}}</text>
        </view>
        <view class="health-badge" wx:if="{{item._daysSinceRecord !== undefined}}">
          <text class="badge-dot {{item._daysSinceRecord < 30 ? 'green' : item._daysSinceRecord < 90 ? 'yellow' : 'red'}}"></text>
          <text class="badge-text">{{item._daysSinceRecord < 1 ? '今天有记录' : item._daysSinceRecord + '天无记录'}}</text>
        </view>
      </view>
      <!-- 右侧快捷操作（仅已登录） -->
      <view wx:if="{{isLoggedIn}}" class="card-actions" catchtap="onQuickRecord" data-id="{{item._id}}" data-name="{{item.name}}">
        <image class="quick-add-icon ui-icon-sm" src="/assets/icons/ui/edit.png" mode="aspectFit" />
        <text class="quick-add-text">速记</text>
      </view>
    </view>
  </view>

  <!-- 列表态悬浮添加按钮：已登录 -->
  <movable-area wx:if="{{isLoggedIn && cats.length > 0 && displayCats.length > 0}}" class="add-fab-area">
    <movable-view
      class="add-fab"
      direction="all"
      inertia
      x="{{addFabX}}"
      y="{{addFabY}}"
      bindchange="onAddFabMove"
      bindtouchend="onAddFabRelease"
      bindtap="addCat"
    >
      <text class="add-fab-plus">+</text>
    </movable-view>
  </movable-area>
  <!-- 底部按钮：未登录但有 demo 数据 -->
  <view wx:elif="{{!isLoggedIn && cats.length > 0 && displayCats.length > 0}}" class="add-section">
    <button class="add-btn" bindtap="goLogin">登录开始使用 →</button>
  </view>

  <!-- 排序弹窗 -->
  <view wx:if="{{showSortModal}}" class="sort-modal-mask" catchtap="closeSortModal">
    <view class="sort-modal" catchtap="stopBubble">
      <view class="sort-modal-head">
        <text class="sort-modal-title">选择排序方式</text>
        <text class="sort-modal-subtitle">让宠物列表按你习惯的顺序展示</text>
      </view>
      <view class="sort-option-list">
        <view
          wx:for="{{sortOptions}}"
          wx:key="value"
          class="sort-option {{sortBy === item.value ? 'active' : ''}}"
          bindtap="onSelectSort"
          data-sort="{{item.value}}"
        >
          <text class="sort-option-label">{{item.label}}</text>
          <text wx:if="{{sortBy === item.value}}" class="sort-option-check">✓</text>
        </view>
      </view>
      <view class="sort-modal-cancel" bindtap="closeSortModal">取消</view>
    </view>
  </view>

  <!-- 速记类型弹窗 -->
  <view wx:if="{{showQuickTypeModal}}" class="quick-type-modal-mask sort-modal-mask" catchtap="closeQuickTypeModal">
    <view class="quick-type-modal sort-modal" catchtap="stopBubble">
      <view class="sort-modal-head">
        <text class="sort-modal-title">选择速记类型</text>
        <text class="sort-modal-subtitle">为 {{quickCatName}} 添加一条健康记录</text>
      </view>
      <view class="sort-option-list">
        <view
          wx:for="{{quickTypeOptions}}"
          wx:key="value"
          class="sort-option"
          bindtap="onSelectQuickType"
          data-type="{{item.value}}"
          data-name="{{item.label}}"
        >
          <text class="sort-option-label">{{item.label}}</text>
          <text class="quick-type-arrow">›</text>
        </view>
      </view>
      <view class="sort-modal-cancel" bindtap="closeQuickTypeModal">取消</view>
    </view>
  </view>

  <!-- 速记弹窗 -->
  <view wx:if="{{showQuickModal}}" class="quick-modal-mask" catchtap="closeQuickModal">
    <view class="quick-modal" catchtap="stopBubble">
      <view class="quick-modal-head">
        <text class="quick-modal-title">快速记录 - {{quickTypeName}}</text>
        <text class="quick-modal-subtitle">选择记录日期，保存到当前宠物档案</text>
      </view>
      <view class="quick-modal-body">
        <text class="quick-modal-label">日期</text>
        <picker mode="date" value="{{quickDate}}" bindchange="onQuickDateChange">
          <view class="quick-picker"><text>{{quickDate}}</text><view class="quick-picker-chevron"></view></view>
        </picker>
      </view>
      <view class="quick-modal-btns">
        <view class="quick-btn-cancel" bindtap="closeQuickModal">取消</view>
        <view class="quick-btn-confirm {{quickSaving ? 'disabled' : ''}}" bindtap="saveQuickRecord">{{quickSaving ? '保存中...' : '保存'}}</view>
      </view>
    </view>
  </view>

</view>
