page {
  background: var(--theme-bg, #F7F9FB);
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, var(--theme-bg-strong, #CDEAE5) 0%, var(--theme-secondary-soft, #EAF7F5) 310rpx, var(--theme-bg, #F7F9FB) 650rpx),
    var(--theme-bg, #F7F9FB);
}

.expense-hero {
  min-height: 180rpx;
  margin: 0 -4rpx 18rpx;
  padding: 4rpx 12rpx 8rpx;
  box-sizing: border-box;
}

.expense-hero .ui-compact-hero-img {
  width: 178rpx;
  height: 150rpx;
  margin-right: 16rpx;
}

.expense-hero .ui-compact-title {
  color: #243044;
  font-size: 34rpx;
}

.expense-hero .ui-compact-desc {
  color: #536579;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}

.form-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), 0.10);
  box-shadow: 0 12rpx 32rpx rgba(68, 92, 120, 0.08);
}

.field {
  margin-bottom: 32rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  color: #243044;
  font-size: 27rpx;
  font-weight: 900;
}

.picker-box {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #F5F9FC;
  border: 1rpx solid #E8EEF4;
  box-sizing: border-box;
}

.picker-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.picker-main text {
  color: #243044;
  font-size: 28rpx;
  font-weight: 800;
}

.picker-icon {
  width: 42rpx;
  height: 42rpx;
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid var(--theme-primary, #5BA7D8);
  border-bottom: 4rpx solid var(--theme-primary, #5BA7D8);
  transform: rotate(45deg);
  margin: -8rpx 5rpx 0 18rpx;
  box-sizing: border-box;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.category-item {
  min-height: 128rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 22rpx;
  background: var(--theme-bg, #F7F9FB);
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.category-icon-wrap {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: var(--theme-primary-soft, #EAF4FB);
}

.category-item.orange .category-icon-wrap { background: #FFF1DF; }
.category-item.red .category-icon-wrap { background: #FFF0F0; }
.category-item.green .category-icon-wrap { background: var(--theme-secondary-soft, #EAF7F5); }
.category-item.blue .category-icon-wrap { background: var(--theme-primary-soft, #EAF4FB); }
.category-item.purple .category-icon-wrap { background: #F3EEF9; }
.category-item.gray .category-icon-wrap { background: #EEF3F7; }

.category-icon {
  width: 38rpx;
  height: 38rpx;
}

.category-name {
  color: #6E7A8A;
  font-size: 24rpx;
  font-weight: 800;
}

.category-item.active {
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), 0.44);
  box-shadow: 0 8rpx 18rpx rgba(var(--theme-primary-rgb, 91, 167, 216), 0.12);
}

.category-item.active .category-name {
  color: var(--theme-primary-deep, #2F8DB8);
}

.amount-box {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #F3FAFD, #F2FAF8);
  border: 2rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), 0.22);
  box-sizing: border-box;
}

.amount-yuan {
  flex-shrink: 0;
  color: var(--theme-primary, #5BA7D8);
  font-size: 44rpx;
  font-weight: 900;
}

.amount-input {
  flex: 1;
  min-width: 0;
  min-height: 76rpx;
  padding-left: 10rpx;
  color: #243044;
  font-size: 46rpx;
  font-weight: 900;
}

.note-input {
  width: 100%;
  min-height: 132rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #F5F9FC;
  border: 1rpx solid #E8EEF4;
  box-sizing: border-box;
  color: #243044;
  font-size: 27rpx;
  line-height: 1.5;
}

.save-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(247, 249, 251, 0), var(--theme-bg, #F7F9FB) 38%);
  box-sizing: border-box;
}

.save-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
  box-shadow: 0 14rpx 36rpx rgba(var(--theme-primary-rgb, 91, 167, 216), 0.28);
}

.save-btn text {
  color: #FFFFFF;
  font-size: 31rpx;
  font-weight: 900;
}

.save-btn.disabled {
  opacity: 0.55;
}

.picker-mask {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: rgba(36, 48, 68, 0.46);
  box-sizing: border-box;
}

.picker-panel {
  width: 100%;
  max-height: 76vh;
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, var(--theme-secondary-soft, #F2FBFA), #FFFFFF);
  box-shadow: 0 28rpx 70rpx rgba(24, 76, 108, 0.20);
  box-sizing: border-box;
}

.picker-title {
  display: block;
  color: #243044;
  font-size: 34rpx;
  font-weight: 900;
}

.picker-subtitle {
  display: block;
  margin: 8rpx 0 22rpx;
  color: #6E7A8A;
  font-size: 23rpx;
  line-height: 1.45;
}

.picker-list {
  max-height: 500rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  overflow-y: auto;
}

.pet-option {
  min-height: 94rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.pet-option.active {
  background: var(--theme-primary-soft, #EAF4FB);
  border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), 0.42);
}

.pet-option-icon {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
  flex-shrink: 0;
}

.pet-option-icon image {
  width: 42rpx;
  height: 42rpx;
}

.pet-option-copy {
  flex: 1;
  min-width: 0;
}

.pet-option-name {
  display: block;
  color: #243044;
  font-size: 28rpx;
  font-weight: 900;
}

.pet-option-desc {
  display: block;
  margin-top: 4rpx;
  color: #6E7A8A;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pet-option-check {
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 50%;
  text-align: center;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
  font-size: 25rpx;
  font-weight: 900;
}

.picker-cancel {
  height: 78rpx;
  line-height: 78rpx;
  margin-top: 18rpx;
  border-radius: 22rpx;
  text-align: center;
  color: #6E7A8A;
  background: #FFFFFF;
  font-size: 27rpx;
  font-weight: 800;
}
