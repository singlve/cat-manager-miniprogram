/* pages/services/services.wxss */
page { background: #F7F9FB; }

.services-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 72rpx;
  box-sizing: border-box;
}

.services-hero {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFFFFF, #F2FAFC);
  border: 1rpx solid rgba(91, 167, 216, 0.12);
  box-shadow: 0 10rpx 28rpx rgba(68, 92, 120, 0.07);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.services-hero .ui-compact-hero-img {
  width: 150rpx;
  height: 120rpx;
  border-radius: 22rpx;
  margin-right: 20rpx;
}

.services-hero .ui-compact-title {
  color: #243044;
  font-size: 32rpx;
}

.services-hero .ui-compact-desc {
  color: #7B8798;
  font-size: 24rpx;
  font-weight: 400;
}

.service-login-card {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(91, 167, 216, 0.08);
  box-shadow: 0 10rpx 30rpx rgba(68, 92, 120, 0.08);
}

.service-login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 36rpx 40rpx;
  text-align: center;
}

.service-login-img {
  width: 260rpx;
  height: 210rpx;
  margin-bottom: 18rpx;
}

.service-login-title {
  color: #243044;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.service-login-desc {
  max-width: 500rpx;
  margin: 12rpx 0 32rpx;
  color: #6E7A8A;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.55;
}

.service-login-btn {
  width: 100%;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 800;
}

.desktop-grid {
  display: flex;
  flex-wrap: wrap;
  row-gap: 34rpx;
  padding: 12rpx 2rpx 24rpx;
}

.desktop-app {
  width: 25%;
  min-height: 146rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
}

.desktop-app:active {
  opacity: 0.72;
}

.desktop-icon {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: 0 12rpx 26rpx rgba(68, 92, 120, 0.10);
}

.desktop-icon-img {
  width: 54rpx;
  height: 54rpx;
}

.icon-teal {
  background: linear-gradient(135deg, #EAF7F5, #DDF3EF);
}

.icon-purple {
  background: linear-gradient(135deg, #F1F4FF, #E9F0FF);
}

.icon-orange {
  background: linear-gradient(135deg, #FFF4E6, #FFE8CC);
}

.desktop-title {
  width: 128rpx;
  min-height: 58rpx;
  color: #243044;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.22;
  text-align: center;
  word-break: keep-all;
}

.notify-badge {
  position: absolute;
  top: -8rpx;
  right: -10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #F36B6B;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}
