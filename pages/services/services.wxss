/* pages/services/services.wxss */
page { background: var(--theme-bg, #F7F9FB); }

.services-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 72rpx;
  box-sizing: border-box;
}

.services-hero {
  border-radius: 28rpx;
  background:
    radial-gradient(
      circle at 8% 18%,
      rgba(var(--theme-primary-rgb, 91, 167, 216), .14),
      transparent 34%
    ),
    linear-gradient(
      135deg,
      rgba(255, 255, 255, .94) 0%,
      var(--theme-primary-soft, #EAF4FB) 58%,
      var(--theme-secondary-soft, #EAF7F5) 100%
    );
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .18);
  box-shadow:
    0 14rpx 34rpx rgba(var(--theme-primary-rgb, 91, 167, 216), .10),
    inset 0 1rpx 0 rgba(255, 255, 255, .72);
}

.services-hero .ui-compact-hero-img {
  margin-right: 0;
}

.services-hero .ui-compact-title {
  color: var(--theme-text, #243044);
  font-size: 32rpx;
}

.services-hero .ui-compact-kicker {
  color: var(--theme-primary-deep, #2F8DB8);
}

.services-hero .ui-compact-desc {
  color: var(--theme-text-secondary, #6E7A8A);
  font-size: 24rpx;
  font-weight: 600;
}

.service-login-card {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), 0.08);
  box-shadow: 0 10rpx 30rpx rgba(68, 92, 120, 0.08);
}

.service-login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 36rpx 40rpx;
  text-align: center;
}

.service-login-img {
  width: 260rpx;
  height: 210rpx;
  margin-bottom: 18rpx;
}

.service-login-title {
  color: #243044;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.service-login-desc {
  max-width: 500rpx;
  margin: 12rpx 0 32rpx;
  color: #6E7A8A;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.55;
}

.service-login-btn {
  width: 100%;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 800;
}

.desktop-grid {
  display: flex;
  flex-wrap: wrap;
  row-gap: 34rpx;
  padding: 12rpx 2rpx 24rpx;
}

.desktop-app {
  width: 25%;
  min-height: 146rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
}

.desktop-app:active {
  opacity: 0.72;
}

.desktop-icon {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: 0 12rpx 26rpx rgba(68, 92, 120, 0.10);
}

.desktop-icon-img {
  width: 54rpx;
  height: 54rpx;
}

.icon-teal {
  background: linear-gradient(135deg, var(--theme-secondary-soft, #EAF7F5), var(--theme-secondary-soft, #DDF3EF));
}

.icon-purple {
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
}

.icon-orange {
  background: linear-gradient(135deg, #FFF4E6, #FFE8CC);
}

.icon-benefit {
  background: linear-gradient(135deg, #FFF1DF, var(--theme-primary-soft, #EAF4FB));
  border: 1rpx solid rgba(255,184,107,.24);
}

.benefit-dot {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 7rpx;
  border: 3rpx solid var(--theme-card, #FFFFFF);
  border-radius: 50%;
  background: #F36B6B;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.icon-theme {
  background: linear-gradient(145deg, #FFFFFF, #EEF7F8);
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .14);
}

.theme-palette {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,.9);
  box-shadow: inset 0 0 0 1rpx rgba(36,48,68,.05);
}

.theme-palette-dot {
  position: absolute;
  width: 25rpx;
  height: 25rpx;
  border: 4rpx solid #FFFFFF;
  border-radius: 50%;
  box-sizing: border-box;
}

.dot-blue { left: 6rpx; top: 7rpx; background: var(--theme-primary, #5BA7D8); }
.dot-green { right: 6rpx; top: 12rpx; background: var(--theme-secondary, #6BC6B3); }
.dot-orange { left: 18rpx; bottom: 5rpx; background: #FFB86B; }

.desktop-title {
  width: 128rpx;
  min-height: 58rpx;
  color: #243044;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.22;
  text-align: center;
  word-break: keep-all;
}

.notify-badge {
  position: absolute;
  top: -8rpx;
  right: -10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #F36B6B;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

@media (max-width: 340px) {
  .services-page { padding-left: 18rpx; padding-right: 18rpx; }
  .services-hero { padding: 20rpx; gap: 12rpx; }
  .services-hero .ui-compact-hero-img {
    width: 126rpx;
    height: 104rpx;
    margin-right: 0;
  }
  .desktop-grid { row-gap: 28rpx; }
  .desktop-icon { width: 86rpx; height: 86rpx; border-radius: 24rpx; }
  .desktop-icon-img { width: 48rpx; height: 48rpx; }
  .desktop-title { width: 116rpx; font-size: 22rpx; }
}
