/* pages/reminders/reminders.wxss */

/* ─── Demo 水印提示 ─── */
.demo-watermark {
  background: linear-gradient(135deg, #fffbe6, #fff7cc);
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #ffe58f;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}
.demo-watermark-icon { width: 32rpx; height: 32rpx; flex-shrink: 0; }
.demo-watermark text {
  font-size: 24rpx;
  color: #d48806;
}

/* ─── 未登录引导 ─── */
.guest-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 52rpx;
}
.guest-illustration {
  width: 200rpx; height: 200rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(255,152,0,0.2);
}
.guest-emoji { font-size: 96rpx; }
.guest-title { font-size: 36rpx; color: #1a1a1a; font-weight: 700; margin-bottom: 16rpx; }
.guest-desc { font-size: 26rpx; color: #888; margin-bottom: 48rpx; text-align: center; max-width: 480rpx; line-height: 1.6; }
.guest-login-btn {
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 50rpx; padding: 26rpx 72rpx;
  box-shadow: 0 12rpx 36rpx rgba(74,144,217,0.4);
  border: none;
}
.guest-login-btn::after { border: none; }

.page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #CDEAE5 0%, #EAF7F5 300rpx, #F7F9FB 620rpx),
    #F7F9FB;
  padding: 24rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

.reminder-hero {
  margin: 0 0 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFFFFF, #F2FAFC);
  border: 1rpx solid rgba(91, 167, 216, 0.12);
  box-shadow: 0 10rpx 28rpx rgba(68, 92, 120, 0.07);
}

.reminder-hero .ui-compact-hero-img {
  width: 150rpx;
  height: 120rpx;
  border-radius: 22rpx;
  margin-right: 20rpx;
}

.reminder-hero .ui-compact-title {
  color: #243044;
  font-size: 32rpx;
}

.reminder-hero .ui-compact-desc {
  color: #7B8798;
  font-size: 24rpx;
  font-weight: 400;
}

.smart-plan-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 96% 16%, rgba(255,184,107,0.22), transparent 30%),
    linear-gradient(135deg, rgba(255,255,255,0.96), #EAF7F5);
  border: 1rpx solid rgba(91, 167, 216, 0.14);
  box-shadow: 0 12rpx 32rpx rgba(68, 92, 120, 0.08);
}

.smart-plan-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #EAF4FB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.smart-plan-body {
  flex: 1;
  min-width: 0;
}

.smart-plan-title {
  display: block;
  font-size: 29rpx;
  font-weight: 900;
  color: #243044;
  line-height: 1.3;
}

.smart-plan-desc {
  display: block;
  margin-top: 5rpx;
  font-size: 23rpx;
  color: #6E7A8A;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.smart-plan-arrow {
  color: #5BA7D8;
  font-size: 42rpx;
  font-weight: 700;
  flex-shrink: 0;
}

/* ─── 空状态 ─── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 560rpx;
  justify-content: flex-start;
  padding: 86rpx 40rpx 120rpx;
  box-sizing: border-box;
  text-align: center;
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}
.reminder-empty-img {
  width: 280rpx;
  height: 220rpx;
  margin: 0 auto 18rpx;
}
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 34rpx; color: #243044; font-weight: 900; margin-bottom: 12rpx; }
.empty-desc { font-size: 27rpx; color: #6E7A8A; text-align: center; line-height: 1.6; font-weight: 600; }
.empty-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 24rpx 60rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(74,144,217,0.35);
}

/* ─── 内容区 ─── */
.content { padding-bottom: 20rpx; }

.reminder-filter-panel {
  margin-bottom: 18rpx;
  padding: 10rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(91, 167, 216, 0.14);
  box-shadow: 0 12rpx 32rpx rgba(68, 92, 120, 0.08);
}

/* ─── 宠物筛选标签栏 ─── */
.cat-filter-tabs {
  display: flex;
  white-space: nowrap;
  padding: 0 !important;
  margin-bottom: 14rpx;
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}
.cat-filter-tab {
  display: inline-flex;
  align-items: center;
  padding: 13rpx 24rpx;
  margin-right: 10rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6E7A8A;
  background: rgba(238, 244, 248, 0.82);
  flex-shrink: 0;
  transition: all 0.2s;
  font-weight: 700;
}
.cat-filter-tab.active {
  background: #FFFFFF;
  color: #2F8DB8;
  font-weight: 900;
  box-shadow: 0 8rpx 20rpx rgba(45, 83, 115, 0.10);
}

/* ─── 区块标题 ─── */
.section-header {
  display: flex;
  align-items: center;
  padding: 20rpx 8rpx 16rpx;
  margin-bottom: 12rpx;
}
.section-icon { font-size: 32rpx; margin-right: 10rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #333; }
.section-badge {
  margin-left: 12rpx;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.section-header.danger .section-title { color: #cf1322; }
.section-header.danger .section-badge { background: #fff1f0; color: #cf1322; }
.section-header.warning .section-title { color: #d48806; }
.section-header.warning .section-badge { background: #fff7e6; color: #d48806; }
.section-header.urgent .section-title { color: #d48806; }
.section-header.urgent .section-badge { background: #fffbe6; color: #d46b08; border: 2rpx solid #ffe58f; }
.section-header.normal .section-title { color: #666; }

/* ─── 卡片 ─── */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-danger { border-left: 8rpx solid #ff4d4f; }
.card-warning { border-left: 8rpx solid #faad14; }
.card-urgent {
  border-left: 8rpx solid #ff6d00;
  background: linear-gradient(to right, #fff9f0, #fff);
  box-shadow: 0 4rpx 16rpx rgba(255, 109, 0, 0.15);
}
.card-normal  { border-left: 8rpx solid #5BA7D8; }

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.type-icon { font-size: 44rpx; margin-right: 14rpx; flex-shrink: 0; }
.card-info { flex: 1; }
.card-header-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.cat-name { font-size: 30rpx; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 4rpx; }
.type-label { font-size: 24rpx; color: #888; }

/* 标签 */
.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.tag-danger {
  background: #FFF1F2;
  color: #D9363E;
  border: 1rpx solid rgba(243, 107, 107, .28);
  box-shadow: none;
}
.tag-warning { background: #faad14; color: #fff; }
.tag-urgent {
  background: #FFF4E6;
  color: #B85A00;
  border: 1rpx solid rgba(255, 184, 107, .38);
  box-shadow: none;
  animation: none;
}

/* 下次提醒时间高亮行 */
.next-date-highlight {
  display: flex;
  align-items: center;
  background: #fff3e0;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 14rpx;
  border: 2rpx solid #ffe0b2;
}
.next-date-highlight.normal {
  background: #f0f7ff;
  border-color: #d4e4ff;
}
.next-date-highlight-label { font-size: 26rpx; color: #999; margin-right: 8rpx; }
.next-date-highlight-val {
  font-size: 28rpx;
  font-weight: 800;
  color: #e65100;
  margin-right: 4rpx;
}
.next-date-highlight.normal .next-date-highlight-val {
  color: #1565c0;
}

/* 未来日期 */
.next-date { font-size: 24rpx; color: #999; flex-shrink: 0; }

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}
.info-label { color: #999; min-width: 60rpx; margin-right: 8rpx; }
.info-val { color: #333; margin-right: 24rpx; }
.info-val.highlight { color: #d48806; font-weight: 600; }

/* 操作按钮 */
.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  gap: 12rpx;
}
.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  border: none;
}
.action-btn.edit {
  background: #e8f4ff;
  color: #5BA7D8;
}
.action-btn.delete {
  background: #fff1f0;
  color: #ff4d4f;
}

/* ─── 底部添加按钮 ─── */
.fab-wrap {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  bottom: calc(40rpx + constant(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  z-index: 100;
}
.fab-btn {
  width: 100%;
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(74,144,217,0.4);
}
.fab-btn::after { border: none; }

.add-fab-area {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
}

.add-fab {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  box-shadow: 0 14rpx 36rpx rgba(91, 167, 216, 0.34);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.add-fab-plus {
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1;
  transform: translateY(-2rpx);
}

/* ── 状态筛选标签 ── */
/* ── 状态筛选（分段控制器） ── */
.status-segment {
  display: flex;
  margin: 0;
  background: rgba(238, 244, 248, 0.78) !important;
  border-radius: 36rpx;
  padding: 6rpx;
  border: none !important;
  box-shadow: none !important;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4F6074;
  background: transparent;
  transition: all 0.25s;
  font-weight: 800;
}
.seg-active {
  background: #fff;
  color: #5BA7D8;
  font-weight: 900;
  box-shadow: 0 8rpx 20rpx rgba(45, 83, 115, 0.10);
}

/* ── 已完成区块 ── */
.section-header.completed {
  /* 无特殊背景，与未来提醒风格一致 */
}
.section-badge.completed {
  color: #2e7d32;
}

/* ── 已完成卡片 ── */
.card-completed {
  background: #f1f8e9;
  border-left: 8rpx solid #a8e6cf;
}

/* ── 已完成标签 ── */
.tag-completed {
  color: #2e7d32;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
}

/* ── 完成按钮 ── */
.complete-chip {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 800;
  color: #3F8F54;
  background: #EAF7F0;
  border: 1rpx solid rgba(63, 143, 84, .18);
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
}
.complete-chip:active {
  background: #DDF1E6;
}
.action-btn.complete {
  color: #2e7d32;
}
.action-btn.complete:active {
  background: #e8f5e9;
}
