<!-- pages/reminders/reminders.wxml -->
<view class="page {{themeClass}}">
  <include src="../../templates/offline-tip.wxml" />

  <view class="ui-compact-hero ui-tab-hero reminder-hero">
    <image class="ui-compact-hero-img" src="/assets/illustrations/empty-reminder-transparent.png" mode="aspectFit" />
    <view class="ui-compact-hero-body">
      <text class="ui-compact-kicker">REMINDER</text>
      <text class="ui-compact-title">提醒列表</text>
      <text class="ui-compact-desc">把疫苗、驱虫、洗护和体检安排好，重要照护不容易忘。</text>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view wx:if="{{!isLoggedIn}}" class="guest-banner">
    <image class="reminder-empty-img" src="/assets/illustrations/empty-reminder-transparent.png" mode="aspectFit" />
    <text class="guest-title">登录后管理提醒</text>
    <text class="guest-desc">登录后可以为宠物设置定期提醒，不错过每一次护理</text>
    <button class="guest-login-btn" bindtap="goLogin">登录 / 注册</button>
  </view>

  <!-- 已登录：筛选区域 + 卡片列表 -->
  <view wx:if="{{isLoggedIn}}">
    <view wx:if="{{loadError}}" class="load-error-state">
      <image class="load-error-icon ui-icon-lg" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
      <text class="load-error-title">提醒加载失败</text>
      <text class="load-error-desc">请检查网络后重新加载，已有提醒不会丢失</text>
      <button class="load-retry-btn" bindtap="retryLoad">重新加载</button>
    </view>

    <view wx:else class="smart-plan-entry" bindtap="goReminderPlan">
      <view class="smart-plan-icon">
        <image class="ui-icon" src="/assets/icons/ui/reminder.png" mode="aspectFit" />
      </view>
      <view class="smart-plan-body">
        <text class="smart-plan-title">智能提醒计划</text>
        <text class="smart-plan-desc">一键生成洗澡、驱虫、体检等常用提醒</text>
      </view>
      <text class="smart-plan-arrow">›</text>
    </view>

    <view class="notify-health-card">
      <view class="notify-health-main" bindtap="onNotifyAction">
        <view class="notify-health-icon {{notifyAuth.status}}">
          <image class="notify-health-icon-img" src="/assets/icons/ui/reminder.png" mode="aspectFit" />
        </view>
        <view class="notify-health-copy">
          <text class="notify-health-title">{{notifyAuth.title}}</text>
          <text class="notify-health-desc">{{latestNotify.text}} · 同日多项合并发送</text>
        </view>
        <view class="notify-health-action">
          <text>{{notifyAuth.status === 'success' || notifyAuth.status === 'disabled' ? '设置' : '去开启'}}</text>
          <view class="notify-action-chevron"></view>
        </view>
      </view>
    </view>

    <view class="reminder-filter-panel">
      <!-- 宠物筛选标签栏 -->
      <scroll-view wx:if="{{catTabs.length > 1}}" class="cat-filter-tabs" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="cat-filter-tab {{catFilter === 'all' ? 'active' : ''}}" bindtap="onCatFilterChange" data-catid="all">全部</view>
        <view
          wx:for="{{catTabs}}"
          wx:key="_id"
          class="cat-filter-tab {{catFilter === item._id ? 'active' : ''}}"
          bindtap="onCatFilterChange"
          data-catid="{{item._id}}"
        >{{item.name}}</view>
      </scroll-view>

      <!-- 状态筛选标签栏 -->
      <view class="status-segment">
        <view class="seg-item {{statusFilter === 'active' && !batchMode ? 'seg-active' : ''}}" bindtap="onStatusFilterChange" data-status="active">进行中</view>
        <view class="seg-item {{statusFilter === 'completed' && !batchMode ? 'seg-active' : ''}}" bindtap="onStatusFilterChange" data-status="completed">已完成</view>
        <view wx:if="{{hasData}}" class="seg-item seg-manage {{batchMode ? 'seg-active' : ''}}" bindtap="toggleBatchMode">
          {{batchMode ? '退出管理' : '批量管理'}}
        </view>
      </view>
    </view>

    <view wx:if="{{hasData && batchMode}}" class="batch-toolbar active">
      <text class="batch-summary">已选 {{selectedReminderIds.length}} 项</text>
      <text class="batch-link" bindtap="selectAllVisible">全选当前</text>
      <text wx:if="{{statusFilter !== 'completed'}}" class="batch-action complete" bindtap="batchCompleteReminders">完成</text>
      <text class="batch-action delete" bindtap="batchDeleteReminders">删除</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!hasData}}" class="empty-state">
      <image class="reminder-empty-img" src="/assets/illustrations/empty-reminder-transparent.png" mode="aspectFit" />
      <text class="empty-title">暂无提醒</text>
      <text class="empty-desc">{{statusFilter === 'active' ? '所有提醒都在进行中，干得漂亮！' : '还没有完成任何提醒'}}</text>
    </view>

    <!-- 已逾期区块 -->
    <view wx:if="{{overdueList.length > 0}}">
      <view class="section-header danger">
        <image class="section-icon ui-icon-sm" src="/assets/icons/ui/warning.png" mode="aspectFit" />
        <text class="section-title">已逾期</text>
        <view class="section-badge danger">{{overdueList.length}}</view>
      </view>
      <view wx:for="{{overdueList}}" wx:key="_id" class="card card-danger">
        <view class="card-header">
          <view wx:if="{{batchMode}}" class="batch-check {{item._selected ? 'selected' : ''}}" bindtap="toggleReminderSelection" data-id="{{item._id}}">
            <view class="batch-check-mark"></view>
          </view>
          <image class="type-icon ui-icon theme-business-icon" src="{{item._typeIconPath}}" mode="aspectFit" />
          <view class="card-info">
            <text class="cat-name">{{item.catName}}</text>
            <text class="type-label">{{item._typeLabel}}</text>
          </view>
          <view class="card-header-actions">
            <view class="tag tag-danger">逾期 {{0 - item.daysUntil}} 天</view>
            <text wx:if="{{!batchMode}}" class="complete-chip" bindtap="markComplete" data-id="{{item._id}}">完成</text>
          </view>
        </view>
        <view class="next-date-highlight">
          <text class="next-date-highlight-label">下次提醒</text>
          <text class="next-date-highlight-val">{{item.nextDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">上次</text><text class="info-val">{{item.lastDate}}</text>
          <text class="info-label">间隔</text><text class="info-val">每{{item.intervalDays}}天</text>
        </view>
        <view wx:if="{{item.note}}" class="info-row">
          <text class="info-label">备注</text><text class="info-val">{{item.note}}</text>
        </view>
        <view class="actions">
          <text class="action-btn edit" bindtap="editReminder" data-id="{{item._id}}">编辑</text>
          <text class="action-btn delete {{deletingReminderId === item._id ? 'disabled' : ''}}" bindtap="deleteReminder" data-id="{{item._id}}">{{deletingReminderId === item._id ? '删除中' : '删除'}}</text>
        </view>
      </view>
    </view>

    <!-- 即将到期区块（7天内） -->
    <view wx:if="{{upcomingList.length > 0}}">
      <view class="section-header urgent">
        <image class="section-icon ui-icon-sm" src="/assets/icons/ui/urgent.png" mode="aspectFit" />
        <text class="section-title">即将到期</text>
        <view class="section-badge urgent">{{upcomingList.length}}</view>
      </view>
      <view wx:for="{{upcomingList}}" wx:key="_id" class="card card-urgent">
        <view class="card-header">
          <view wx:if="{{batchMode}}" class="batch-check {{item._selected ? 'selected' : ''}}" bindtap="toggleReminderSelection" data-id="{{item._id}}">
            <view class="batch-check-mark"></view>
          </view>
          <image class="type-icon ui-icon theme-business-icon" src="{{item._typeIconPath}}" mode="aspectFit" />
          <view class="card-info">
            <text class="cat-name">{{item.catName}}</text>
            <text class="type-label">{{item._typeLabel}}</text>
          </view>
          <view class="card-header-actions">
            <view class="tag tag-urgent">{{item.daysUntil}}天后</view>
            <text wx:if="{{!batchMode}}" class="complete-chip" bindtap="markComplete" data-id="{{item._id}}">完成</text>
          </view>
        </view>
        <view class="next-date-highlight">
          <text class="next-date-highlight-label">下次提醒</text>
          <text class="next-date-highlight-val">{{item.nextDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">上次</text><text class="info-val">{{item.lastDate}}</text>
          <text class="info-label">间隔</text><text class="info-val">每{{item.intervalDays}}天</text>
        </view>
        <view wx:if="{{item.note}}" class="info-row">
          <text class="info-label">备注</text><text class="info-val">{{item.note}}</text>
        </view>
        <view class="actions">
          <text class="action-btn edit" bindtap="editReminder" data-id="{{item._id}}">编辑</text>
          <text class="action-btn delete {{deletingReminderId === item._id ? 'disabled' : ''}}" bindtap="deleteReminder" data-id="{{item._id}}">{{deletingReminderId === item._id ? '删除中' : '删除'}}</text>
        </view>
      </view>
    </view>

    <!-- 未来提醒区块 -->
    <view wx:if="{{futureList.length > 0}}">
      <view class="section-header normal">
        <image class="section-icon ui-icon-sm" src="/assets/icons/ui/calendar.png" mode="aspectFit" />
        <text class="section-title">未来提醒</text>
      </view>
      <view wx:for="{{futureList}}" wx:key="_id" class="card card-normal">
        <view class="card-header">
          <view wx:if="{{batchMode}}" class="batch-check {{item._selected ? 'selected' : ''}}" bindtap="toggleReminderSelection" data-id="{{item._id}}">
            <view class="batch-check-mark"></view>
          </view>
          <image class="type-icon ui-icon theme-business-icon" src="{{item._typeIconPath}}" mode="aspectFit" />
          <view class="card-info">
            <text class="cat-name">{{item.catName}}</text>
            <text class="type-label">{{item._typeLabel}}</text>
          </view>
          <view class="card-header-actions">
            <text wx:if="{{!batchMode}}" class="complete-chip" bindtap="markComplete" data-id="{{item._id}}">完成</text>
          </view>
        </view>
        <view class="next-date-highlight normal">
          <text class="next-date-highlight-label">距今约</text>
          <text class="next-date-highlight-val">{{item.daysUntil}} 天</text>
          <text class="next-date-highlight-label">，下次</text>
          <text class="next-date-highlight-val">{{item.nextDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">上次</text><text class="info-val">{{item.lastDate}}</text>
          <text class="info-label">间隔</text><text class="info-val">每{{item.intervalDays}}天</text>
        </view>
        <view wx:if="{{item.note}}" class="info-row">
          <text class="info-label">备注</text><text class="info-val">{{item.note}}</text>
        </view>
        <view class="actions">
          <text class="action-btn edit" bindtap="editReminder" data-id="{{item._id}}">编辑</text>
          <text class="action-btn delete {{deletingReminderId === item._id ? 'disabled' : ''}}" bindtap="deleteReminder" data-id="{{item._id}}">{{deletingReminderId === item._id ? '删除中' : '删除'}}</text>
        </view>
      </view>
    </view>

    <!-- 已完成区块 -->
    <view wx:if="{{completedList.length > 0}}">
      <view class="section-header completed">
        <image class="section-icon ui-icon-sm" src="/assets/icons/ui/done.png" mode="aspectFit" />
        <text class="section-title">已完成</text>
        <view class="section-badge completed">{{completedList.length}}</view>
      </view>
      <view wx:for="{{completedList}}" wx:key="_id" class="card card-completed">
        <view class="card-header">
          <view wx:if="{{batchMode}}" class="batch-check {{item._selected ? 'selected' : ''}}" bindtap="toggleReminderSelection" data-id="{{item._id}}">
            <view class="batch-check-mark"></view>
          </view>
          <image class="type-icon ui-icon theme-business-icon" src="{{item._typeIconPath}}" mode="aspectFit" />
          <view class="card-info">
            <text class="cat-name">{{item.catName}}</text>
            <text class="type-label">{{item._typeLabel}}</text>
          </view>
          <view class="tag tag-completed">已完成</view>
        </view>
        <view class="info-row">
          <text class="info-label">完成日期</text><text class="info-val">{{item.completedAt}}</text>
          <text class="info-label">下次</text><text class="info-val">{{item.nextDate}}</text>
        </view>
        <view wx:if="{{item.note}}" class="info-row">
          <text class="info-label">备注</text><text class="info-val">{{item.note}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Demo 数据（未登录但有猫筛选时） -->
  <view wx:elif="{{!isLoggedIn && hasData}}" class="content">
    <view class="demo-watermark">
      <image class="demo-watermark-icon ui-icon-sm" src="/assets/icons/ui/about.png" mode="aspectFit" />
      <text>以下为示例展示，登录后可管理自己的提醒</text>
    </view>

    <view wx:if="{{overdueList.length > 0}}">
      <view class="section-header danger">
        <image class="section-icon ui-icon-sm" src="/assets/icons/ui/warning.png" mode="aspectFit" />
        <text class="section-title">已逾期</text>
        <view class="section-badge danger">{{overdueList.length}}</view>
      </view>
      <view wx:for="{{overdueList}}" wx:key="_id" class="card card-danger">
        <view class="card-header">
          <image class="type-icon ui-icon theme-business-icon" src="{{item._typeIconPath}}" mode="aspectFit" />
          <view class="card-info">
            <text class="cat-name">{{item.catName}}</text>
            <text class="type-label">{{item._typeLabel}}</text>
          </view>
          <view class="tag tag-danger">逾期 {{0 - item.daysUntil}} 天</view>
        </view>
        <view class="next-date-highlight">
          <text class="next-date-highlight-label">下次提醒</text>
          <text class="next-date-highlight-val">{{item.nextDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">上次</text><text class="info-val">{{item.lastDate}}</text>
          <text class="info-label">间隔</text><text class="info-val">每{{item.intervalDays}}天</text>
        </view>
      </view>
    </view>

    <view wx:if="{{upcomingList.length > 0}}">
      <view class="section-header urgent">
        <image class="section-icon ui-icon-sm" src="/assets/icons/ui/urgent.png" mode="aspectFit" />
        <text class="section-title">即将到期</text>
        <view class="section-badge urgent">{{upcomingList.length}}</view>
      </view>
      <view wx:for="{{upcomingList}}" wx:key="_id" class="card card-urgent">
        <view class="card-header">
          <image class="type-icon ui-icon theme-business-icon" src="{{item._typeIconPath}}" mode="aspectFit" />
          <view class="card-info">
            <text class="cat-name">{{item.catName}}</text>
            <text class="type-label">{{item._typeLabel}}</text>
          </view>
          <view class="tag tag-urgent">{{item.daysUntil}}天后</view>
        </view>
        <view class="next-date-highlight">
          <text class="next-date-highlight-label">下次提醒</text>
          <text class="next-date-highlight-val">{{item.nextDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">上次</text><text class="info-val">{{item.lastDate}}</text>
          <text class="info-label">间隔</text><text class="info-val">每{{item.intervalDays}}天</text>
        </view>
      </view>
    </view>

    <view wx:if="{{futureList.length > 0}}">
      <view class="section-header normal">
        <image class="section-icon ui-icon-sm" src="/assets/icons/ui/calendar.png" mode="aspectFit" />
        <text class="section-title">未来提醒</text>
      </view>
      <view wx:for="{{futureList}}" wx:key="_id" class="card card-normal">
        <view class="card-header">
          <image class="type-icon ui-icon theme-business-icon" src="{{item._typeIconPath}}" mode="aspectFit" />
          <view class="card-info">
            <text class="cat-name">{{item.catName}}</text>
            <text class="type-label">{{item._typeLabel}}</text>
          </view>
        </view>
        <view class="next-date-highlight normal">
          <text class="next-date-highlight-label">距今约</text>
          <text class="next-date-highlight-val">{{item.daysUntil}} 天</text>
          <text class="next-date-highlight-label">，下次</text>
          <text class="next-date-highlight-val">{{item.nextDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">上次</text><text class="info-val">{{item.lastDate}}</text>
          <text class="info-label">间隔</text><text class="info-val">每{{item.intervalDays}}天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 列表态悬浮添加按钮：已登录且当前有提醒卡片 -->
  <movable-area wx:if="{{isLoggedIn && statusFilter === 'active' && hasData}}" class="add-fab-area">
    <movable-view
      class="add-fab"
      direction="all"
      inertia
      x="{{addFabX}}"
      y="{{addFabY}}"
      bindchange="onAddFabMove"
      bindtouchend="onAddFabRelease"
      bindtap="addReminder"
    >
      <text class="add-fab-plus">+</text>
    </movable-view>
  </movable-area>

  <!-- 空状态添加按钮：已登录但当前没有提醒卡片 -->
  <view wx:elif="{{isLoggedIn && statusFilter === 'active' && !hasData}}" class="fab-wrap">
    <button class="fab-btn" bindtap="addReminder">+ 添加提醒</button>
  </view>
  <!-- 未登录底部引导 -->
  <view wx:elif="{{!isLoggedIn && hasData}}" class="fab-wrap">
    <button class="fab-btn" bindtap="goLogin">登录开始使用 →</button>
  </view>

</view>
