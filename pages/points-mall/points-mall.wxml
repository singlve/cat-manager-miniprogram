<!--pages/points-mall/points-mall.wxml-->
<view class="page">
  <include src="../../templates/offline-tip.wxml" />

  <!-- 积分余额 -->
  <view class="points-banner">
    <view class="points-balance">
      <text class="balance-label">我的积分</text>
      <text class="balance-num">{{points}}</text>
    </view>
    <view class="banner-action" bindtap="goInventory">
      <text>🎒 我的背包</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar">
    <view class="filter-tag {{filter==='all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">全部</view>
    <view class="filter-tag {{filter==='virtual' ? 'active' : ''}}" bindtap="switchFilter" data-filter="virtual">虚拟商品</view>
    <view class="filter-tag {{filter==='physical' ? 'active' : ''}}" bindtap="switchFilter" data-filter="physical">实物商品</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-tip">加载中...</view>

  <!-- 商品列表 -->
  <block wx:else>
    <view wx:if="{{filteredItems.length === 0}}" class="empty-tip">
      <text style="font-size:60rpx;">🛒</text>
      <text style="color:#999;margin-top:16rpx;">暂无商品</text>
    </view>
    <view wx:else class="item-list">
      <view class="item-card" wx:for="{{filteredItems}}" wx:key="_id" bindtap="openRedeem" data-item="{{item}}">
        <view class="item-img-wrap">
          <image wx:if="{{item.image}}" class="item-img" src="{{item.image}}" mode="aspectFill" lazy-load/>
          <view wx:else class="item-img item-img-placeholder">🎁</view>
          <view wx:if="{{item.type === 'physical'}}" class="item-badge physical">实物</view>
          <view wx:else class="item-badge virtual">虚拟</view>
        </view>
        <view class="item-body">
          <text class="item-name">{{item.name}}</text>
          <text wx:if="{{item.desc}}" class="item-desc">{{item.desc}}</text>
          <view class="item-footer">
            <view class="item-points">
              <text class="points-icon">⚡</text>
              <text class="points-num">{{item.points}}</text>
            </view>
            <view wx:if="{{item.type === 'physical'}}" class="item-stock">
              <text>库存：{{item.stock || 0}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 兑换弹窗（含数量选择） -->
  <view wx:if="{{showRedeemModal}}" class="mask" catchtap="closeRedeem">
    <view class="redeem-sheet" catchtap="stopBubble">
      <view class="sheet-bar"></view>
      <text class="sheet-title">确认兑换</text>
      <view class="redeem-info" wx:if="{{redeemTarget}}">
        <text class="redeem-name">{{redeemTarget.name}}</text>
        <text class="redeem-desc" wx:if="{{redeemTarget.desc}}">{{redeemTarget.desc}}</text>

        <!-- 数量选择器（实物商品且库存>1时显示） -->
        <view wx:if="{{redeemTarget.type === 'physical' && redeemMaxQty > 1}}" class="qty-section">
          <text class="qty-label">兑换数量</text>
          <view class="qty-stepper">
            <view class="step-btn {{redeemQty <= 1 ? 'disabled' : ''}}" catchtap="qtyMinus">−</view>
            <text class="step-val">{{redeemQty}}</text>
            <view class="step-btn {{redeemQty >= redeemMaxQty ? 'disabled' : ''}}" catchtap="qtyPlus">+</view>
          </view>
          <view class="qty-shortcuts">
            <view wx:for="{{[1,2,3,5,10]}}" wx:key="*this"
              wx:if="{{item <= redeemMaxQty}}"
              class="qs {{redeemQty === item ? 'active' : ''}}"
              catchtap="setRedeemQty" data-qty="{{item}}">{{item}}件</view>
          </view>
        </view>

        <view class="redeem-cost">
          <text>消耗积分：</text>
          <text class="cost-num">{{redeemTotalCost}}</text>
        </view>
        <view class="redeem-tip {{points < redeemTotalCost || (redeemTarget.type === 'physical' && redeemQty > (redeemTarget.stock || 0)) ? 'insufficient' : ''}}">
          <text wx:if="{{points < redeemTotalCost}}">❌ 积分不足（当前 {{points}} 积分）</text>
          <text wx:elif="{{redeemTarget.type === 'physical' && redeemQty > (redeemTarget.stock || 0)}}">❌ 库存不足</text>
          <text wx:else>兑换后剩余 {{points - redeemTotalCost}} 积分</text>
        </view>
      </view>
      <view class="sheet-btns">
        <view class="s-btn cancel" catchtap="closeRedeem">取消</view>
        <view class="s-btn confirm {{redeeming || points < redeemTotalCost || (redeemTarget.type === 'physical' && redeemQty > (redeemTarget.stock || 0)) ? 'disabled' : ''}}"
          catchtap="confirmRedeem">{{redeeming ? '兑换中...' : '确认兑换(' + redeemQty + '件)'}}</view>
      </view>
    </view>
  </view>

</view>
