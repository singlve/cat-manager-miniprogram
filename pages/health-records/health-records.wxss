/* pages/health-records/health-records.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
}

/* ─── 页面头部 ─── */
.page-header { margin-bottom: 28rpx; }
.page-title { font-size: 40rpx; font-weight: 800; color: #1a1a1a; display: block; margin-bottom: 6rpx; }
.page-subtitle { font-size: 26rpx; color: #999; }

/* ─── 筛选标签 ─── */
.filter-tabs { display: flex; gap: 16rpx; margin-bottom: 28rpx; flex-wrap: wrap; }
.tab { padding: 12rpx 28rpx; background: #fff; border-radius: 40rpx; font-size: 26rpx; color: #666; border: 2rpx solid transparent; }
.tab.active { background: #4A90D9; color: #fff; border-color: #4A90D9; }

/* ─── 空状态 ─── */
.empty { display: flex; flex-direction: column; align-items: center; padding-top: 80rpx; }
.empty-illustration { width: 200rpx; height: 200rpx; margin-bottom: 32rpx; background: #fff3e0; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 32rpx rgba(255,179,71,0.2); }
.empty-emoji { font-size: 96rpx; }
.empty-text { font-size: 32rpx; color: #333; font-weight: 700; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: #999; margin-bottom: 48rpx; text-align: center; max-width: 420rpx; line-height: 1.6; }
.empty-cta { background: linear-gradient(135deg, #4A90D9, #6BA3E0); color: #fff; font-size: 28rpx; font-weight: 600; border-radius: 48rpx; padding: 24rpx 60rpx; box-shadow: 0 8rpx 30rpx rgba(74,144,217,0.35); }

/* ─── 记录列表 ─── */
.record-list { display: flex; flex-direction: column; gap: 20rpx; }
.record-card { display: flex; align-items: center; gap: 20rpx; background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.record-icon { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; flex-shrink: 0; }
.record-icon.bath { background: #e3f2fd; }
.record-icon.deworm { background: #f3e5f5; }
.record-icon.vaccine { background: #fff3e0; }
.record-icon.checkup { background: #e8f5e9; }
.record-center { flex: 1; }
.record-type { font-size: 30rpx; color: #333; font-weight: 600; display: block; margin-bottom: 6rpx; }
.record-date { font-size: 24rpx; color: #999; display: block; }
.record-note { font-size: 24rpx; color: #666; display: block; margin-top: 6rpx; }
.record-right { display: flex; flex-direction: column; gap: 12rpx; align-items: center; padding: 4rpx 8rpx; }
.edit-record { font-size: 24rpx; color: #4A90D9; padding: 6rpx 16rpx; border-radius: 20rpx; background: #e8f0ff; }
.delete-record { font-size: 24rpx; color: #ff4d4f; padding: 6rpx 16rpx; border-radius: 20rpx; background: #fff1f0; }

/* ─── 编辑弹窗 ─── */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center;
  z-index: 999;
}
.modal-dialog {
  width: 620rpx; background: #fff; border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
}
.modal-title { font-size: 34rpx; font-weight: 700; color: #1a1a1a; display: block; text-align: center; margin-bottom: 32rpx; }
.edit-field { margin-bottom: 24rpx; display: flex; align-items: center; gap: 20rpx; }
.edit-label { font-size: 28rpx; color: #666; width: 80rpx; flex-shrink: 0; }
.edit-value {
  flex: 1; font-size: 28rpx; color: #333;
  background: #f5f6fa; padding: 18rpx 24rpx; border-radius: 12rpx;
}
.edit-input {
  flex: 1; font-size: 28rpx; color: #333;
  background: #f5f6fa; padding: 18rpx 24rpx; border-radius: 12rpx;
}
.modal-btns { display: flex; justify-content: center; gap: 24rpx; margin-top: 16rpx; }
.modal-btn { font-size: 28rpx; padding: 18rpx 48rpx; border-radius: 40rpx; text-align: center; }
.modal-btn.cancel { color: #999; background: #f0f0f0; }
.modal-btn.confirm { color: #fff; background: #4A90D9; }
.btn-hover { opacity: 0.7; }
