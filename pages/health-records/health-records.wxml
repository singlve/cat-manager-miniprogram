<!-- pages/health-records/health-records.wxml -->
<view class="container {{themeClass}}">
  <include src="../../templates/offline-tip.wxml" />

  <view class="ui-compact-hero health-hero">
    <image class="ui-compact-hero-img" src="/assets/illustrations/pet-profile-clean.png" mode="aspectFit" />
    <view class="ui-compact-hero-body">
      <text class="ui-compact-kicker">HEALTH LOG</text>
      <text class="ui-compact-title">健康成长档案</text>
      <text class="ui-compact-desc">集中查看洗护、驱虫、免疫和体检记录。</text>
    </view>
  </view>

  <view class="health-filter-panel">
    <!-- 宠物筛选标签 -->
    <view class="filter-block">
      <text class="filter-label">查看宠物</text>
      <scroll-view class="cat-tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="cat-tabs">
          <view
            wx:for="{{catOptions}}"
            wx:key="key"
            class="cat-tab {{currentCat === item.key ? 'active' : ''}}"
            bindtap="setCatFilter"
            data-cat="{{item.key}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 类型筛选标签 -->
    <view class="filter-block type-filter-block">
      <text class="filter-label">记录类型</text>
      <view class="filter-tabs">
        <view
          wx:for="{{filterOptions}}"
          wx:key="key"
          class="type-tab {{currentFilter === item.key ? 'active' : ''}}"
          bindtap="setFilter"
          data-filter="{{item.key}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="filter-block date-filter-block">
      <text class="filter-label">时间范围</text>
      <view class="date-filter-tabs">
        <view
          wx:for="{{dateFilterOptions}}"
          wx:key="key"
          class="date-filter-tab {{dateFilter === item.key ? 'active' : ''}}"
          bindtap="setDateFilter"
          data-range="{{item.key}}"
        >{{item.label}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loadError && loadedRecordCount === 0}}" class="load-error-state">
    <image class="load-error-icon ui-icon-lg" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
    <text class="load-error-title">健康记录加载失败</text>
    <text class="load-error-desc">请检查网络连接后重新加载</text>
    <button class="load-retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{filteredRecords.length === 0}}" class="empty">
    <image class="ui-empty-img" src="/assets/illustrations/pet-profile-clean.png" mode="aspectFill" />
    <text class="empty-text">暂无健康记录</text>
    <text class="empty-hint">在宠物详情页点击快速记录按钮为宠物添加第一条记录</text>
    <view class="empty-cta" hover-class="btn-hover" bindtap="goBack">去添加记录 ›</view>
  </view>

  <!-- 记录列表 -->
  <view wx:else class="record-list">
    <view wx:for="{{filteredRecords}}" wx:key="_id" class="record-card">
      <view class="record-left">
        <view class="record-icon {{item.type}}">
          <image class="ui-icon-sm theme-business-icon" src="{{item.type === 'bath' ? '/assets/icons/ui/bath.png' : item.type === 'deworm' ? '/assets/icons/ui/deworm.png' : item.type === 'vaccine' ? '/assets/icons/ui/vaccine.png' : '/assets/icons/ui/checkup.png'}}" mode="aspectFit" />
        </view>
      </view>
      <view class="record-center">
        <!-- 筛选全部宠物时显示宠物名 -->
        <view wx:if="{{currentCat === 'all'}}" class="record-cat-name">
          <image wx:if="{{item._catAvatar}}" class="cat-avatar-sm" src="{{item._catAvatar}}" mode="aspectFill" lazy-load></image>
          <image wx:else class="cat-avatar-placeholder ui-icon-sm" src="/assets/icons/ui/cat.png" mode="aspectFit" />
          <text>{{item._catName}}</text>
        </view>
        <text class="record-type">{{item.type === 'bath' ? '洗澡' : item.type === 'deworm' ? '驱虫' : item.type === 'vaccine' ? '免疫' : '体检'}}</text>
        <text class="record-date">{{item.date}}</text>
        <text class="record-note" wx:if="{{item.note}}">{{item.note}}</text>
      </view>
      <view class="record-right">
        <view class="edit-record" data-id="{{item._id}}" bindtap="openEdit">编辑</view>
        <view class="delete-record" data-id="{{item._id}}" bindtap="deleteRecord">删除</view>
      </view>
    </view>
  </view>

  <!-- 底部分页状态 -->
  <view wx:if="{{loadedRecordCount > 0}}" class="list-footer">
    <text wx:if="{{recordsLoading}}" class="list-footer-text">加载中...</text>
    <text wx:elif="{{!hasMoreRecords}}" class="list-footer-text">— 没有更多了 —</text>
  </view>

  <!-- 编辑弹窗 -->
  <view wx:if="{{showEditModal}}" class="modal-mask">
    <view class="modal-dialog" catchtap="">
      <text class="modal-kicker">HEALTH RECORD</text>
      <text class="modal-title">编辑健康记录</text>
      <text class="modal-subtitle">调整记录类型、日期或备注信息</text>

      <!-- 类型选择 -->
      <view class="edit-field stacked">
        <text class="edit-label">类型</text>
        <view class="edit-type-grid">
          <view class="edit-type-item {{editType === 'bath' ? 'active' : ''}}" bindtap="selectEditType" data-type="bath">
            <image class="ui-icon-sm theme-business-icon" src="/assets/icons/ui/bath.png" mode="aspectFit" />
            <text>洗澡</text>
          </view>
          <view class="edit-type-item {{editType === 'deworm' ? 'active' : ''}}" bindtap="selectEditType" data-type="deworm">
            <image class="ui-icon-sm theme-business-icon" src="/assets/icons/ui/deworm.png" mode="aspectFit" />
            <text>驱虫</text>
          </view>
          <view class="edit-type-item {{editType === 'vaccine' ? 'active' : ''}}" bindtap="selectEditType" data-type="vaccine">
            <image class="ui-icon-sm theme-business-icon" src="/assets/icons/ui/vaccine.png" mode="aspectFit" />
            <text>免疫</text>
          </view>
          <view class="edit-type-item {{editType === 'checkup' ? 'active' : ''}}" bindtap="selectEditType" data-type="checkup">
            <image class="ui-icon-sm theme-business-icon" src="/assets/icons/ui/checkup.png" mode="aspectFit" />
            <text>体检</text>
          </view>
        </view>
      </view>

      <!-- 日期选择 -->
      <view class="edit-field stacked">
        <text class="edit-label">日期</text>
        <picker mode="date" value="{{editDate}}" bindchange="onEditDateChange">
          <view class="edit-value">
            <text>{{editDate}}</text>
            <text class="edit-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 备注 -->
      <view class="edit-field stacked">
        <text class="edit-label">备注</text>
        <input class="edit-input" value="{{editNote}}" bindinput="onEditNoteInput" placeholder="选填" placeholder-style="color:#ccc;" />
      </view>

      <view class="modal-btns">
        <view class="modal-btn cancel" hover-class="btn-hover" bindtap="cancelEdit">取消</view>
        <view class="modal-btn confirm {{editSaving ? 'disabled' : ''}}" hover-class="btn-hover" bindtap="saveEdit">{{editSaving ? '保存中...' : '保存'}}</view>
      </view>
    </view>
  </view>

</view>
