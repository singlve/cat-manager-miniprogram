page { background: #f5f6fa; }

/* ── search ── */
.search-bar {
  display: flex; align-items: center; gap: 12rpx;
  padding: 20rpx 24rpx; background: #fff;
}

.search-type {
  flex-shrink: 0;
  padding: 14rpx 16rpx;
  background: #f0f2f7; border-radius: 8rpx;
  font-size: 26rpx; color: #333;
}

.search-input {
  flex: 1;
  height: 72rpx; padding: 0 16rpx;
  background: #f0f2f7; border-radius: 8rpx;
  font-size: 28rpx;
}

.search-btn {
  flex-shrink: 0;
  width: 120rpx; height: 72rpx; line-height: 72rpx;
  text-align: center;
  background: #4A90D9; color: #fff;
  border-radius: 8rpx; font-size: 28rpx;
  padding: 0; margin: 0;
}
.search-btn::after { border: none; }
.search-btn[disabled] { opacity: .5; }

/* ── user card ── */
.user-list { padding: 16rpx 24rpx; }

.user-card {
  background: #fff; border-radius: 12rpx; padding: 24rpx;
  margin-bottom: 16rpx;
}

.user-card-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx;
}
.user-nickname { font-size: 32rpx; font-weight: 600; color: #222; }
.user-phone  { font-size: 24rpx; color: #999; }

.user-stats {
  display: flex; gap: 24rpx;
  flex-wrap: wrap;
}
.stat-item {
  display: flex; flex-direction: column; align-items: center;
  min-width: 100rpx;
}
.stat-val  { font-size: 28rpx; font-weight: 600; color: #4A90D9; }
.stat-label { font-size: 22rpx; color: #aaa; }

/* ── empty / error ── */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 0;
}
.empty-icon   { font-size: 80rpx; }
.empty-text   { font-size: 28rpx; color: #999; margin-top: 16rpx; }
.empty-sub    { font-size: 24rpx; color: #bbb; margin-top: 8rpx; }

/* ── edit sheet ── */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.5); z-index: 1000;
}
.sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom);
}
.sheet-bar {
  width: 60rpx; height: 6rpx;
  background: #ddd; border-radius: 3rpx;
  margin: 16rpx auto;
}
.sheet-title {
  display: block; text-align: center;
  font-size: 32rpx; font-weight: 600;
  padding: 8rpx 0 24rpx;
}

.field-group {
  padding: 0 32rpx 20rpx;
}
.field-label {
  font-size: 26rpx; color: #666;
  margin-bottom: 8rpx; display: block;
}
.field-input {
  width: 100%; height: 72rpx;
  padding: 0 16rpx;
  background: #f5f6fa; border-radius: 8rpx;
  font-size: 28rpx; box-sizing: border-box;
}
.field-textarea {
  width: 100%; min-height: 80rpx;
  padding: 12rpx 16rpx;
  background: #f5f6fa; border-radius: 8rpx;
  font-size: 26rpx; box-sizing: border-box;
}

.sheet-btns {
  display: flex; gap: 20rpx;
  padding: 20rpx 32rpx 40rpx;
}
.sheet-btns .cancel,
.sheet-btns .confirm {
  flex: 1; height: 80rpx; line-height: 80rpx;
  text-align: center; border-radius: 12rpx;
  font-size: 30rpx;
  padding: 0; margin: 0;
}
.sheet-btns .cancel  { background: #f0f2f7; color: #666; }
.sheet-btns .confirm { background: #4A90D9; color: #fff; }
.sheet-btns .confirm.disabled { opacity: .4; }
.sheet-btns .cancel::after,
.sheet-btns .confirm::after { border: none; }
