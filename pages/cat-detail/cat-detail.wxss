/* pages/cat-detail/cat-detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx 24rpx 40rpx;
}

/* ─── 头部卡片 ─── */
.cat-header {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
  display: flex;
  gap: 28rpx;
  position: relative;
}

.avatar-wrap { flex-shrink: 0; }

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 5rpx solid #e8f0ff;
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f0f4ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emoji { font-size: 64rpx; }

.cat-meta { flex: 1; }

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.cat-name { font-size: 40rpx; font-weight: 800; color: #1a1a1a; }

.gender-tag {
  font-size: 22rpx;
  background: #e8f0ff;
  color: #4A90D9;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.breed { font-size: 26rpx; color: #666; display: block; margin-bottom: 10rpx; }

.info-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 8rpx; }

.tag {
  font-size: 22rpx;
  background: #f5f6fa;
  color: #666;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.tag-neutered {
  background: #f0f9eb;
  color: #52c41a;
}

.tag-passed {
  background: #fff0f6;
  color: #eb2f96;
}

.tag-withme {
  background: #e6f7ff;
  color: #1890ff;
}

.note { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }

.header-actions {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  display: flex;
  gap: 8rpx;
}

.action-btn { font-size: 24rpx; color: #4A90D9; padding: 6rpx 12rpx; }
.action-btn.delete { color: #ff4d4f; }

/* ─── 通用卡片区块 ─── */
.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title { font-size: 32rpx; font-weight: 700; color: #1a1a1a; }
.view-more { font-size: 26rpx; color: #4A90D9; }

/* ─── 快速记录按钮 ─── */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 20rpx;
  background: #f8f9fc;
  transition: transform 0.15s;
}

.quick-btn:active { transform: scale(0.95); }
.quick-icon { font-size: 48rpx; margin-bottom: 10rpx; }
.quick-label { font-size: 24rpx; color: #666; }
.quick-btn.bath { background: #e3f2fd; }
.quick-btn.deworm { background: #f3e5f5; }
.quick-btn.vaccine { background: #fff3e0; }
.quick-btn.checkup { background: #e8f5e9; }
.quick-hint { font-size: 22rpx; color: #bbb; text-align: center; margin-top: 16rpx; display: block; }

/* ─── 空状态 ─── */
.empty-records {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
}

.empty-main { font-size: 28rpx; color: #999; margin-bottom: 8rpx; }
.empty-sub { font-size: 24rpx; color: #bbb; }

/* ─── 健康时间轴 ─── */
.timeline { display: flex; flex-direction: column; }

.timeline-item {
  display: flex;
  gap: 20rpx;
  min-height: 120rpx;
}

/* 左侧：节点 + 竖线 */
.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 64rpx;
  flex-shrink: 0;
  position: relative;
}

/* 竖线：撑满剩余高度，连接相邻节点 */
.timeline-line {
  position: absolute;
  top: 40rpx;
  bottom: -40rpx;
  width: 3rpx;
  background: #e8eaf0;
}

/* 节点圆点 */
.timeline-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.dot-icon { font-size: 30rpx; }

/* 节点颜色按类型 */
.dot-bath { background: #e3f2fd; }
.dot-deworm { background: #f3e5f5; }
.dot-vaccine { background: #fff3e0; }
.dot-checkup { background: #e8f5e9; }

/* 右侧：记录内容 */
.timeline-content {
  flex: 1;
  padding-bottom: 36rpx;
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding-top: 12rpx;
}

.timeline-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.record-type-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.record-ago {
  font-size: 22rpx;
  color: #aaa;
  background: #f5f6fa;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.record-date-full {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 4rpx;
}

.record-note {
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
  background: #f8f9fc;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  display: inline-block;
}

/* ─── 日期选择弹窗 ─── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-dialog {
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
}

.modal-type-hint {
  font-size: 30rpx;
  color: #4A90D9;
  margin-bottom: 32rpx;
}

.date-picker-trigger {
  font-size: 32rpx;
  color: #333;
  background: #f5f6fa;
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  margin-bottom: 36rpx;
  display: inline-block;
}

.modal-btns {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.modal-btn {
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
  text-align: center;
}

.modal-btn.cancel {
  color: #999;
  background: #f0f0f0;
}

.modal-btn.confirm {
  color: #fff;
  background: #4A90D9;
}

.btn-hover {
  opacity: 0.7;
}

/* ─── 体重记录区 ─── */
.weight-summary-card {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.weight-current {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.weight-number {
  font-size: 64rpx;
  font-weight: 900;
  color: #2e7d32;
  line-height: 1;
}
.weight-unit {
  font-size: 28rpx;
  color: #388e3c;
  font-weight: 600;
}

.weight-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.weight-label { font-size: 22rpx; color: #388e3c; font-weight: 600; }
.weight-date  { font-size: 24rpx; color: #558b2f; }

.weight-total {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}
.weight-total-num  { font-size: 40rpx; font-weight: 800; color: #33691e; }
.weight-total-label { font-size: 20rpx; color: #558b2f; }

.quick-add-weight {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fff;
  border: 2rpx dashed #a5d6a7;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #43a047;
  font-size: 28rpx;
  font-weight: 600;
}
.quick-add-icon  { font-size: 36rpx; }
.quick-add-text {}

/* ─── 体重录入弹窗 ─── */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.weight-modal {
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}

.modal-title-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  display: block;
  margin-bottom: 36rpx;
  text-align: center;
}

.wm-field { margin-bottom: 28rpx; }
.wm-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}
.wm-picker {
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}
.wm-input {
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 700;
}

.wm-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.wm-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
}
.wm-btn.cancel {
  background: #f5f6fa;
  color: #666;
}
.wm-btn.confirm {
  background: linear-gradient(135deg, #43a047, #66bb6a);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(67,160,71,0.35);
}


/* ─── 分享卡预览 ─── */
.card-preview-wrap {
  position: fixed; inset: 0; z-index: 9999;
  background: rgba(0,0,0,.55);
  overflow-y: auto;
}
.card-preview {
  margin: 60rpx 32rpx 80rpx;
  background: #fff; border-radius: 24rpx;
  padding: 0 0 32rpx; overflow: hidden;
}
.card-top {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  padding: 40rpx 0 30rpx;
  display: flex; flex-direction: column; align-items: center;
}
.card-title {
  font-size: 32rpx; font-weight: 700; color: rgba(255,255,255,.85);
}
.card-avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: rgba(255,255,255,.95);
  display: flex; align-items: center; justify-content: center;
  margin-top: 24rpx; overflow: hidden;
}
.card-avatar-img {
  width: 100%; height: 100%; border-radius: 50%;
}
.card-avatar-text {
  font-size: 44rpx; font-weight: 700; color: #4A90D9;
}
.card-name {
  display: block; text-align: center;
  font-size: 36rpx; font-weight: 700; color: #222;
  margin-top: 24rpx;
}
.card-breed {
  display: block; text-align: center;
  font-size: 26rpx; color: #888; margin-top: 8rpx;
}
.card-divider {
  height: 1rpx; background: #f0f0f0;
  margin: 24rpx 32rpx;
}
.card-info {
  display: flex; flex-wrap: wrap;
  padding: 0 32rpx;
}
.card-info-item {
  width: 50%; padding: 12rpx 0;
}
.card-info-label {
  font-size: 24rpx; color: #999;
}
.card-info-val {
  display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-top: 4rpx;
}
.card-records {
  padding: 16rpx 32rpx 0;
}
.card-section-title {
  font-size: 26rpx; font-weight: 600; color: #4A90D9;
  display: block; margin-bottom: 12rpx;
}
.card-record {
  display: flex; justify-content: space-between;
  padding: 8rpx 0; font-size: 26rpx; color: #555;
}
.card-record-type { color: #888; }
.card-footer {
  display: block; text-align: center;
  font-size: 22rpx; color: #bbb;
  margin: 32rpx 0 16rpx;
}
.card-btns {
  display: flex; gap: 20rpx; padding: 0 32rpx;
}
.cb-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  text-align: center; border-radius: 12rpx;
  font-size: 28rpx; background: #f0f2f7; color: #333;
  padding: 0; margin: 0;
}
.cb-btn.primary { background: #4A90D9; color: #fff; }
.cb-btn::after { border: none; }
.card-close {
  display: block; text-align: center;
  font-size: 26rpx; color: #4A90D9;
  margin-top: 24rpx;
}
.share-actions { display: flex; gap: 20rpx; padding: 16rpx 0 40rpx; justify-content: center; }
.sa-btn { width: 240rpx; height: 80rpx; line-height: 80rpx; text-align: center; border-radius: 50rpx; font-size: 28rpx; background: rgba(255,255,255,.9); color: #333; padding: 0; margin: 0; }
.sa-btn.primary { background: #4A90D9; color: #fff; }
.sa-btn::after { border: none; }
.card-img { width: 100%; display: block; }
.card-canvas { position: absolute; top: 0; left: 0; width: 1px; height: 1px; opacity: 0; }
