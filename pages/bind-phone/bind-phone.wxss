/* pages/bind-phone/bind-phone.wxss */
page { background: #F7F9FB; }
.page {
  min-height: 100vh;
  padding: 72rpx 36rpx 48rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #EAF7F5 0%, rgba(247,249,251,0) 360rpx),
    #F7F9FB;
}

.card {
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(91, 167, 216, 0.10);
  border-radius: 28rpx;
  padding: 46rpx 40rpx 40rpx;
  box-shadow: 0 14rpx 40rpx rgba(68, 92, 120, 0.10);
}

.bind-hero-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 38rpx;
  margin: 0 auto 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #EAF4FB, #EAF7F5);
  box-shadow: 0 14rpx 34rpx rgba(91, 167, 216, 0.18);
}

.bind-hero-img {
  width: 82rpx;
  height: 82rpx;
}

.card-title {
  font-size: 40rpx; font-weight: 900; color: #243044;
  text-align: center; margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx; color: #6E7A8A;
  text-align: center; margin-bottom: 48rpx;
  font-weight: 600;
}

.input-row {
  background: #F5F9FC;
  border: 1rpx solid #E8EEF4;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  display: flex; align-items: center;
}

.btn-confirm {
  width: 100%;
  background: linear-gradient(135deg, #5BA7D8, #6BC6B3); color: #fff;
  font-size: 30rpx; font-weight: 800;
  border-radius: 50rpx; padding: 26rpx 0;
  text-align: center; margin-top: 32rpx;
  box-shadow: 0 12rpx 30rpx rgba(91, 167, 216, 0.24);
}
.btn-confirm:active { opacity: 0.8; }

.btn-skip {
  text-align: center; margin-top: 24rpx;
  font-size: 26rpx; color: #999;
}
.btn-skip:active { opacity: 0.6; }
