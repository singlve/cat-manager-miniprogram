/* pages/bind-phone/bind-phone.wxss */
page { background: #f0f2f7; }
.page { padding: 48rpx 36rpx; }

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 40rpx; font-weight: 700; color: #1a1a1a;
  text-align: center; margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx; color: #999;
  text-align: center; margin-bottom: 48rpx;
}

.input-row {
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  display: flex; align-items: center;
}

.btn-confirm {
  width: 100%;
  background: #4A90D9; color: #fff;
  font-size: 30rpx; font-weight: 600;
  border-radius: 50rpx; padding: 26rpx 0;
  text-align: center; margin-top: 32rpx;
}
.btn-confirm:active { opacity: 0.8; }

.btn-skip {
  text-align: center; margin-top: 24rpx;
  font-size: 26rpx; color: #999;
}
.btn-skip:active { opacity: 0.6; }
