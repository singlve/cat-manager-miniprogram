<!-- pages/register/register.wxml -->
<view class="register-page">
  <view class="header">
    <image class="ui-empty-img" src="/assets/illustrations/profile-mascot-transparent.png" mode="aspectFill" />
    <text class="title">注册账号</text>
    <text class="subtitle">成为宠物小管家Plus的一员</text>
  </view>

  <view class="form">
    <view class="input-group">
      <image class="input-icon ui-icon-sm" src="/assets/icons/ui/user.png" mode="aspectFit" />
      <input class="input" placeholder="请输入昵称" bindinput="nicknameInput" maxlength="20" />
    </view>

    <view class="input-group">
      <image class="input-icon ui-icon-sm" src="/assets/icons/ui/phone.png" mode="aspectFit" />
      <input class="input" type="number" placeholder="请输入手机号" bindinput="phoneInput" maxlength="11" />
    </view>

    <view class="input-group">
      <image class="input-icon ui-icon-sm" src="/assets/icons/ui/admin.png" mode="aspectFit" />
      <input class="input" type="password" placeholder="请输入密码" bindinput="passwordInput" />
    </view>

    <view class="input-group">
      <image class="input-icon ui-icon-sm" src="/assets/icons/ui/done.png" mode="aspectFit" />
      <input class="input" type="password" placeholder="请确认密码" bindinput="confirmInput" />
    </view>

    <button class="register-btn" bindtap="register">立即注册</button>

    <view class="login-link">
      <text>已有账号？</text>
      <text class="link" bindtap="goLogin">去登录</text>
    </view>
  </view>
</view>
