/* pages/expense/expense.wxss */
page { background: #F7F9FB; }

/* ═══════════════ 顶部导航 ═══════════════ */
.nav-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 28rpx rgba(36, 48, 68, .05);
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-year-row { display: flex; align-items: center; gap: 8rpx; }
.nav-arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #EAF4FB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.nav-arrow.disabled {
  background: #F2F5F8;
  opacity: .65;
}
.nav-arrow.disabled .arrow-mark { border-color: #A5AFBC; }
.nav-year-text { font-size: 30rpx; font-weight: 700; color: #243044; min-width: 100rpx; text-align: center; }

.arrow-mark {
  width: 16rpx;
  height: 16rpx;
  border-top: 5rpx solid #5BA7D8;
  border-right: 5rpx solid #5BA7D8;
  box-sizing: border-box;
}
.arrow-left { transform: rotate(-135deg); margin-left: 6rpx; }
.arrow-right { transform: rotate(45deg); margin-right: 6rpx; }

/* 视图切换 */
.view-toggle {
  display: flex;
  background: #EEF4F8;
  border-radius: 24rpx;
  padding: 4rpx;
}
.tog-btn {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  color: #6E7A8A;
  border-radius: 22rpx;
  transition: all .2s;
}
.tog-btn.active {
  background-color: #5BA7D8;
  background-image: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(91, 167, 216, .24);
}

/* ═══════════════ 筛选 ═══════════════ */
.filter-row {
  margin: 16rpx 24rpx 0;
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}
.filter-pick {
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,.92) !important;
  border: 1rpx solid rgba(91, 167, 216, .18) !important;
  border-radius: 24rpx !important;
  padding: 0 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(45, 83, 115, .08) !important;
  box-sizing: border-box;
}
.filter-current {
  font-size: 28rpx;
  color: #243044;
  font-weight: 700;
}
.filter-arrow-mark {
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid #5BA7D8;
  border-bottom: 4rpx solid #5BA7D8;
  transform: rotate(45deg);
  margin-left: 16rpx;
  box-sizing: border-box;
}

/* ═══════════════ 月度卡片 ═══════════════ */
.month-card {
  background-color: #5BA7D8;
  background-image: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  margin: 16rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx 28rpx 20rpx;
  box-shadow: 0 16rpx 34rpx rgba(91, 167, 216, .22);
}
.page .month-card {
  background-color: #5BA7D8 !important;
  background-image: linear-gradient(135deg, #5BA7D8, #6BC6B3) !important;
  border: none !important;
  box-shadow: 0 16rpx 34rpx rgba(91, 167, 216, .22) !important;
}
.mc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.mc-arrow {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,.16);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  flex-shrink: 0;
  border: 1rpx solid rgba(255,255,255,.26);
}
.mc-arrow .arrow-mark {
  width: 18rpx;
  height: 18rpx;
  border-top-color: #fff;
  border-right-color: #fff;
  border-top-width: 5rpx;
  border-right-width: 5rpx;
}
.mc-arrow:active { opacity: .72; }
.mc-label { font-size: 28rpx; color: rgba(255,255,255,0.9); font-weight: 600; text-align: center; flex: 1; }
.mc-total {
  display: block; text-align: center;
  font-size: 58rpx; color: #fff; font-weight: 800;
  margin-top: 16rpx;
}
.page .month-card .mc-label,
.page .month-card .mc-total {
  color: #fff !important;
}
.mc-breakdown { margin-top: 16rpx; display: flex; flex-wrap: wrap; gap: 10rpx; justify-content: center; }
.mc-cat {
  font-size: 22rpx; color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.15); border-radius: 16rpx;
  padding: 4rpx 16rpx;
}

/* ═══════════════ 加载 & 空状态 ═══════════════ */
.loading-box { text-align: center; padding: 120rpx 0; color: #A5AFBC; font-size: 28rpx; }
.empty-tip {
  text-align: center; padding: 100rpx 0;
  display: flex; flex-direction: column; align-items: center;
}
.empty-icon-img { width: 96rpx; height: 96rpx; }
.empty-text { font-size: 30rpx; color: #6E7A8A; margin-top: 20rpx; }
.empty-hint { font-size: 24rpx; color: #A5AFBC; margin-top: 8rpx; }

/* ═══════════════ 记录列表 ═══════════════ */
.expense-list { padding: 20rpx 24rpx 140rpx; }
.date-group { margin-bottom: 12rpx; }
.date-label {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 8rpx 8rpx;
}
.date-text { font-size: 26rpx; color: #888; font-weight: 600; }
.date-sum { font-size: 24rpx; color: #aaa; }

.expense-item {
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx;
  margin-bottom: 8rpx; box-shadow: 0 8rpx 22rpx rgba(36, 48, 68, .05);
}
.exp-left { display: flex; align-items: center; min-width: 0; }
.exp-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 16rpx;
  background: #EAF4FB; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.exp-icon-img { width: 40rpx; height: 40rpx; }
.exp-info { margin-left: 16rpx; min-width: 0; }
.exp-cat { font-size: 28rpx; color: #243044; font-weight: 600; display: block; }
.exp-note { font-size: 24rpx; color: #6E7A8A; display: block; margin-top: 2rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 340rpx; }
.exp-pet-name { font-size: 22rpx; color: #5BA7D8; display: block; margin-top: 2rpx; }
.exp-amount { font-size: 32rpx; color: #FF6B6B; font-weight: 700; flex-shrink: 0; }

.hint-box { text-align: center; padding: 8rpx 24rpx 20rpx; }
.hint-box text { font-size: 22rpx; color: #ccc; }

/* ═══════════════ 年度：汇总卡片 ═══════════════ */
.year-summary-card {
  background-color: #5BA7D8;
  background-image: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  margin: 16rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 16rpx 34rpx rgba(91, 167, 216, .22);
}
.page .year-summary-card {
  background-color: #5BA7D8 !important;
  background-image: linear-gradient(135deg, #5BA7D8, #6BC6B3) !important;
  border: none !important;
  box-shadow: 0 16rpx 34rpx rgba(91, 167, 216, .22) !important;
}
.ys-label { display: block; font-size: 26rpx; color: rgba(255,255,255,0.75); }
.ys-total { display: block; font-size: 56rpx; color: #fff; font-weight: 800; margin: 12rpx 0 24rpx; }
.ys-row { display: flex; align-items: center; justify-content: space-around; }
.ys-cell { display: flex; flex-direction: column; align-items: center; flex: 1; }
.ysc-val { font-size: 28rpx; color: #fff; font-weight: 700; }
.ysc-lbl { font-size: 22rpx; color: rgba(255,255,255,0.65); margin-top: 4rpx; }
.ys-divider { width: 1rpx; height: 48rpx; background: rgba(255,255,255,0.2); }
.page .year-summary-card .ys-label,
.page .year-summary-card .ys-total,
.page .year-summary-card .ysc-val,
.page .year-summary-card .ysc-lbl {
  color: #fff !important;
}

/* ═══════════════ 年度：卡片容器 ═══════════════ */
.chart-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(36, 48, 68, .05);
}
.chart-title {
  font-size: 28rpx; font-weight: 700; color: #243044;
  margin-bottom: 20rpx; display: block;
}

/* ── 月度柱状图 ── */
.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 280rpx;
  padding: 0 4rpx;
}
.bar-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}
.bar-val {
  font-size: 18rpx; color: #aaa;
  margin-bottom: 6rpx;
  white-space: nowrap;
  transform: scale(0.85);
  transform-origin: center;
}
.bar {
  width: 28rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #c5d5f0;
  min-height: 0;
  transition: height .3s;
}
.bar-max { background: linear-gradient(180deg, #FFB86B, #F6A04F); }
.bar-zero { height: 4rpx; background: #e8e8e8; border-radius: 2rpx; }
.bar-label {
  font-size: 20rpx; color: #999;
  margin-top: 8rpx;
}

/* ── 分类占比 ── */
.cat-rows { display: flex; flex-direction: column; gap: 16rpx; }
.cat-row { display: flex; flex-direction: column; gap: 6rpx; }
.cr-left {
  display: flex; align-items: center;
  font-size: 24rpx;
}
.cr-icon-img { width: 34rpx; height: 34rpx; margin-right: 8rpx; flex-shrink: 0; }
.cr-name { color: #555; font-weight: 500; flex: 1; }
.cr-pct { color: #aaa; font-size: 22rpx; }
.cr-track {
  height: 10rpx;
  background: #E8EEF4;
  border-radius: 5rpx;
  overflow: hidden;
}
.cr-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width .4s;
}
.cr-amt { font-size: 22rpx; color: #888; }

/* ── 猫咪排行 ── */
.rank-list { display: flex; flex-direction: column; gap: 14rpx; }
.rank-item { display: flex; align-items: center; gap: 12rpx; }
.rk-idx {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #e8e8e8;
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  color: #888;
  flex-shrink: 0;
}
.rk-gold { background: linear-gradient(135deg, #FFD700, #FFA500); color: #fff; }
.rk-silver { background: linear-gradient(135deg, #C0C0C0, #A0A0A0); color: #fff; }
.rk-bronze { background: linear-gradient(135deg, #CD7F32, #B8860B); color: #fff; }
.rk-name { font-size: 26rpx; color: #444; width: 140rpx; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.rk-bar-wrap { flex: 1; height: 10rpx; background: #E8EEF4; border-radius: 5rpx; overflow: hidden; }
.rk-bar { height: 100%; border-radius: 5rpx; transition: width .4s; }
.rk-amt { font-size: 24rpx; color: #888; font-weight: 600; flex-shrink: 0; }

/* ═══════════════ FAB ═══════════════ */
/* ── 添加按钮（与 cat-list 统一风格）── */
.add-section {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  bottom: calc(40rpx + constant(safe-area-inset-bottom));
  left: 0; right: 0;
  display: flex; justify-content: center;
  padding: 0 40rpx; z-index: 50;
}
.add-btn {
  width: 100%;
  background-color: #5BA7D8;
  background-image: linear-gradient(135deg, #5BA7D8, #6BC6B3);
  color: #fff; font-size: 34rpx; font-weight: 700;
  border-radius: 50rpx; padding: 28rpx 0;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(74, 144, 217, 0.45);
}
.add-btn::after { border: none; }

/* ═══════════════ 弹窗 ═══════════════ */
.cat-filter-modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 180;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  background: rgba(36, 48, 68, .34);
  box-sizing: border-box;
}
.cat-filter-modal {
  width: 100%;
  max-height: 70vh;
  padding: 34rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(255,255,255,.88) 0, rgba(255,255,255,0) 260rpx),
    linear-gradient(180deg, #EAF4FB 0%, #EAF7F5 100%);
  border: 1rpx solid rgba(255,255,255,.78);
  box-shadow: 0 28rpx 70rpx rgba(36, 48, 68, .22);
  box-sizing: border-box;
  transform: translateY(48rpx);
}
.cat-filter-modal-head {
  margin-bottom: 24rpx;
}
.cat-filter-modal-title {
  display: block;
  color: #243044;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}
.cat-filter-modal-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #6E7A8A;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}
.cat-filter-option-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  max-height: 48vh;
  overflow-y: auto;
}
.cat-filter-option {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,.78);
  border: 1rpx solid rgba(91, 167, 216, .12);
  box-sizing: border-box;
}
.cat-filter-option.active {
  background: #fff !important;
  border-color: rgba(91, 167, 216, .38) !important;
  box-shadow: 0 12rpx 28rpx rgba(45, 83, 115, .12);
}
.cat-filter-option-text {
  color: #243044;
  font-size: 28rpx;
  font-weight: 700;
}
.cat-filter-option.active .cat-filter-option-text {
  color: #2F8DB8 !important;
}
.cat-filter-check {
  color: #5BA7D8;
  font-size: 34rpx;
  font-weight: 900;
}
.mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.45); z-index: 200;
  display: flex; align-items: flex-end; justify-content: center;
}
.sheet {
  width: 100vw; background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 32rpx 44rpx;
}
.sheet-bar {
  width: 60rpx; height: 6rpx; background: #ddd;
  border-radius: 3rpx; margin: 0 auto 28rpx;
}
.sheet-title { display: block; font-size: 32rpx; font-weight: 700; color: #333; text-align: center; }
.sheet-sub { display: block; font-size: 26rpx; color: #888; text-align: center; margin-top: 8rpx; }
.sheet-btns { display: flex; gap: 20rpx; margin-top: 32rpx; }
.s-btn { flex: 1; text-align: center; padding: 22rpx 0; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; }
.s-cancel { background: #f0f0f5; color: #666; }
.s-confirm { background: #FF6B6B; color: #fff; }
