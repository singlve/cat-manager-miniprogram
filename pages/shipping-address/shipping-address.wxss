/* pages/shipping-address/shipping-address.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* ── 地址卡片 ── */
.addr-card {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.default-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: #4CAF50;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 0 16rpx 0 16rpx;
}

.addr-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.addr-phone {
  font-size: 26rpx;
  color: #666;
}

.addr-body {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.addr-actions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 32rpx;
}

.addr-act-btn {
  font-size: 24rpx;
  color: #4A90D9;
  padding: 4rpx 0;
}

.addr-act-btn.danger {
  color: #e74c3c;
}

/* ── 空状态 ── */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  font-size: 28rpx;
  color: #999;
}

/* ── 添加按钮 ── */
.add-btn {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  bottom: calc(32rpx + constant(safe-area-inset-bottom));
  left: 48rpx;
  right: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #4A90D9;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,144,217,0.35);
}

/* ── 弹窗 ── */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
}

.editor-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 20rpx 36rpx 60rpx;
  max-height: 85vh;
  overflow-y: auto;
}

.editor-bar {
  width: 80rpx;
  height: 8rpx;
  background: #ddd;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.editor-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}

/* ── 表单 ── */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.form-input {
  height: 80rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.region-picker.placeholder {
  color: #bbb;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.flex-1 { flex: 1; }

/* ── 弹窗按钮 ── */
.editor-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 36rpx;
}

.e-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.e-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.e-btn.confirm {
  background: #4A90D9;
  color: #fff;
}

.e-btn.confirm.disabled {
  background: #a0c4e8;
  color: #fff;
}