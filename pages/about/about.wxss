/* pages/about/about.wxss */
.page {
  min-height: 100vh;
  background: #f5f6fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 80rpx;
  box-sizing: border-box;
}

.icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(74,144,217,0.3);
}

.icon { font-size: 80rpx; }

.app-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.version {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 48rpx;
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.desc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.desc-body {
  font-size: 28rpx;
  color: #666;
  display: block;
  line-height: 1.8;
}

.features .feature-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  font-size: 28rpx;
  color: #555;
  border-bottom: 1rpx solid #f5f5f5;
}

.feature-item:last-child { border-bottom: none; }

.feature-icon { font-size: 32rpx; margin-right: 16rpx; }

.back-btn {
  width: 100%;
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(74,144,217,0.35);
  margin-top: 20rpx;
}

.back-btn::after { border: none; }
