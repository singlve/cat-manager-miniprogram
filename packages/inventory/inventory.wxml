<!--pages/inventory/inventory.wxml-->
<view class="page {{themeClass}}">
  <include src="../../../templates/offline-tip.wxml" />

  <!-- 顶部说明 -->
  <view class="ui-hero-card inventory-hero">
    <image class="ui-hero-img" src="/assets/illustrations/rewards-hero-pets-transparent.png" mode="aspectFit" />
    <text class="ui-hero-title">我的背包</text>
    <text class="ui-hero-subtitle">查看已兑换的商品、确认发货和追踪物流。</text>
  </view>

  <!-- 筛选 Tab -->
  <view class="filter-bar">
    <view class="tab {{filterTab==='all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab {{filterTab==='physical' ? 'active' : ''}}" bindtap="switchTab" data-tab="physical">实物商品</view>
    <view class="tab {{filterTab==='virtual' ? 'active' : ''}}" bindtap="switchTab" data-tab="virtual">虚拟商品</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="ui-loading-state">
    <view class="ui-loading-mark"></view>
    <text class="ui-loading-text">正在整理背包商品</text>
  </view>
  <view wx:elif="{{loadError}}" class="load-error-state">
    <image class="load-error-icon ui-icon-lg" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
    <text class="load-error-title">背包加载失败</text>
    <text class="load-error-desc">请检查网络后重新加载</text>
    <button class="load-retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{filteredItems.length === 0}}" class="empty-tip">
    <image class="ui-empty-img" src="/assets/illustrations/profile-mascot-transparent.png" mode="aspectFill" />
    <text class="empty-text">{{emptyText}}</text>
    <text class="empty-hint">去商城看看吧</text>
    <view class="empty-btn" bindtap="goMall">去逛逛</view>
  </view>

  <!-- 商品列表 -->
  <view wx:else class="item-list">
    <view class="item-card" wx:for="{{filteredItems}}" wx:key="key">

      <!-- 主行：图片 + 信息 + 数量角标 -->
      <view class="card-main">
        <view wx:if="{{item.virtualType === 'theme'}}" class="item-img theme-inventory-preview preview-{{item.themeKey}}">
          <view class="inventory-preview-top"></view>
          <view class="inventory-preview-card"></view>
          <view class="inventory-preview-button"></view>
        </view>
        <image wx:elif="{{item.image}}" class="item-img" src="{{item.image}}" mode="aspectFill" lazy-load/>
        <view wx:else class="item-img placeholder">
          <image class="ui-icon-lg" src="{{item.itemType === 'virtual' ? '/assets/icons/ui/ticket.png' : '/assets/icons/ui/package.png'}}" mode="aspectFit" />
        </view>

        <view class="item-body">
          <view class="item-name-row">
            <text class="item-name">{{item.name}}</text>
            <view class="item-name-actions">
              <text class="qty-badge">×{{item.totalQty}}</text>
              <text wx:if="{{item.virtualType !== 'theme'}}" class="delete-chip" catchtap="deleteInventoryGroup" data-item="{{item}}">删除</text>
            </view>
          </view>
          <text class="item-points">{{item.virtualType === 'theme' ? '永久主题' : item.points + ' 积分/件'}}</text>

          <!-- 状态标签行（紧凑） -->
          <view class="status-row" wx:if="{{item.inBackpackQty > 0 || item.pendingQty > 0 || item.shippedQty > 0 || item.receivedQty > 0 || item.completedQty > 0}}">
            <text wx:if="{{item.inBackpackQty > 0}}" class="st st-wait">待确认 {{item.inBackpackQty}}</text>
            <text wx:if="{{item.waitingStockQty > 0}}" class="st st-pend">等待补货 {{item.waitingStockQty}}</text>
            <text wx:if="{{item.pendingQty > 0}}" class="st st-pend">待发货 {{item.pendingQty}}</text>
            <text wx:if="{{item.shippedQty > 0}}" class="st st-ship">已发货 {{item.shippedQty}}</text>
            <text wx:if="{{item.receivedQty > 0}}" class="st st-recv">已签收 {{item.receivedQty}}</text>
            <text wx:if="{{item.virtualType === 'theme' && item.completedQty > 0}}" class="st st-theme">主题已解锁</text>
            <text wx:elif="{{item.completedQty > 0}}" class="st st-recv">已到账 {{item.completedQty}}</text>
          </view>
        </view>
      </view>

      <!-- 已发货快递信息（同批次一起兑换的只展示一条快递信息） -->
      <view wx:if="{{item.uniqueTrackings.length > 0}}" class="ship-block">
        <view wx:for="{{item.uniqueTrackings}}" wx:for-item="t" wx:for-index="ti" wx:key="ti" class="ship-row">
          <view class="ship-left">
            <image class="ship-icon ui-icon-sm" src="/assets/icons/ui/delivery.png" mode="aspectFit" />
            <view class="ship-info">
              <text class="ship-carrier">{{t.carrier || '快递'}}<text wx:if="{{t.count > 1}}" class="ship-count">（{{t.count}}件一起发货）</text></text>
              <text class="ship-no">{{t.trackingNo || '暂无单号'}}</text>
            </view>
          </view>
          <view class="ship-right">
            <text class="ship-track" catchtap="queryTracking" data-tracking="{{t.trackingNo}}" data-carrier="{{t.carrier}}">物流</text>
            <text class="ship-copy" catchtap="copyTracking" data-tracking="{{t.trackingNo}}" data-carrier="{{t.carrier}}">复制</text>
          </view>
        </view>
      </view>

      <!-- 待确认操作区 -->
      <view wx:if="{{item.inBackpackItems.length > 0}}" class="action-row">
        <text class="action-hint">{{item.waitingStockQty > 0 ? item.waitingStockQty + '件等待补货，可稍后重试' : item.inBackpackQty + '件待确认，确认后创建发货单'}}</text>
        <view class="action-btns">
          <view class="abtn abtn-main" catchtap="openConfirmModal" data-item="{{item}}">确认兑换</view>
          <view class="abtn abtn-sub" catchtap="cancelAll" data-item="{{item}}">取消</view>
        </view>
      </view>

    </view>
  </view>

  <!-- ── 确认兑换弹窗 ── -->
  <view wx:if="{{showConfirm}}" class="mask" bindtap="closeConfirmModal">
    <view class="sheet" catchtap="stopBubble">
      <view class="sheet-bar"></view>
      <text class="sheet-title">确认兑换</text>
      <text class="sheet-sub">{{confirmTarget.name}}（最多 {{confirmMax}} 件）</text>

      <!-- 数量选择 -->
      <view class="qty-row">
        <view class="qty-btn {{confirmQty <= 1 ? 'disabled' : ''}}" catchtap="qtyMinus">−</view>
        <text class="qty-val">{{confirmQty}}</text>
        <view class="qty-btn {{confirmQty >= confirmMax ? 'disabled' : ''}}" catchtap="qtyPlus">+</view>
      </view>

      <!-- 快捷选择 -->
      <view class="shortcuts">
        <view class="sc {{confirmQty === 1 ? 'active' : ''}}" catchtap="setQty" data-qty="1">1件</view>
        <view wx:if="{{confirmMax >= 2}}" class="sc {{confirmQty === 2 ? 'active' : ''}}" catchtap="setQty" data-qty="2">2件</view>
        <view wx:if="{{confirmMax >= 3}}" class="sc {{confirmQty === 3 ? 'active' : ''}}" catchtap="setQty" data-qty="3">3件</view>
        <view class="sc sc-all {{confirmQty === confirmMax ? 'active' : ''}}" catchtap="setQty" data-qty="{{confirmMax}}">全部</view>
      </view>

      <!-- 收货地址（仅实物） -->
      <view wx:if="{{confirmTarget.itemType === 'physical'}}" class="addr-section">
        <text class="form-label">收货地址</text>
        <view wx:if="{{addresses.length === 0}}" class="addr-empty" catchtap="goShippingAddress">
          <text>请先添加收货地址</text>
          <view class="inline-chevron"></view>
        </view>
        <view wx:else class="addr-list">
          <view
            wx:for="{{addresses}}" wx:for-item="a" wx:key="_id"
            class="addr-opt {{selectedAddressId === a._id ? 'active' : ''}}"
            catchtap="selectAddress" data-id="{{a._id}}"
          >
            <view class="addr-name">{{a.name}} {{a.phone}}</view>
            <view class="addr-detail">{{a.province}} {{a.city}} {{a.district}} {{a.detail}}</view>
          </view>
        </view>
      </view>

      <!-- 按钮 -->
      <view class="sheet-btns">
        <view class="s-btn s-cancel" catchtap="closeConfirmModal">取消</view>
        <view class="s-btn s-confirm {{saving ? 'disabled' : ''}}" catchtap="doConfirm">{{saving ? '提交中...' : '确认兑换'}}</view>
      </view>
    </view>
  </view>

  <!-- ── 物流查询弹窗 ── -->
  <view wx:if="{{showTracking}}" class="mask" bindtap="closeTracking">
    <view class="sheet track-sheet" catchtap="stopBubble">
      <view class="sheet-bar"></view>
      <text class="sheet-title">物流详情</text>

      <view class="track-header">
        <text class="track-carrier">{{currentTrackingCarrier || '快递'}}</text>
        <text class="track-no">{{currentTrackingNo}}</text>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{trackingLoading}}" class="track-loading">
        <text>查询中...</text>
      </view>

      <!-- 查询结果 -->
      <view wx:elif="{{trackingResult}}" class="track-body">
        <!-- 当前状态 -->
        <view class="track-state">
          <text class="track-state-label">当前状态：</text>
          <text class="track-state-value">{{trackingResult.state === '1' ? '已签收' : trackingResult.state === '0' ? '运输中' : trackingResult.state === '4' ? '派件中' : trackingResult.state === '2' ? '疑难件' : trackingResult.state === '3' ? '已退回' : '未知'}}</text>
        </view>

        <!-- 轨迹时间线 -->
        <view wx:if="{{trackingResult.data && trackingResult.data.length > 0}}" class="track-timeline">
          <view wx:for="{{trackingResult.data}}" wx:for-item="step" wx:key="time" class="track-step {{index === 0 ? 'latest' : ''}}">
            <view class="track-step-dot"></view>
            <view class="track-step-line" wx:if="{{index < trackingResult.data.length - 1}}"></view>
            <view class="track-step-body">
              <text class="track-step-context">{{step.context}}</text>
              <text class="track-step-time">{{step.time}}</text>
            </view>
          </view>
        </view>

        <!-- 无轨迹 -->
        <view wx:else class="track-empty">
          <text>暂未查到物流轨迹</text>
          <text class="track-empty-hint">单号可能还未录入系统，请稍后再试</text>
        </view>
      </view>

      <view class="sheet-btns">
        <view class="s-btn s-confirm" catchtap="closeTracking">关闭</view>
      </view>
    </view>
  </view>

</view>
