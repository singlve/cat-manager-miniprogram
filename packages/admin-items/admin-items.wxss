/* pages/admin-items/admin-items.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ════════════════════════════════════════════════════
   搜索栏
   ════════════════════════════════════════════════════ */
.search-bar {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05);
}
.search-type-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f6fa;
  border-radius: 32rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}
.search-type-label {
  font-size: 24rpx;
  color: var(--theme-primary, #5BA7D8);
  font-weight: 600;
}
.search-type-arrow {
  font-size: 20rpx;
  color: var(--theme-primary, #5BA7D8);
  margin-left: 4rpx;
}

.select-chevron {
  width: 10rpx;
  height: 10rpx;
  margin: -5rpx 2rpx 0 12rpx;
  border-right: 3rpx solid var(--theme-primary, #5BA7D8);
  border-bottom: 3rpx solid var(--theme-primary, #5BA7D8);
  transform: rotate(45deg);
  flex-shrink: 0;
}
.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border-radius: 32rpx;
  padding: 0 16rpx;
  height: 64rpx;
}
.search-input-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 64rpx;
  line-height: 64rpx;
}
.search-placeholder {
  color: #bbb;
  font-size: 26rpx;
}
.search-clear {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  background: #e0e0e0;
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 4rpx;
}
.search-result-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 24rpx 12rpx;
}

/* ── Tab ── */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 25rpx;
  color: #666;
  position: relative;
}

.lottery-summary {
  margin: 20rpx 24rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.lottery-summary-title { display: block; color: #243044; font-size: 28rpx; font-weight: 900; }
.lottery-summary-desc { display: block; margin-top: 6rpx; color: #6E7A8A; font-size: 21rpx; }
.lottery-summary-weight { flex-shrink: 0; color: var(--theme-primary-deep, #2F8DB8); font-size: 23rpx; font-weight: 800; }
.lottery-toolbar {
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 16rpx;
  margin: 20rpx 24rpx;
}
.lottery-tool-btn {
  height: 76rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}
.lottery-tool-btn.primary {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--theme-action-start, #5BA7D8), var(--theme-action-end, #6BC6B3));
}
.lottery-tool-btn.secondary {
  color: var(--theme-primary-deep, #2F8DB8);
  background: var(--theme-primary-soft, #EAF4FB);
  border: 2rpx solid var(--theme-primary-line, #CFE7F6);
}
.lottery-prize-card {
  margin: 0 24rpx 16rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(68,92,120,.06);
}
.lottery-color-dot { width: 18rpx; height: 76rpx; border-radius: 999rpx; flex-shrink: 0; }
.lottery-prize-main { flex: 1; min-width: 0; }
.lottery-prize-title-row { display: flex; align-items: center; gap: 10rpx; }
.lottery-prize-name { color: #243044; font-size: 28rpx; font-weight: 900; }
.lottery-type-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: var(--theme-primary-deep, #2F8DB8);
  background: var(--theme-primary-soft, #EAF4FB);
  font-size: 19rpx;
}
.lottery-prize-meta { display: block; margin-top: 6rpx; color: #7A8798; font-size: 21rpx; }
.lottery-prize-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; }
.lottery-action-row { display: flex; align-items: center; gap: 6rpx; }
.lottery-order-actions { display: flex; gap: 8rpx; }
.lottery-order-btn {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--theme-primary-deep, #2F8DB8);
  background: var(--theme-primary-soft, #EAF4FB);
  font-size: 24rpx;
  font-weight: 900;
}
.lottery-order-btn.disabled { opacity: .28; }
.lottery-editor-sheet { max-height: 88vh; }
.lottery-enable-row { display: flex; align-items: center; justify-content: space-between; }
.lottery-field-head { display: flex; align-items: center; justify-content: space-between; }
.lottery-probability-preview {
  color: var(--theme-primary-deep, #2F8DB8);
  font-size: 22rpx;
  font-weight: 800;
}
.form-help {
  display: block;
  margin-top: 10rpx;
  color: var(--theme-text-muted, #A5AFBC);
  font-size: 21rpx;
  line-height: 1.5;
}
.lottery-color-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}
.lottery-color-option {
  min-width: 0;
  padding: 12rpx 6rpx;
  border: 2rpx solid var(--theme-divider, #E8EEF4);
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: var(--theme-text-secondary, #6E7A8A);
  background: var(--theme-card, #FFFFFF);
  font-size: 19rpx;
}
.lottery-color-option.active {
  border-color: var(--theme-primary, #5BA7D8);
  box-shadow: 0 0 0 4rpx var(--theme-primary-soft, #EAF4FB);
}
.lottery-color-swatch {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
}
.lottery-test-sheet { padding-bottom: calc(28rpx + env(safe-area-inset-bottom)); }
.lottery-test-note {
  display: block;
  margin: -12rpx 20rpx 20rpx;
  color: var(--theme-text-secondary, #6E7A8A);
  text-align: center;
  font-size: 22rpx;
  line-height: 1.55;
}
.admin-wheel-wrap {
  position: relative;
  width: 420rpx;
  height: 420rpx;
  margin: 28rpx auto 18rpx;
}
.admin-wheel {
  position: absolute;
  inset: 0;
  border: 14rpx solid rgba(255,255,255,.85);
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 18rpx 42rpx rgba(55,78,110,.18);
  transition: transform 2.5s cubic-bezier(.12,.67,.18,1);
}
.admin-wheel-pointer {
  position: absolute;
  z-index: 4;
  top: -18rpx;
  left: 50%;
  width: 0;
  height: 0;
  transform: translateX(-50%);
  border-left: 22rpx solid transparent;
  border-right: 22rpx solid transparent;
  border-top: 54rpx solid var(--theme-primary-deep, #2F8DB8);
}
.admin-wheel-label {
  position: absolute;
  inset: 22rpx;
  display: flex;
  justify-content: center;
  transform-origin: center;
  pointer-events: none;
}
.admin-wheel-label text {
  width: 112rpx;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 2rpx 5rpx rgba(0,0,0,.18);
}
.admin-wheel-center {
  position: absolute;
  z-index: 3;
  left: 50%;
  top: 50%;
  width: 112rpx;
  height: 112rpx;
  border: 10rpx solid rgba(255,255,255,.92);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: var(--theme-primary-deep, #2F8DB8);
  font-size: 25rpx;
  font-weight: 900;
}
.admin-wheel-center.disabled { opacity: .75; }
.lottery-test-result {
  display: block;
  min-height: 42rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
}
.lottery-test-close { margin: 22rpx 20rpx 0; }

.tab-item.active {
  color: var(--theme-primary, #5BA7D8);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--theme-primary, #5BA7D8);
  border-radius: 2rpx;
}

/* ── 添加按钮 ── */
.add-btn {
  margin: 20rpx 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--theme-primary, #5BA7D8);
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}

/* ── 商品/头像框行 ── */
.item-row {
  display: flex;
  align-items: center;
  margin: 0 24rpx 12rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.item-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #f0f4f8;
  flex-shrink: 0;
}

.item-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  display: block;
}

.item-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.act-btn {
  font-size: 24rpx;
  color: var(--theme-primary, #5BA7D8);
  padding: 4rpx 8rpx;
}

.act-btn.primary { background: var(--theme-primary, #5BA7D8); color: #fff; padding: 8rpx 20rpx; border-radius: 24rpx; }
.act-btn.disabled { color: #ccc; }
.act-btn.danger {
  color: #F36B6B;
  background: #FFF5F5;
  border: 1rpx solid rgba(243,107,107,.24);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

/* ── 发货地址预览 ── */
.ship-addr-preview {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.ship-addr-text {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}


.act-btn.primary { background: var(--theme-primary, #5BA7D8); color: #fff; padding: 8rpx 20rpx; border-radius: 24rpx; }
.act-btn.disabled { color: #ccc; }

/* ── 兑换记录卡片 ── */
.record-card {
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-item-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.record-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.record-status.status-in_backpack { color: #999; background: #f0f0f0; }
.record-status.status-pending { color: #FF9800; background: #FFF3E0; }
.record-status.status-shipped { color: var(--theme-primary-deep, #2F8DB8); background: var(--theme-primary-soft, #EAF4FB); }
.record-status.status-received { color: #4CAF50; background: #E8F5E9; }
.record-status.status-cancelled { color: #999; background: #f5f5f5; }

.record-body {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.record-meta {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
  line-height: 1.6;
}

.tracking-no { color: var(--theme-primary, #5BA7D8); }

.record-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* ── 弹窗 ── */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
}

.sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 20rpx 36rpx 60rpx;
  max-height: 85vh;
  overflow-y: auto;
}

.sheet-bar {
  width: 80rpx;
  height: 8rpx;
  background: #ddd;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  text-align: center;
  margin-bottom: 28rpx;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.form-input {
  height: 76rpx;
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

.form-picker {
  height: 76rpx;
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.form-picker.placeholder { color: #A5AFBC; }

.form-picker-locked {
  color: #526071;
  background: #EEF4F8;
  border: 1rpx solid #E1EAF0;
}

.locked-hint {
  color: #8E9AAA;
  font-size: 22rpx;
}

.option-mask {
  position: fixed;
  inset: 0;
  z-index: 1300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
  background: rgba(36,48,68,.48);
}
.option-panel {
  width: 100%;
  max-height: 76vh;
  overflow-y: auto;
  padding: 30rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background: linear-gradient(180deg, var(--theme-secondary-soft, #F2FBFA), #FFFFFF);
  box-shadow: 0 28rpx 70rpx rgba(24,76,108,.22);
}
.option-accent {
  width: 64rpx; height: 7rpx; margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--theme-primary, #5BA7D8), var(--theme-secondary, #6BC6B3));
}
.option-title { display: block; text-align: center; color: #243044; font-size: 31rpx; font-weight: 900; margin-bottom: 22rpx; }
.option-list { display: flex; flex-direction: column; gap: 12rpx; }
.option-item {
  min-height: 72rpx;
  padding: 0 22rpx;
  display: flex; align-items: center; justify-content: space-between;
  box-sizing: border-box;
  border: 1rpx solid #E8EEF4;
  border-radius: 18rpx;
  background: #FFFFFF;
  color: #536579;
  font-size: 27rpx; font-weight: 800;
}
.option-item.active { border-color: rgba(var(--theme-primary-rgb, 91, 167, 216), .45); background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5)); color: var(--theme-primary-deep, #2F8DB8); }
.option-check {
  width: 13rpx; height: 8rpx;
  border-left: 3rpx solid var(--theme-primary, #5BA7D8);
  border-bottom: 3rpx solid var(--theme-primary, #5BA7D8);
  transform: rotate(-45deg);
}
.option-cancel {
  margin-top: 18rpx; padding: 18rpx 0;
  border-radius: 999rpx; background: #EEF4F8;
  color: #6E7A8A; font-size: 27rpx; font-weight: 800; text-align: center;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.flex-1 { flex: 1; }

.img-upload {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  font-size: 24rpx;
  color: #bbb;
  text-align: center;
}

.sheet-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.s-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.s-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.s-btn.confirm {
  background: var(--theme-primary, #5BA7D8);
  color: #fff;
}

.s-btn.confirm.disabled {
  background: #a0c4e8;
}

/* ── 空状态 ── */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  font-size: 28rpx;
  color: #999;
}
/* ── 清空按钮 ── */
.records-actions {
  padding: 0 24rpx 16rpx;
  display: flex;
  justify-content: flex-end;
}
.clear-btn {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 12rpx 32rpx;
  border: 1rpx solid #ffcdd0;
  border-radius: 30rpx;
}


/* ── 兑换记录（合并展示） ── */
.record-left { display: flex; align-items: center; gap: 12rpx; }
.record-count-badge {
  font-size: 22rpx; font-weight: 700; color: var(--theme-primary, #5BA7D8);
  background: #EEF4FB; padding: 2rpx 14rpx; border-radius: 16rpx;
}
.record-type-tag {
  font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 8rpx;
  background: #f0f0f0; color: #888;
}

/* ── 发货管理 ── */
.section-title {
  font-size: 26rpx; font-weight: 600; color: #666;
  padding: 24rpx 24rpx 12rpx;
}

.shipment-card {
  margin: 0 24rpx 16rpx; padding: 24rpx;
  background: #fff; border-radius: 16rpx;
  border-left: 6rpx solid #FF9800;
}

.shipment-card.shipped { border-left-color: #4CAF50; }

.ship-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14rpx;
}
.ship-header-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.ship-item-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; }
.ship-qty {
  font-size: 24rpx; font-weight: 700; color: #FF9800;
  background: #FFF3E0; padding: 2rpx 14rpx; border-radius: 16rpx;
}
.ship-delete-link {
  font-size: 22rpx;
  font-weight: 700;
  color: #F36B6B;
  background: #FFF5F5;
  border: 1rpx solid rgba(243,107,107,.22);
  padding: 3rpx 14rpx;
  border-radius: 999rpx;
}

.ship-body { border-top: 1rpx solid #f0f0f0; padding-top: 14rpx; }
.ship-meta {
  font-size: 24rpx; color: #666; display: block; margin-bottom: 4rpx; line-height: 1.5;
}
.ship-tracking-row {
  display: flex; align-items: center; margin-top: 8rpx;
}
.ship-carrier-label {
  font-size: 24rpx; font-weight: 600; color: #333; margin-right: 12rpx;
  white-space: nowrap;
}
.ship-tracking-no {
  font-size: 24rpx; color: var(--theme-primary, #5BA7D8);
}

.ship-actions {
  display: flex; gap: 16rpx; margin-top: 16rpx;
  padding-top: 16rpx; border-top: 1rpx solid #f0f0f0;
}

/* ── 主题色收口：管理工具保留紧凑布局，只替换中性色 ── */
.page {
  background: var(--theme-bg, #F7F9FB);
}

.search-bar,
.tab-bar,
.item-row,
.record-card,
.shipment-card,
.sheet {
  background: var(--theme-card, #FFFFFF);
  border-color: var(--theme-divider, #E8EEF4);
}

.search-type-btn,
.search-input-wrap,
.ship-addr-preview,
.form-input,
.form-picker,
.s-btn.cancel {
  background: var(--theme-surface-muted, #F5F9FC);
}

.search-input,
.item-name,
.record-item-name,
.ship-item-name,
.ship-carrier-label,
.sheet-title,
.form-input,
.form-picker {
  color: var(--theme-text, #243044);
}

.search-placeholder,
.search-result-hint,
.item-meta,
.empty-tip,
.locked-hint {
  color: var(--theme-text-muted, #A5AFBC);
}

.tab-item,
.record-meta,
.section-title,
.ship-meta,
.form-label,
.s-btn.cancel {
  color: var(--theme-text-secondary, #6E7A8A);
}

.tab-bar,
.record-body,
.record-actions,
.ship-body,
.ship-actions {
  border-color: var(--theme-divider, #E8EEF4);
}

.item-thumb,
.record-type-tag,
.record-status.status-in_backpack,
.record-status.status-cancelled {
  background: var(--theme-surface-muted, #F5F9FC);
}

.record-type-tag,
.record-status.status-in_backpack,
.record-status.status-cancelled {
  color: var(--theme-text-secondary, #6E7A8A);
}

.record-count-badge {
  color: var(--theme-primary-deep, #2F8DB8);
  background: var(--theme-primary-soft, #EAF4FB);
}

.sheet-bar,
.search-clear {
  background: var(--theme-divider, #E8EEF4);
}

.search-clear {
  color: var(--theme-text-secondary, #6E7A8A);
}

.form-picker-locked,
.option-cancel {
  background: var(--theme-surface-muted, #F5F9FC);
  border-color: var(--theme-divider, #E8EEF4);
  color: var(--theme-text-secondary, #6E7A8A);
}

.option-panel {
  background: linear-gradient(180deg, var(--theme-secondary-soft, #EAF7F5), var(--theme-card, #FFFFFF));
}

.option-title {
  color: var(--theme-text, #243044);
}

.option-item {
  border-color: var(--theme-divider, #E8EEF4);
  background: var(--theme-card, #FFFFFF);
  color: var(--theme-text-secondary, #6E7A8A);
}
