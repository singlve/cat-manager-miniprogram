<!--pages/admin-items/admin-items.wxml-->
<view class="page {{themeClass}}">

  <!-- 非管理员提示 -->
  <view wx:if="{{!isAdmin}}" class="empty-tip">
    <image class="ui-empty-img" src="/assets/illustrations/admin-dashboard-transparent.png" mode="aspectFill" />
    <text>无权访问此页面</text>
  </view>

  <block wx:else>
    <view class="service-feature-hero-shell">
      <view class="service-feature-hero admin">
        <view class="service-feature-art">
          <view class="service-feature-art-back"></view>
          <view class="service-feature-art-mid"></view>
          <view class="service-feature-art-front">
            <image class="service-feature-art-icon theme-business-icon" src="/assets/icons/ui/admin.png" mode="aspectFit" />
          </view>
          <view class="service-feature-art-dot"></view>
        </view>
        <view class="service-feature-copy">
          <text class="service-feature-kicker">ADMIN STORE</text>
          <text class="service-feature-title">商品与发货</text>
          <text class="service-feature-desc">集中管理商品、兑换记录和发货状态。</text>
        </view>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab==='items' ? 'active' : ''}}" bindtap="switchTab" data-tab="items">商品管理</view>
      <view class="tab-item {{activeTab==='records' ? 'active' : ''}}" bindtap="switchTab" data-tab="records">兑换记录</view>
      <view class="tab-item {{activeTab==='shipments' ? 'active' : ''}}" bindtap="switchTab" data-tab="shipments">发货管理</view>
      <view class="tab-item {{activeTab==='lottery' ? 'active' : ''}}" bindtap="switchTab" data-tab="lottery">抽奖配置</view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="ui-loading-state">
      <view class="ui-loading-mark"></view>
      <text class="ui-loading-text">正在加载管理数据</text>
    </view>
    <view wx:elif="{{loadError}}" class="load-error-state">
      <image class="load-error-icon ui-icon-lg" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
      <text class="load-error-title">管理数据加载失败</text>
      <text class="load-error-desc">请检查网络和相关云函数后重新加载</text>
      <button class="load-retry-btn" bindtap="retryLoad">重新加载</button>
    </view>

    <!-- ═══ 商品管理 Tab ═══ -->
    <block wx:elif="{{!loadError && activeTab === 'items'}}">
      <view class="add-btn" bindtap="openAddItem">+ 添加商品</view>
      <view wx:if="{{items.length === 0}}" class="empty-tip"><image class="ui-empty-img" src="/assets/illustrations/admin-dashboard-transparent.png" mode="aspectFill" /><text>暂无商品</text></view>
      <view class="item-row" wx:for="{{items}}" wx:key="_id">
        <image wx:if="{{item.image}}" class="item-thumb" src="{{item.image}}" mode="aspectFill" lazy-load/>
        <view wx:else class="item-thumb item-thumb-placeholder"><image class="ui-icon-lg" src="/assets/icons/ui/gift.png" mode="aspectFit" /></view>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-meta">{{item._typeLabel}} | {{item.points}}积分{{item._isSystemTheme ? ' | 永久解锁' : ' | 库存:' + item.stock}}</text>
        </view>
        <view class="item-actions">
          <switch checked="{{item.enabled !== false}}" color="{{themePrimary || '#5BA7D8'}}" bindchange="toggleItemEnabled" data-item="{{item}}"/>
          <text class="act-btn" bindtap="openEditItem" data-item="{{item}}">编辑</text>
          <text wx:if="{{!item._isSystemTheme}}" class="act-btn danger" bindtap="deleteItem" data-id="{{item._id}}">删除</text>
        </view>
      </view>
    </block>

    <!-- ═══ 兑换记录 Tab（合并展示） ═══ -->
    <block wx:elif="{{!loadError && activeTab === 'records'}}">
      <!-- 搜索栏 -->
      <view class="search-bar">
        <view class="search-type-btn" bindtap="openOptionPicker" data-kind="searchType">
          <text class="search-type-label">{{searchTypes[searchTypeIdx]}}</text>
          <view class="select-chevron"></view>
        </view>
        <view class="search-input-wrap">
          <image class="search-input-icon ui-icon-sm" src="/assets/icons/ui/search.png" mode="aspectFit" />
          <input class="search-input" type="text" placeholder="请输入{{searchTypes[searchTypeIdx]}}搜索..." value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search" placeholder-class="search-placeholder" />
          <text wx:if="{{searchKeyword}}" class="search-clear" catchtap="onSearchClear">✕</text>
        </view>
      </view>
      <view wx:if="{{records.length === 0}}" class="empty-tip">
        <text>{{searchKeyword ? '没有匹配的记录' : '暂无兑换记录'}}</text>
      </view>
      <view wx:else>
        <text class="search-result-hint" wx:if="{{searchKeyword}}">找到 {{records.length}} 条匹配记录</text>
        <view class="record-card" wx:for="{{records}}" wx:key="key">
          <view class="record-header">
            <view class="record-left">
              <text class="record-item-name">{{item.itemName}}</text>
              <text class="record-count-badge">×{{item.count}}</text>
            </view>
            <text class="record-type-tag">{{item.itemType === 'virtual' ? '虚拟' : '实物'}}</text>
          </view>
          <view class="record-body">
            <text class="record-meta">用户：{{item.userNickname || '未知用户'}}</text>
            <text class="record-meta">兑换数量：{{item.count}} 件</text>
            <text class="record-meta">消耗积分：{{item.totalPoints}} 分</text>
            <text class="record-meta">首次兑换：{{item.firstAtFormatted || ''}}</text>
          </view>
          <view class="record-actions">
            <text class="act-btn danger" catchtap="deleteRedeemRecordGroup" data-record="{{item}}">删除记录</text>
          </view>
        </view>
      </view>
    </block>

    <!-- ═══ 发货管理 Tab ═══ -->
    <block wx:elif="{{!loadError && activeTab==='shipments'}}">
      <view wx:if="{{shipments.length === 0}}" class="empty-tip"><image class="ui-empty-img" src="/assets/illustrations/admin-dashboard-transparent.png" mode="aspectFill" /><text>暂无待处理发货单</text></view>
      <view wx:else>
        <!-- 待发货 -->
        <block wx:if="{{shipments.length > 0}}">
          <view class="section-title" wx:if="{{hasPending}}">待发货</view>
          <view class="shipment-card" wx:for="{{shipments}}" wx:key="_id"
                wx:if="{{item.status === 'pending'}}">
            <view class="ship-header">
              <text class="ship-item-name">{{item.itemName}}</text>
              <view class="ship-header-actions">
                <text class="ship-qty">×{{item.qty}}</text>
                <text class="ship-delete-link" catchtap="deleteShipmentCard" data-shipment="{{item}}">删除</text>
              </view>
            </view>
            <view class="ship-body">
              <text class="ship-meta">用户：{{item.userNickname || '未知'}}</text>
              <text class="ship-meta" wx:if="{{item.shippingAddress}}">收货人：{{item.shippingAddress.name}} {{item.shippingAddress.phone}}</text>
              <text class="ship-meta" wx:if="{{item.shippingAddress}}">地址：{{item.shippingAddress.province}}{{item.shippingAddress.city}}{{item.shippingAddress.district}} {{item.shippingAddress.detail}}</text>
              <text class="ship-meta">创建时间：{{item.createdAtFormatted}}</text>
            </view>
            <view class="ship-actions">
              <text class="act-btn primary" catchtap="openShipModal" data-shipment="{{item}}">发货</text>
            </view>
          </view>
        </block>

        <!-- 已发货 -->
        <view class="section-title" wx:if="{{hasShipped}}">已发货</view>
        <view class="shipment-card shipped" wx:for="{{shipments}}" wx:key="_id"
              wx:if="{{item.status === 'shipped'}}">
          <view class="ship-header">
            <text class="ship-item-name">{{item.itemName}}</text>
            <view class="ship-header-actions">
              <text class="ship-qty">×{{item.qty}}</text>
              <text class="ship-delete-link" catchtap="deleteShipmentCard" data-shipment="{{item}}">删除</text>
            </view>
          </view>
          <view class="ship-body">
            <text class="ship-meta">收货人：{{item.shippingAddress.name}} {{item.shippingAddress.phone}}</text>
            <view class="ship-tracking-row">
              <text class="ship-carrier-label">{{item.carrier || '快递'}}</text>
              <text class="ship-tracking-no" catchtap="copyTracking" data-tracking="{{item.trackingNo}}">{{item.trackingNo || ''}} （点击复制）</text>
            </view>
            <text class="ship-meta">发货时间：{{item.shippedAtFormatted}}</text>
          </view>
          <view class="ship-actions">
            <text class="act-btn" catchtap="openShipModal" data-shipment="{{item}}">修改快递</text>
          </view>
        </view>
      </view>
    </block>

    <!-- ═══ 抽奖配置 Tab ═══ -->
    <block wx:elif="{{!loadError && activeTab==='lottery'}}">
      <view class="lottery-summary">
        <view>
          <text class="lottery-summary-title">当前奖池</text>
          <text class="lottery-summary-desc">数字越大越容易抽中，卡片上的概率会自动计算</text>
        </view>
        <text class="lottery-summary-weight">{{lotteryPrizes.length}} 项奖品</text>
      </view>
      <view class="lottery-toolbar">
        <view class="lottery-tool-btn secondary" bindtap="openLotteryTester">测试转盘</view>
        <view class="lottery-tool-btn primary" bindtap="openAddLotteryPrize">+ 添加奖品</view>
      </view>
      <view wx:if="{{lotteryPrizes.length === 0}}" class="empty-tip">
        <text>暂无抽奖奖品</text>
      </view>
      <block wx:else>
        <view class="lottery-prize-card" wx:for="{{lotteryPrizes}}" wx:key="_id">
          <view class="lottery-color-dot" style="background:{{item.color || '#5BA7D8'}};"></view>
          <view class="lottery-prize-main">
            <view class="lottery-prize-title-row">
              <text class="lottery-prize-name">{{item.name}}</text>
              <text class="lottery-type-tag">{{item._typeLabel}}</text>
            </view>
            <text class="lottery-prize-meta">预计中奖概率 {{item._probability}}%</text>
            <text wx:if="{{item.type === 'physical'}}" class="lottery-prize-meta">奖池库存 {{item.stock || 0}}</text>
            <text wx:elif="{{item.virtualType === 'theme'}}" class="lottery-prize-meta">主题标识 {{item.virtualValue}}</text>
            <text wx:elif="{{item.virtualType !== 'none'}}" class="lottery-prize-meta">奖励数量 {{item.virtualValue}}</text>
          </view>
          <view class="lottery-prize-actions">
            <switch checked="{{item.enabled !== false}}" color="{{themePrimary || '#5BA7D8'}}" bindchange="toggleLotteryEnabled" data-item="{{item}}"/>
            <view class="lottery-order-actions">
              <view class="lottery-order-btn {{index === 0 ? 'disabled' : ''}}" catchtap="moveLotteryPrize" data-index="{{index}}" data-direction="-1">↑</view>
              <view class="lottery-order-btn {{index === lotteryPrizes.length - 1 ? 'disabled' : ''}}" catchtap="moveLotteryPrize" data-index="{{index}}" data-direction="1">↓</view>
            </view>
            <view class="lottery-action-row">
              <text class="act-btn" bindtap="openEditLotteryPrize" data-item="{{item}}">编辑</text>
              <text class="act-btn danger" bindtap="deleteLotteryPrize" data-item="{{item}}">删除</text>
            </view>
          </view>
        </view>
      </block>
    </block>

    <!-- 编辑商品弹窗 -->
    <view wx:if="{{showEditor}}" class="mask" catchtap="closeEditor">
      <view class="sheet" catchtap="stopBubble">
        <view class="sheet-bar"></view>
        <text class="sheet-title">{{editingId ? '编辑商品' : '添加商品'}}</text>

        <view class="form-group">
          <text class="form-label">名称</text>
          <input class="form-input" placeholder="请输入名称" value="{{form.name}}" data-key="name" bindinput="onFormInput" maxlength="20"/>
        </view>

        <view class="form-group">
          <text class="form-label">类型</text>
          <view wx:if="{{form.isSystemTheme}}" class="form-picker form-picker-locked">
            <text>主题商品</text>
            <text class="locked-hint">系统类型不可修改</text>
          </view>
          <view wx:else class="form-picker" bindtap="openOptionPicker" data-kind="itemType">
            <text>{{form.type === 'virtual' ? '虚拟商品' : '实物商品'}}</text>
            <view class="select-chevron"></view>
          </view>
        </view>
        <view wx:if="{{form.type === 'virtual' && form.isSystemTheme}}" class="form-group">
          <text class="form-label">主题标识</text>
          <view class="form-picker form-picker-locked">
            <text>{{form.virtualValue}}</text>
            <text class="locked-hint">永久权益</text>
          </view>
        </view>
        <view wx:elif="{{form.type === 'virtual'}}" class="form-row">
          <view class="form-group flex-1">
            <text class="form-label">虚拟类型</text>
            <view class="form-picker" bindtap="openOptionPicker" data-kind="virtualType">
              <text>{{form.virtualType === 'card' ? '补签卡' : '积分'}}</text>
              <view class="select-chevron"></view>
            </view>
          </view>
          <view class="form-group flex-1">
            <text class="form-label">数量</text>
            <input class="form-input" type="number" value="{{form.virtualValue}}" data-key="virtualValue" bindinput="onFormInput"/>
          </view>
        </view>
        <view class="form-row">
          <view class="form-group flex-1">
            <text class="form-label">所需积分</text>
            <input class="form-input" type="number" value="{{form.points}}" data-key="points" bindinput="onFormInput"/>
          </view>
          <view wx:if="{{!form.isSystemTheme}}" class="form-group flex-1">
            <text class="form-label">库存</text>
            <input class="form-input" type="number" value="{{form.stock}}" data-key="stock" bindinput="onFormInput"/>
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">描述</text>
          <input class="form-input" placeholder="商品描述（可选）" value="{{form.desc}}" data-key="desc" bindinput="onFormInput"/>
        </view>

        <view class="form-group">
          <text class="form-label">图片</text>
          <view class="img-upload" bindtap="chooseImage">
            <image wx:if="{{form.image}}" class="upload-preview" src="{{form.image}}" mode="aspectFill"/>
            <text wx:else class="upload-placeholder">+ 点击上传图片</text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">启用</text>
          <switch checked="{{form.enabled}}" color="{{themePrimary || '#5BA7D8'}}" bindchange="onFormSwitch"/>
        </view>

        <view class="sheet-btns">
          <view class="s-btn cancel" bindtap="closeEditor">取消</view>
          <view class="s-btn confirm {{saving ? 'disabled' : ''}}" bindtap="saveForm">{{saving ? '保存中...' : '保存'}}</view>
        </view>
      </view>
    </view>

    <!-- 抽奖奖品编辑弹窗 -->
    <view wx:if="{{showLotteryEditor}}" class="mask" catchtap="closeLotteryEditor">
      <view class="sheet lottery-editor-sheet" catchtap="stopBubble">
        <view class="sheet-bar"></view>
        <text class="sheet-title">{{editingLotteryId ? '编辑抽奖奖品' : '添加抽奖奖品'}}</text>

        <view class="form-group">
          <text class="form-label">奖品名称</text>
          <input class="form-input" value="{{lotteryForm.name}}" placeholder="例如：20积分" data-key="name" bindinput="onLotteryFormInput" maxlength="20"/>
        </view>

        <view class="form-row">
          <view class="form-group flex-1">
            <text class="form-label">奖品类型</text>
            <view class="form-picker" bindtap="openOptionPicker" data-kind="lotteryType">
              <text>{{lotteryForm.type === 'physical' ? '实物奖品' : '虚拟奖品'}}</text>
              <view class="select-chevron"></view>
            </view>
          </view>
          <view wx:if="{{lotteryForm.type === 'virtual'}}" class="form-group flex-1">
            <text class="form-label">虚拟奖励</text>
            <view class="form-picker" bindtap="openOptionPicker" data-kind="lotteryVirtualType">
              <text>{{lotteryForm.virtualType === 'points' ? '积分' : lotteryForm.virtualType === 'card' ? '补签卡' : lotteryForm.virtualType === 'theme' ? '现有主题' : '谢谢参与'}}</text>
              <view class="select-chevron"></view>
            </view>
          </view>
        </view>

        <view wx:if="{{lotteryForm.type === 'virtual' && lotteryForm.virtualType === 'theme'}}" class="form-group">
          <text class="form-label">选择主题</text>
          <view class="form-picker" bindtap="openOptionPicker" data-kind="lotteryTheme">
            <text>{{lotteryForm.virtualValue || '请选择主题'}}</text>
            <view class="select-chevron"></view>
          </view>
        </view>

        <view wx:if="{{lotteryForm.type === 'virtual' && lotteryForm.virtualType !== 'theme' && lotteryForm.virtualType !== 'none'}}" class="form-group">
          <text class="form-label">奖励数量</text>
          <input class="form-input" type="number" value="{{lotteryForm.virtualValue}}" data-key="virtualValue" bindinput="onLotteryFormInput"/>
        </view>

        <block wx:if="{{lotteryForm.type === 'physical'}}">
          <view class="form-group">
            <text class="form-label">关联实物商品</text>
            <view class="form-picker" bindtap="openOptionPicker" data-kind="lotteryPhysicalItem">
              <text>{{lotteryForm.linkedItemId ? lotteryForm.name : '请选择已上架实物商品'}}</text>
              <view class="select-chevron"></view>
            </view>
          </view>
          <view class="form-group">
            <text class="form-label">抽奖库存</text>
            <input class="form-input" type="number" value="{{lotteryForm.stock}}" data-key="stock" bindinput="onLotteryFormInput"/>
          </view>
        </block>

        <view class="form-group">
          <view class="lottery-field-head">
            <text class="form-label">中奖权重</text>
            <text class="lottery-probability-preview">预计 {{lotteryForm.estimatedProbability}}%</text>
          </view>
          <input class="form-input" type="number" value="{{lotteryForm.weight}}" data-key="weight" bindinput="onLotteryFormInput"/>
          <text class="form-help">只需填写相对大小。例如权重 20 大约是权重 10 的两倍机会。</text>
        </view>

        <view class="form-group">
          <text class="form-label">转盘颜色</text>
          <view class="lottery-color-grid">
            <view
              wx:for="{{lotteryColors}}"
              wx:key="value"
              class="lottery-color-option {{lotteryForm.color === item.value ? 'active' : ''}}"
              data-color="{{item.value}}"
              bindtap="selectLotteryColor"
            >
              <view class="lottery-color-swatch" style="background:{{item.value}};"></view>
              <text>{{item.name}}</text>
            </view>
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">奖品说明</text>
          <input class="form-input" value="{{lotteryForm.desc}}" placeholder="可选" data-key="desc" bindinput="onLotteryFormInput"/>
        </view>
        <view class="form-group lottery-enable-row">
          <text class="form-label">立即启用</text>
          <switch checked="{{lotteryForm.enabled}}" color="{{themePrimary || '#5BA7D8'}}" bindchange="onLotteryFormSwitch"/>
        </view>

        <view class="sheet-btns">
          <view class="s-btn cancel" bindtap="closeLotteryEditor">取消</view>
          <view class="s-btn confirm {{lotterySaving ? 'disabled' : ''}}" bindtap="saveLotteryPrize">{{lotterySaving ? '保存中...' : '保存奖品'}}</view>
        </view>
      </view>
    </view>

    <!-- 管理员测试转盘：只模拟，不发奖、不消耗抽奖机会 -->
    <view wx:if="{{showLotteryTester}}" class="mask" catchtap="closeLotteryTester">
      <view class="sheet lottery-test-sheet" catchtap="stopBubble">
        <view class="sheet-bar"></view>
        <text class="sheet-title">测试转盘</text>
        <text class="lottery-test-note">仅模拟当前奖池，不发放奖励，也不会消耗签到抽奖次数。</text>
        <view class="admin-wheel-wrap">
          <view class="admin-wheel-pointer"></view>
          <view class="admin-wheel" style="transform:rotate({{testWheelAngle}}deg);background:{{testWheelBackground}};">
            <view
              class="admin-wheel-label"
              wx:for="{{testWheelLabels}}"
              wx:key="key"
              style="left:{{item.x}}%;top:{{item.y}}%;"
            >
              <text style="transform:rotate({{testWheelCounterAngle}}deg);">{{item.name}}</text>
            </view>
          </view>
          <view class="admin-wheel-center {{testSpinning ? 'disabled' : ''}}" bindtap="runLotteryTest">
            {{testSpinning ? '...' : '测试'}}
          </view>
        </view>
        <text wx:if="{{testLotteryResult}}" class="lottery-test-result" style="color:{{testLotteryResultColor}};">{{testLotteryResult}}</text>
        <view class="s-btn cancel lottery-test-close" bindtap="closeLotteryTester">关闭</view>
      </view>
    </view>

    <!-- 发货弹窗 -->
    <view wx:if="{{showShipEditor}}" class="mask" catchtap="closeShipEditor">
      <view class="sheet" catchtap="stopBubble">
        <view class="sheet-bar"></view>
        <text class="sheet-title">{{shipRecord.status === 'shipped' ? '修改快递信息' : '填写快递信息'}}</text>

        <view wx:if="{{shipRecord.shippingAddress}}" class="ship-addr-preview">
          <text class="form-label">收货信息</text>
          <text class="ship-addr-text">收货人：{{shipRecord.shippingAddress.name}} {{shipRecord.shippingAddress.phone}}</text>
          <text class="ship-addr-text">地址：{{shipRecord.shippingAddress.province}}{{shipRecord.shippingAddress.city}}{{shipRecord.shippingAddress.district}}{{shipRecord.shippingAddress.detail}}</text>
        </view>

        <view class="form-group">
          <text class="form-label">快递公司</text>
          <view class="form-picker {{shipCarrier ? '' : 'placeholder'}}" bindtap="openOptionPicker" data-kind="carrier">
            <text>{{shipCarrier || '请选择'}}</text>
            <view class="select-chevron"></view>
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">快递单号</text>
          <input class="form-input" type="text" placeholder="请输入快递单号" value="{{shipTrackingNo}}" bindinput="onShipTrackingInput" maxlength="50"/>
        </view>

        <view class="sheet-btns">
          <view class="s-btn cancel" catchtap="closeShipEditor">取消</view>
          <view class="s-btn confirm {{shipping ? 'disabled' : ''}}" catchtap="confirmShip">{{shipping ? '保存中...' : '保存'}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{showOptionPicker}}" class="option-mask" catchtap="closeOptionPicker">
      <view class="option-panel" catchtap="stopBubble">
        <view class="option-accent"></view>
        <text class="option-title">{{optionPickerTitle}}</text>
        <view class="option-list">
          <view
            wx:for="{{optionPickerOptions}}"
            wx:key="value"
            class="option-item {{optionPickerSelected === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            data-index="{{index}}"
            bindtap="selectOption"
          >
            <text>{{item.label}}</text>
            <view wx:if="{{optionPickerSelected === item.value}}" class="option-check"></view>
          </view>
        </view>
        <view class="option-cancel" bindtap="closeOptionPicker">取消</view>
      </view>
    </view>
  </block>

</view>
