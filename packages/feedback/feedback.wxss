page { background: var(--theme-bg, #F7F9FB); }

/* ── filter bar ── */
.filter-bar {
  display: flex; padding: 16rpx 24rpx;
  background: var(--theme-card, #FFFFFF); white-space: nowrap;
}
.filter-item {
  display: inline-flex; align-items: center; gap: 4rpx;
  padding: 12rpx 24rpx; border-radius: 32rpx;
  font-size: 26rpx; color: var(--theme-text-secondary, #6E7A8A);
  margin-right: 12rpx; background: var(--theme-surface-muted, #F5F9FC);
}
.filter-item.active {
  background: var(--theme-primary, #5BA7D8); color: #fff;
}

/* ── list ── */
.feedback-list { padding: 16rpx 24rpx; }

.fb-card {
  background: var(--theme-card, #FFFFFF); border-radius: 16rpx;
  padding: 24rpx; margin-bottom: 16rpx;
  position: relative;
}
.fb-card.adopted {
  border: 2rpx solid #4CAF50; background: #f6fdf7;
}

.adopted-badge {
  background: #E8F5E9; color: #2E7D32;
  font-size: 24rpx; padding: 8rpx 16rpx;
  border-radius: 8rpx; margin-bottom: 12rpx;
  display: inline-block;
}

/* ── header ── */
.fb-header {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 16rpx;
}
.fb-user { display: flex; align-items: center; gap: 12rpx; }
.fb-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: var(--theme-primary-soft, #EAF4FB); color: var(--theme-primary-deep, #2F8DB8);
  font-size: 28rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.fb-avatar-img {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  flex-shrink: 0;
}
.fb-nickname { font-size: 28rpx; color: var(--theme-text, #243044); display: block; }
.fb-time { font-size: 22rpx; color: var(--theme-text-muted, #A5AFBC); display: block; margin-top: 4rpx; }

.fb-cat {
  font-size: 22rpx; padding: 4rpx 14rpx;
  border-radius: 20rpx; flex-shrink: 0;
}

/* ── content ── */
.fb-content {
  font-size: 30rpx; color: var(--theme-text, #243044); line-height: 1.6;
  margin-bottom: 16rpx; word-break: break-all;
}

/* ── images ── */
.fb-images {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  margin-bottom: 16rpx;
}
.fb-img {
  width: 180rpx; height: 180rpx;
  border-radius: 8rpx; background: var(--theme-surface-muted, #F5F9FC);
}

/* ── actions ── */
.fb-actions {
  display: flex; gap: 32rpx;
  padding-top: 16rpx; border-top: 1rpx solid var(--theme-divider, #E8EEF4);
}
.fb-act {
  font-size: 26rpx; color: var(--theme-text-muted, #A5AFBC);
  display: flex; align-items: center; gap: 4rpx;
  padding: 12rpx 16rpx; border-radius: 8rpx;
}
.fb-act-hover { background: var(--theme-surface-muted, #F5F9FC); }
.fb-act.liked { color: #e74c3c; }
.admin-act { color: var(--theme-primary, #5BA7D8); font-weight: 600; }
.delete-act { color: #e74c3c; }

/* ── comments ── */
.fb-comments {
  margin-top: 16rpx; padding-top: 16rpx;
  border-top: 1rpx solid var(--theme-divider, #E8EEF4);
}
.cmt-item {
  font-size: 26rpx; color: var(--theme-text-secondary, #6E7A8A); line-height: 1.5;
  padding: 8rpx 0;
}
.cmt-main { display: inline; }
.cmt-user { color: var(--theme-primary, #5BA7D8); font-weight: 500; }
.cmt-text { color: var(--theme-text-secondary, #6E7A8A); }
.cmt-hover { background: var(--theme-surface-muted, #F5F9FC); border-radius: 8rpx; }
.cmt-replies {
  margin-top: 8rpx; padding-left: 24rpx;
  border-left: 2rpx solid var(--theme-divider, #E8EEF4);
}
.cmt-sub { padding: 4rpx 0; }

/* ── empty / loading ── */
.loading-box { text-align: center; padding: 120rpx 0; color: var(--theme-text-muted, #A5AFBC); }
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: var(--theme-text-muted, #A5AFBC); margin-top: 16rpx; }

/* ── 添加按钮（与 cat-list 统一风格）── */
.add-section {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  bottom: calc(40rpx + constant(safe-area-inset-bottom));
  left: 0; right: 0;
  display: flex; justify-content: center;
  padding: 0 40rpx; z-index: 99;
}
.add-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
  color: #fff; font-size: 34rpx; font-weight: 700;
  border-radius: 50rpx; padding: 28rpx 0;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(74, 144, 217, 0.45);
}
.add-btn::after { border: none; }

/* ── modal ── */
.mask { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 1000; }
.sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--theme-card, #FFFFFF); border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh; overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom);
}
.sheet-bar {
  width: 60rpx; height: 6rpx; background: var(--theme-divider, #E8EEF4);
  border-radius: 3rpx; margin: 16rpx auto;
}
.sheet-title {
  display: block; text-align: center;
  font-size: 32rpx; font-weight: 600; padding: 8rpx 0 12rpx;
}
.sheet-sub {
  display: block; text-align: center;
  font-size: 24rpx; color: var(--theme-text-muted, #A5AFBC); padding: 0 32rpx 16rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.field-group { padding: 0 32rpx 20rpx; }
.field-label { font-size: 26rpx; color: var(--theme-text-secondary, #6E7A8A); margin-bottom: 8rpx; display: block; }
.picker-val {
  padding: 16rpx; background: var(--theme-surface-muted, #F5F9FC); border-radius: 8rpx;
  font-size: 28rpx;
}
.field-textarea {
  width: 100%; min-height: 160rpx; padding: 16rpx;
  background: var(--theme-surface-muted, #F5F9FC); border-radius: 8rpx;
  font-size: 28rpx; box-sizing: border-box;
}
.sheet-btns {
  display: flex; gap: 20rpx; padding: 20rpx 32rpx 40rpx;
}
.sheet-btns .cancel, .sheet-btns .confirm {
  flex: 1; height: 80rpx; line-height: 80rpx;
  text-align: center; border-radius: 12rpx; font-size: 30rpx;
  padding: 0; margin: 0;
}
.sheet-btns .cancel { background: var(--theme-surface-muted, #F5F9FC); color: var(--theme-text-secondary, #6E7A8A); }
.sheet-btns .confirm { background: var(--theme-primary, #5BA7D8); color: #fff; }
.sheet-btns .confirm.disabled { opacity: .5; }
.sheet-btns .cancel::after, .sheet-btns .confirm::after { border: none; }

/* ── 通知胶囊 ── */
.notify-capsule {
  display: flex; align-items: center; justify-content: center;
  margin: 16rpx auto; padding: 16rpx 48rpx;
  background: #3A3A3A;
  border-radius: 12rpx;
  width: fit-content;
}
.notify-capsule:active { opacity: 0.8; }
.capsule-text {
  font-size: 26rpx; color: #ccc;
}

/* ── 卡片高亮 ── */
.fb-card.highlight {
  animation: highlightPulse 0.6s ease 3;
  box-shadow: 0 0 0 4rpx var(--theme-primary, #5BA7D8);
}
@keyframes highlightPulse {
  0%, 100% { background: var(--theme-card, #FFFFFF); }
  50% { background: var(--theme-primary-soft, #EAF4FB); }
}

/* ── 通知面板 ── */
.notify-empty {
  text-align: center; padding: 60rpx; color: var(--theme-text-muted, #A5AFBC); font-size: 28rpx;
}
.notify-list {
  padding: 0 32rpx 40rpx;
  max-height: 60vh; overflow-y: auto;
}
.notify-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 24rpx 0; border-bottom: 1rpx solid var(--theme-divider, #E8EEF4);
  position: relative;
}
.notify-item:active { background: var(--theme-surface-muted, #F5F9FC); }
.notify-icon { font-size: 36rpx; flex-shrink: 0; margin-top: 2rpx; }
.notify-body { flex: 1; }
.notify-snippet { font-size: 28rpx; color: var(--theme-text, #243044); display: block; line-height: 1.5; }
.notify-time { font-size: 22rpx; color: var(--theme-text-muted, #A5AFBC); display: block; margin-top: 6rpx; }
.notify-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #e74c3c; flex-shrink: 0; margin-top: 8rpx;
}
