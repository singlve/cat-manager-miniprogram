<view class="page admin-benefit-page {{themeClass}}">
  <view wx:if="{{!isAdmin}}" class="empty-tip">无权访问</view>
  <block wx:else>
    <view class="service-feature-hero-shell">
      <view class="service-feature-hero admin">
        <view class="service-feature-art">
          <view class="service-feature-art-back"></view>
          <view class="service-feature-art-mid"></view>
          <view class="service-feature-art-front">
            <image class="service-feature-art-icon theme-business-icon" src="/assets/icons/ui/ticket.png" mode="aspectFit" />
          </view>
          <view class="service-feature-art-dot"></view>
        </view>
        <view class="service-feature-copy">
          <text class="service-feature-kicker">ADMIN BENEFITS</text>
          <text class="service-feature-title">福利管理</text>
          <text class="service-feature-desc">配置版本礼遇、节日福利和用户补偿。</text>
        </view>
      </view>
    </view>

    <view class="benefit-tabs">
      <view class="{{activeTab === 'campaigns' ? 'active' : ''}}" bindtap="switchTab" data-tab="campaigns">活动配置</view>
      <view class="{{activeTab === 'claims' ? 'active' : ''}}" bindtap="switchTab" data-tab="claims">领取记录</view>
    </view>

    <view wx:if="{{loading}}" class="ui-loading-state">
      <view class="ui-loading-mark"></view><text class="ui-loading-text">正在加载福利数据</text>
    </view>
    <view wx:elif="{{loadError}}" class="load-error-state">
      <text class="load-error-title">福利数据加载失败</text>
      <button class="load-retry-btn" bindtap="loadAll">重新加载</button>
    </view>

    <block wx:elif="{{activeTab === 'campaigns'}}">
      <view class="admin-add-btn" bindtap="openAdd">+ 新建福利活动</view>
      <view wx:if="{{campaigns.length === 0}}" class="empty-tip">暂无福利活动</view>
      <view wx:for="{{campaigns}}" wx:key="_id" class="campaign-card">
        <view class="campaign-head">
          <view class="campaign-title-wrap">
            <text class="campaign-title">{{item.title}}</text>
            <text class="campaign-status {{item._statusClass}}">{{item._statusText}}</text>
            <text wx:if="{{item._endingText}}" class="ending-soon">{{item._endingText}}</text>
          </view>
          <switch checked="{{item.enabled !== false}}" color="{{themePrimary || '#5BA7D8'}}" bindchange="toggleCampaign" data-item="{{item}}" />
        </view>
        <text class="campaign-desc">{{item.desc || '暂无说明'}}</text>
        <view class="campaign-meta">
          <text>{{item._rewardText}}</text>
          <text>{{item._audienceText}}</text>
          <text>{{item._timeText}}</text>
        </view>
        <view class="campaign-stats">
          <view><text>{{item.eligibleUsers}}</text><text>预计适用用户</text></view>
          <view><text>{{item.claimedCount || 0}}</text><text>已领取</text></view>
          <view><text>{{item.remainingQuota < 0 ? '不限' : item.remainingQuota}}</text><text>剩余份数</text></view>
        </view>
        <text class="campaign-quota">{{item._quotaText}}</text>
        <view class="campaign-actions">
          <text bindtap="openEdit" data-item="{{item}}">编辑</text>
          <text bindtap="copyCampaign" data-item="{{item}}">复制</text>
          <text class="danger" bindtap="deleteCampaign" data-item="{{item}}">删除</text>
        </view>
      </view>
    </block>

    <block wx:else>
      <scroll-view class="claim-filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="claim-filter-row">
          <view wx:for="{{claimCampaignOptions}}" wx:key="value" class="claim-filter-chip {{claimCampaignFilter === item.value ? 'active' : ''}}" bindtap="selectClaimCampaign" data-value="{{item.value}}">{{item.label}}</view>
        </view>
      </scroll-view>
      <view class="claim-status-filter">
        <view wx:for="{{claimStatusFilters}}" wx:key="value" class="{{claimStatusFilter === item.value ? 'active' : ''}}" bindtap="selectClaimStatus" data-value="{{item.value}}">{{item.label}}</view>
      </view>
      <view wx:if="{{filteredClaims.length === 0}}" class="empty-tip">当前筛选下暂无领取记录</view>
      <view wx:for="{{filteredClaims}}" wx:key="_id" class="claim-card">
        <view>
          <text class="claim-title">{{item.campaignTitle}}</text>
          <text class="claim-user">{{item.userNickname || '未命名用户'}}</text>
          <text class="claim-time">{{item._timeText}}</text>
        </view>
        <view class="claim-side">
          <text class="claim-reward">{{item._rewardText}}</text>
          <text class="claim-status">{{item._statusText}}</text>
        </view>
      </view>
    </block>

    <view wx:if="{{showEditor}}" class="editor-mask" catchtap="closeEditor">
      <view class="editor-sheet" catchtap="stopBubble">
        <scroll-view class="editor-scroll" scroll-y enhanced show-scrollbar="{{false}}">
          <view class="editor-content">
            <view class="sheet-bar"></view>
            <text class="editor-title">{{editingId ? '编辑福利活动' : '新建福利活动'}}</text>

            <text class="form-label">福利名称</text>
            <input class="form-input" value="{{form.title}}" data-key="title" bindinput="onInput" placeholder="例如：周年庆登录礼" placeholder-class="form-placeholder" />
            <text class="form-label">福利说明</text>
            <textarea class="form-textarea" value="{{form.desc}}" data-key="desc" bindinput="onInput" placeholder="说明领取内容和使用方式" placeholder-class="form-placeholder" />

            <text class="form-label">奖励类型</text>
            <view class="choice-grid">
              <view wx:for="{{rewardTypes}}" wx:key="value" class="choice-item {{form.rewardType === item.value ? 'active' : ''}}" bindtap="selectRewardType" data-value="{{item.value}}">{{item.label}}</view>
            </view>

            <text class="form-label">每位用户获得数量</text>
            <input class="form-input" type="number" value="{{form.rewardAmount}}" data-key="rewardAmount" bindinput="onInput" />
            <text wx:if="{{form.rewardType === 'points'}}" class="form-help">例如填 100，表示每位用户领取后获得 100 积分。</text>
            <text wx:elif="{{form.rewardType === 'card'}}" class="form-help">例如填 2，表示每位用户领取后获得 2 张补签卡。</text>
            <text wx:elif="{{form.rewardType === 'theme_voucher'}}" class="form-help">通常填 1，表示每位用户获得 1 张主题兑换券。</text>
            <text wx:elif="{{form.rewardType === 'theme'}}" class="form-help">指定主题每位用户只需获得 1 套，数量请保持为 1。</text>
            <text wx:elif="{{form.rewardType === 'draw'}}" class="form-help">例如填 2，表示每位用户获得 2 次额外抽奖机会。</text>
            <text wx:else class="form-help">表示每位用户可领取的实物件数，通常填 1。</text>

            <text class="form-label">总发放份数</text>
            <input class="form-input" type="number" value="{{form.totalQuota}}" data-key="totalQuota" bindinput="onInput" />
            <text class="form-help">默认 100 份；填 0 表示不限总份数。每位用户仍然只能领取一次。</text>

            <block wx:if="{{form.rewardType === 'theme_voucher'}}">
              <text class="form-label">可兑换主题积分上限</text>
              <input class="form-input" type="number" value="{{form.maxThemePoints}}" data-key="maxThemePoints" bindinput="onInput" />
            </block>

            <block wx:if="{{form.rewardType === 'theme'}}">
              <text class="form-label">指定主题</text>
              <view class="choice-grid">
                <view wx:for="{{themes}}" wx:key="key" class="choice-item {{form.themeKey === item.key ? 'active' : ''}}" bindtap="selectTheme" data-key="{{item.key}}">{{item.name}}</view>
              </view>
            </block>

            <block wx:if="{{form.rewardType === 'physical'}}">
              <text class="form-label">关联实物商品</text>
              <view class="choice-list">
                <view wx:for="{{physicalItems}}" wx:key="_id" class="choice-row {{form.linkedItemId === item._id ? 'active' : ''}}" bindtap="selectPhysical" data-id="{{item._id}}">
                  <text>{{item.name}}</text><text>库存 {{item.stock || 0}}</text>
                </view>
              </view>
            </block>

            <text class="form-label">适用用户</text>
            <view class="segment-choice">
              <view class="{{form.audience === 'all' ? 'active' : ''}}" bindtap="selectAudience" data-value="all">全部用户</view>
              <view class="{{form.audience === 'new' ? 'active' : ''}}" bindtap="selectAudience" data-value="new">新用户</view>
            </view>
            <block wx:if="{{form.audience === 'new'}}">
              <text class="form-label">注册时间起算点</text>
              <view class="time-control">
                <picker class="time-picker" mode="date" value="{{form.newUserSinceDate}}" bindchange="onTimePartChange" data-key="newUserSince" data-part="date">
                  <view class="time-picker-value">{{form.newUserSinceDate || '选择日期'}}<view class="time-picker-arrow"></view></view>
                </picker>
                <picker class="time-picker" mode="time" value="{{form.newUserSinceTime}}" bindchange="onTimePartChange" data-key="newUserSince" data-part="time">
                  <view class="time-picker-value">{{form.newUserSinceTime || '选择时间'}}<view class="time-picker-arrow"></view></view>
                </picker>
              </view>
              <text class="form-help">仅注册时间不早于该时间的用户可领取；老账号或缺少注册时间的账号不可领取。</text>
            </block>
            <view class="audience-preview">
              <view>
                <text class="audience-preview-label">预计适用人数</text>
                <text class="audience-preview-value">{{audiencePreview === null ? '尚未计算' : audiencePreview + ' 人'}}</text>
              </view>
              <view class="audience-preview-btn" bindtap="previewAudience">{{previewingAudience ? '计算中' : '重新计算'}}</view>
            </view>

            <text class="form-label">活动开始时间</text>
            <view class="time-control">
              <picker class="time-picker" mode="date" value="{{form.startAtDate}}" bindchange="onTimePartChange" data-key="startAt" data-part="date">
                <view class="time-picker-value">{{form.startAtDate}}<view class="time-picker-arrow"></view></view>
              </picker>
              <picker class="time-picker" mode="time" value="{{form.startAtTime}}" bindchange="onTimePartChange" data-key="startAt" data-part="time">
                <view class="time-picker-value">{{form.startAtTime}}<view class="time-picker-arrow"></view></view>
              </picker>
            </view>
            <text class="form-help">新建活动默认使用当前系统时间，保存后立即开始。</text>
            <view class="form-label-row">
              <text class="form-label">活动结束时间</text>
              <text wx:if="{{form.endAt}}" class="time-clear" bindtap="clearEndTime">设为长期有效</text>
            </view>
            <view class="time-control">
              <picker class="time-picker" mode="date" value="{{form.endAtDate || form.startAtDate}}" bindchange="onTimePartChange" data-key="endAt" data-part="date">
                <view class="time-picker-value {{!form.endAtDate ? 'placeholder' : ''}}">{{form.endAtDate || '选择日期'}}<view class="time-picker-arrow"></view></view>
              </picker>
              <picker class="time-picker" mode="time" value="{{form.endAtTime || form.startAtTime}}" bindchange="onTimePartChange" data-key="endAt" data-part="time">
                <view class="time-picker-value {{!form.endAtTime ? 'placeholder' : ''}}">{{form.endAtTime || '选择时间'}}<view class="time-picker-arrow"></view></view>
              </picker>
            </view>
            <text class="form-help">结束时间不选择时，活动长期有效。</text>
            <text class="form-label">展示顺序</text>
            <input class="form-input" type="number" value="{{form.sort}}" data-key="sort" bindinput="onInput" />
            <text class="form-help">数字越小越靠前，活动不多时按 1、2、3 依次填写即可。</text>

            <view class="form-switch-row">
              <text>立即启用</text>
              <switch checked="{{form.enabled}}" color="{{themePrimary || '#5BA7D8'}}" bindchange="toggleFormEnabled" />
            </view>
          </view>
        </scroll-view>

        <view class="editor-actions">
          <view class="editor-cancel" bindtap="closeEditor">取消</view>
          <view class="editor-confirm" bindtap="saveCampaign">{{saving ? '保存中' : '保存活动'}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
