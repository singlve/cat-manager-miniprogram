<!--packages/expense-add/expense-add.wxml-->
<view class="page {{themeClass}}">
  <view class="ui-compact-hero expense-hero">
    <include src="../../templates/festival-hero-decor.wxml" />
    <image class="ui-compact-hero-img" src="/packages/assets/illustrations/rewards-hero-pets.webp" mode="aspectFit" />
    <view class="ui-compact-hero-body">
      <text class="ui-compact-kicker">DAILY EXPENSE</text>
      <text class="ui-compact-title">记录一笔花销</text>
      <text class="ui-compact-desc">把宠物的食品、医疗和日常用品整理清楚。</text>
    </view>
  </view>

  <view class="form-card">
    <view class="field" wx:if="{{cats.length > 0}}">
      <text class="field-label">记到哪里</text>
      <view class="picker-box" bindtap="openPetPicker">
        <view class="picker-main">
          <image class="picker-icon ui-icon-sm" src="{{cats[selectedCatIdx] && cats[selectedCatIdx]._id ? (cats[selectedCatIdx].species === 'dog' ? '/assets/icons/ui/dog.png' : '/assets/icons/ui/cat.png') : '/assets/icons/ui/record.png'}}" mode="aspectFit" />
          <text>{{cats[selectedCatIdx] ? cats[selectedCatIdx].name : '选择宠物'}}</text>
        </view>
        <view class="picker-arrow"></view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">花销分类</text>
      <view class="category-grid">
        <view
          wx:for="{{categories}}"
          wx:for-item="c"
          wx:for-index="ci"
          wx:key="key"
          class="category-item {{c.tone}} {{selectedCategoryIdx === ci ? 'active' : ''}}"
          bindtap="selectCategory"
          data-idx="{{ci}}"
        >
          <view class="category-icon-wrap">
            <image class="category-icon ui-icon theme-business-icon" src="{{c.iconPath}}" mode="aspectFit" />
          </view>
          <text class="category-name">{{c.name}}</text>
        </view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">金额</text>
      <view class="amount-box">
        <text class="amount-yuan">¥</text>
        <input
          class="amount-input"
          type="digit"
          placeholder="0.00"
          value="{{amount}}"
          bindinput="onAmountInput"
          focus="{{true}}"
        />
      </view>
    </view>

    <view class="field">
      <text class="field-label">日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="picker-box">
          <view class="picker-main">
            <image class="picker-icon ui-icon-sm" src="/assets/icons/ui/calendar.png" mode="aspectFit" />
            <text>{{date || '选择日期'}}</text>
          </view>
          <view class="picker-arrow"></view>
        </view>
      </picker>
    </view>

    <view class="field">
      <text class="field-label">备注（选填）</text>
      <textarea
        class="note-input"
        placeholder="例如：猫粮、体检或玩具..."
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="100"
        auto-height
      />
    </view>
  </view>

  <view class="save-section">
    <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="doSave">
      <text>{{saving ? '保存中...' : '保存记录'}}</text>
    </view>
  </view>

  <view wx:if="{{showPetPicker}}" class="picker-mask" catchtap="closePetPicker">
    <view class="picker-panel" catchtap="">
      <text class="picker-title">选择记账对象</text>
      <text class="picker-subtitle">可以记录公共花销，也可以归到某只宠物名下</text>
      <view class="picker-list">
        <view
          wx:for="{{cats}}"
          wx:key="_id"
          class="pet-option {{selectedCatIdx === index ? 'active' : ''}}"
          bindtap="selectPet"
          data-index="{{index}}"
        >
          <view class="pet-option-icon">
            <image class="ui-icon" src="{{item._id ? (item.species === 'dog' ? '/assets/icons/ui/dog.png' : '/assets/icons/ui/cat.png') : '/assets/icons/ui/record.png'}}" mode="aspectFit" />
          </view>
          <view class="pet-option-copy">
            <text class="pet-option-name">{{item.name}}</text>
            <text class="pet-option-desc">{{item._id ? (item.breed || '宠物专属花销') : '多只宠物共同使用的花销'}}</text>
          </view>
          <text wx:if="{{selectedCatIdx === index}}" class="pet-option-check">✓</text>
        </view>
      </view>
      <view class="picker-cancel" bindtap="closePetPicker">取消</view>
    </view>
  </view>
</view>
