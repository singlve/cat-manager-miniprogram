<!--pages/points-mall/points-mall.wxml-->
<view class="page {{themeClass}}">
  <include src="../../../templates/offline-tip.wxml" />

  <view class="ui-hero-card">
    <image class="ui-hero-img" src="/assets/illustrations/rewards-hero-pets-transparent.png" mode="aspectFit" />
    <text class="ui-hero-title">积分小铺</text>
    <text class="ui-hero-subtitle">把日常照护攒成积分，换一点给宝贝的小惊喜。</text>
  </view>

  <!-- 积分余额 -->
  <view class="points-banner">
    <view class="points-balance">
      <text class="balance-label">我的积分</text>
      <text class="balance-num">{{points}}</text>
    </view>
    <view class="voucher-mini">
      <image src="/assets/icons/ui/ticket.png" mode="aspectFit" />
      <view>
        <text>主题券</text>
        <text>{{themeVouchers}} 张</text>
      </view>
    </view>
    <view class="banner-action" bindtap="goInventory">
      <image class="ui-icon-sm" src="/assets/icons/ui/backpack.png" mode="aspectFit" />
      <text>我的背包</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="mall-guide">
    <view class="mall-guide-item" bindtap="openRules">
      <image class="mall-guide-icon" src="/assets/icons/ui/ticket.png" mode="aspectFit" />
      <text>积分规则</text>
    </view>
    <view class="mall-guide-divider"></view>
    <view class="mall-guide-item" bindtap="openRedeemRecords">
      <image class="mall-guide-icon" src="/assets/icons/ui/record.png" mode="aspectFit" />
      <text>兑换记录</text>
    </view>
    <view class="mall-guide-divider"></view>
    <view class="mall-guide-item" bindtap="goThemeCenter">
      <image class="mall-guide-icon" src="/assets/icons/ui/package.png" mode="aspectFit" />
      <text>使用主题</text>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar">
    <view class="filter-tag {{filter==='all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">全部</view>
    <view class="filter-tag {{filter==='virtual' ? 'active' : ''}}" bindtap="switchFilter" data-filter="virtual">虚拟商品</view>
    <view class="filter-tag {{filter==='physical' ? 'active' : ''}}" bindtap="switchFilter" data-filter="physical">实物商品</view>
    <view wx:if="{{themeVouchers > 0}}" class="filter-tag {{filter==='voucher' ? 'active' : ''}}" bindtap="switchFilter" data-filter="voucher">主题券可兑</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="ui-loading-state">
    <view class="ui-loading-mark"></view>
    <text class="ui-loading-text">正在加载积分商品</text>
  </view>
  <view wx:elif="{{loadError}}" class="load-error-state">
    <image class="load-error-icon ui-icon-lg" src="/assets/icons/ui/cloud.png" mode="aspectFit" />
    <text class="load-error-title">商品加载失败</text>
    <text class="load-error-desc">请检查网络后重新加载</text>
    <button class="load-retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <!-- 商品列表 -->
  <block wx:else>
    <view wx:if="{{filteredItems.length === 0}}" class="empty-tip">
      <image class="ui-empty-img" src="/assets/illustrations/pet-profile-clean.png" mode="aspectFill" />
      <text style="color:#999;margin-top:16rpx;">暂无商品</text>
    </view>
    <view wx:else class="item-list">
      <view class="item-card" wx:for="{{filteredItems}}" wx:key="_id" bindtap="openRedeem" data-item="{{item}}">
        <view class="item-img-wrap">
          <view wx:if="{{item.virtualType === 'theme'}}" class="item-img theme-product-preview preview-{{item.virtualValue}}">
            <view class="theme-preview-top"></view>
            <view class="theme-preview-card"></view>
            <view class="theme-preview-row">
              <view class="theme-preview-dot"></view>
              <view class="theme-preview-line"></view>
            </view>
          </view>
          <image wx:elif="{{item.image}}" class="item-img" src="{{item.image}}" mode="aspectFill" lazy-load/>
          <view wx:else class="item-img item-img-placeholder"><image class="ui-icon-lg" src="/assets/icons/ui/gift.png" mode="aspectFit" /></view>
          <view wx:if="{{item.type === 'physical'}}" class="item-badge physical">实物</view>
          <view wx:elif="{{item.virtualType === 'theme'}}" class="item-badge theme">
            {{item.limited ? (item.badge || '限定主题') : '主题'}}
          </view>
          <view wx:else class="item-badge virtual">虚拟</view>
          <view wx:if="{{item._owned}}" class="owned-badge">已拥有</view>
        </view>
        <view class="item-body">
          <text class="item-name">{{item.name}}</text>
          <text wx:if="{{item.desc}}" class="item-desc">{{item.desc}}</text>
          <view class="item-footer">
            <view class="item-points">
              <image class="points-icon ui-icon-sm" src="/assets/icons/ui/ticket.png" mode="aspectFit" />
              <text class="points-num">{{item.points}}</text>
            </view>
            <view wx:if="{{item.type === 'physical'}}" class="item-stock">
              <text>库存：{{item.stock || 0}}</text>
            </view>
            <view wx:elif="{{item._owned}}" class="item-owned">永久拥有</view>
            <view wx:elif="{{item._voucherEligible && themeVouchers > 0}}" class="voucher-usable">可用主题券</view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 兑换弹窗（含数量选择） -->
  <view wx:if="{{showRedeemModal}}" class="mask" catchtap="closeRedeem">
    <view class="redeem-sheet" catchtap="stopBubble">
      <view class="sheet-bar"></view>
      <text class="sheet-title">确认兑换</text>
      <view class="redeem-info" wx:if="{{redeemTarget}}">
        <text class="redeem-name">{{redeemTarget.name}}</text>
        <text class="redeem-desc" wx:if="{{redeemTarget.desc}}">{{redeemTarget.desc}}</text>

        <view wx:if="{{redeemTarget.virtualType === 'theme' && voucherEligible}}" class="payment-methods">
          <view
            class="payment-method {{redeemMethod === 'theme_voucher' ? 'active' : ''}}"
            catchtap="selectRedeemMethod"
            data-method="theme_voucher"
          >
            <text class="payment-method-title">使用主题兑换券</text>
            <text class="payment-method-desc">现有 {{themeVouchers}} 张，本次不扣积分</text>
          </view>
          <view
            class="payment-method {{redeemMethod === 'points' ? 'active' : ''}}"
            catchtap="selectRedeemMethod"
            data-method="points"
          >
            <text class="payment-method-title">使用积分兑换</text>
            <text class="payment-method-desc">需要 {{redeemTarget.points}} 积分</text>
          </view>
        </view>

        <!-- 数量选择器（实物商品且库存>1时显示） -->
        <view wx:if="{{redeemTarget.type === 'physical' && redeemMaxQty > 1}}" class="qty-section">
          <text class="qty-label">兑换数量</text>
          <view class="qty-stepper">
            <view class="step-btn {{redeemQty <= 1 ? 'disabled' : ''}}" catchtap="qtyMinus">−</view>
            <text class="step-val">{{redeemQty}}</text>
            <view class="step-btn {{redeemQty >= redeemMaxQty ? 'disabled' : ''}}" catchtap="qtyPlus">+</view>
          </view>
          <view class="qty-shortcuts">
            <view wx:for="{{[1,2,3,5,10]}}" wx:key="*this"
              wx:if="{{item <= redeemMaxQty}}"
              class="qs {{redeemQty === item ? 'active' : ''}}"
              catchtap="setRedeemQty" data-qty="{{item}}">{{item}}件</view>
          </view>
        </view>

        <view class="redeem-cost">
          <text>{{redeemMethod === 'theme_voucher' ? '使用兑换券：' : '消耗积分：'}}</text>
          <text class="cost-num">{{redeemMethod === 'theme_voucher' ? '1 张' : redeemTotalCost}}</text>
        </view>
        <view class="redeem-tip {{redeemMethod === 'points' && points < redeemTotalCost || (redeemTarget.type === 'physical' && redeemQty > (redeemTarget.stock || 0)) ? 'insufficient' : ''}}">
          <text wx:if="{{redeemMethod === 'theme_voucher'}}">兑换后剩余 {{themeVouchers - 1}} 张主题券，积分保持不变</text>
          <text wx:elif="{{points < redeemTotalCost}}">积分不足（当前 {{points}} 积分）</text>
          <text wx:elif="{{redeemTarget.type === 'physical' && redeemQty > (redeemTarget.stock || 0)}}">❌ 库存不足</text>
          <text wx:else>兑换后剩余 {{points - redeemTotalCost}} 积分</text>
        </view>
      </view>
      <view class="sheet-btns">
        <view class="s-btn cancel" catchtap="closeRedeem">取消</view>
        <view class="s-btn confirm {{redeeming || (redeemMethod === 'points' && points < redeemTotalCost) || (redeemTarget.type === 'physical' && redeemQty > (redeemTarget.stock || 0)) ? 'disabled' : ''}}"
          catchtap="confirmRedeem">{{redeeming ? '兑换中...' : (redeemTarget.virtualType === 'theme' ? '确认解锁主题' : '确认兑换(' + redeemQty + '件)')}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showRulesModal}}" class="mask center-mask" catchtap="closeRules">
    <view class="info-modal" catchtap="stopBubble">
      <view class="info-modal-head">
        <view>
          <text class="info-modal-kicker">POINTS GUIDE</text>
          <text class="info-modal-title">积分规则</text>
        </view>
        <view class="info-modal-close" bindtap="closeRules"></view>
      </view>
      <view class="rule-list">
        <view class="rule-row">
          <text class="rule-number">01</text>
          <view><text class="rule-title">每日签到</text><text class="rule-desc">连续 1–3 天每天 10 分，4–7 天每天 15 分，8–30 天每天 20 分，之后每天 25 分。</text></view>
        </view>
        <view class="rule-row">
          <text class="rule-number">02</text>
          <view><text class="rule-title">累计奖励</text><text class="rule-desc">累计签到 7、30、60、100、365 天时，可获得对应里程碑积分。</text></view>
        </view>
        <view class="rule-row">
          <text class="rule-number">03</text>
          <view><text class="rule-title">连续抽奖</text><text class="rule-desc">每连续签到 7 天获得一次抽奖机会，断签后连续天数会重新计算。</text></view>
        </view>
        <view class="rule-row">
          <text class="rule-number">04</text>
          <view><text class="rule-title">兑换说明</text><text class="rule-desc">实物兑换后进入背包等待确认，虚拟物品和主题兑换成功后直接到账。</text></view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showRecordsModal}}" class="mask center-mask" catchtap="closeRedeemRecords">
    <view class="info-modal records-modal" catchtap="stopBubble">
      <view class="info-modal-head">
        <view>
          <text class="info-modal-kicker">REDEMPTION</text>
          <text class="info-modal-title">我的兑换记录</text>
        </view>
        <view class="info-modal-close" bindtap="closeRedeemRecords"></view>
      </view>
      <view wx:if="{{recordsLoading}}" class="record-empty">正在加载...</view>
      <scroll-view wx:elif="{{redeemRecords.length}}" class="record-list" scroll-y>
        <view class="record-row" wx:for="{{redeemRecords}}" wx:key="_id">
          <view class="record-main">
            <text class="record-name">{{item.itemName}}</text>
            <text class="record-time">{{item._timeText}}</text>
          </view>
          <view class="record-side">
            <text class="record-cost">{{item._costText}}</text>
            <text class="record-status">{{item._statusText}}</text>
          </view>
        </view>
      </scroll-view>
      <view wx:else class="record-empty">还没有兑换记录</view>
    </view>
  </view>

</view>
