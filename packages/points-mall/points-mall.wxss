/* pages/points-mall/points-mall.wxss */

.page {
  min-height: 100vh;
  background: var(--theme-bg, #F7F9FB);
}

/* ── 积分横幅 ── */
.points-banner {
  background: linear-gradient(135deg, var(--theme-primary, #5BA7D8), var(--theme-primary-deep, #4D8FB8));
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.points-balance {
  display: flex;
  flex-direction: column;
}

.balance-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.balance-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  margin-top: 4rpx;
}

.banner-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 32rpx;
}

.voucher-mini {
  display: flex;
  align-items: center;
  gap: 9rpx;
  padding: 10rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,.16);
}
.voucher-mini image { width: 34rpx; height: 34rpx; }
.voucher-mini text { display: block; color: rgba(255,255,255,.76); font-size: 18rpx; line-height: 1.2; }
.voucher-mini text:last-child { margin-top: 3rpx; color: #FFFFFF; font-size: 22rpx; font-weight: 900; }

.mall-guide {
  display: flex;
  align-items: center;
  margin: 0 24rpx 22rpx;
  padding: 20rpx 12rpx;
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .10);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 8rpx 24rpx rgba(68, 92, 120, .06);
}

.mall-guide-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9rpx;
  color: var(--theme-text, #243044);
  font-size: 24rpx;
  font-weight: 800;
}

.mall-guide-icon {
  width: 34rpx;
  height: 34rpx;
}

.mall-guide-divider {
  width: 1rpx;
  height: 34rpx;
  background: var(--theme-divider, #E8EEF4);
}

/* ── 筛选栏 ── */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-tag {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f5f5;
  transition: all 0.2s;
}

.filter-tag.active {
  background: var(--theme-primary, #5BA7D8);
  color: #fff;
  font-weight: 600;
}

/* ── 商品列表 ── */
.item-list {
  padding: 16rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.item-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.item-img-wrap {
  position: relative;
  height: 200rpx;
  background: #f0f4f8;
  overflow: hidden;
}

.item-img {
  width: 100%;
  height: 100%;
}

.item-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.item-badge.virtual {
  background: #2196F3;
}

.item-badge.physical {
  background: #FF9800;
}

.item-badge.theme {
  background: var(--theme-secondary, #6BC6B3);
}

.owned-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(36,48,68,.78);
  color: #FFFFFF;
  font-size: 19rpx;
  font-weight: 800;
}

.theme-product-preview {
  position: relative;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
}

.theme-preview-top {
  height: 38rpx;
  border-radius: 12rpx;
  background: currentColor;
  opacity: .9;
}

.theme-preview-card {
  height: 62rpx;
  margin-top: 15rpx;
  border-radius: 14rpx;
  background: rgba(255,255,255,.82);
  box-shadow: 0 6rpx 14rpx rgba(36,48,68,.08);
}

.theme-preview-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.theme-preview-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: currentColor;
}

.theme-preview-line {
  width: 92rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.9);
}

.preview-peach { color: #E9857B; background: linear-gradient(145deg, #FDEDEA, #FFF1DF); }
.preview-forest { color: #5F9F7B; background: linear-gradient(145deg, #E7F3EB, #E7F3F6); }
.preview-night { color: #526D96; background: linear-gradient(145deg, #E7EDF6, #E4F1F0); }
.preview-lunar { color: #C85250; background: linear-gradient(145deg, #FBE9E7, #FFF2D8); }
.preview-birthday { color: #B56FC5; background: linear-gradient(145deg, #F3E8F7, #FCE9EE); }
.preview-christmas { color: #477C63; background: linear-gradient(145deg, #E5F0E9, #F6E5E6); }

.item-owned {
  color: var(--theme-secondary-deep, #3F9486);
  font-size: 21rpx;
  font-weight: 700;
}

.item-body {
  padding: 16rpx 20rpx 20rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: -webkit-box;
  min-height: 68rpx;
  margin-bottom: 6rpx;
  line-height: 1.25;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  min-width: 0;
}

.item-points {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.points-icon {
  font-size: 24rpx;
}

.points-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B00;
}

.item-stock {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.voucher-usable {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  color: var(--theme-primary-deep, #2F8DB8);
  background: var(--theme-primary-soft, #EAF4FB);
  font-size: 18rpx;
  font-weight: 800;
  white-space: nowrap;
}

@media (max-width: 340px) {
  .points-banner { padding-left: 26rpx; padding-right: 26rpx; }
  .banner-action { padding-left: 16rpx; padding-right: 16rpx; }
  .filter-bar { gap: 8rpx; padding-left: 20rpx; padding-right: 20rpx; }
  .filter-tag { flex: 1; padding-left: 8rpx; padding-right: 8rpx; text-align: center; }
  .item-list { padding-left: 18rpx; padding-right: 18rpx; gap: 16rpx; }
  .item-card { width: calc(50% - 8rpx); }
  .item-img-wrap { height: 176rpx; }
  .item-body { padding-left: 16rpx; padding-right: 16rpx; }
  .points-num { font-size: 27rpx; }
  .item-stock { font-size: 19rpx; }
}

/* ── 兑换弹窗 ── */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
}

.redeem-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 20rpx 36rpx 60rpx;
}

.sheet-bar {
  width: 80rpx;
  height: 8rpx;
  background: #ddd;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.redeem-info {
  text-align: center;
}

.redeem-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.redeem-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 24rpx;
}

.payment-methods {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 22rpx 0;
  text-align: left;
}
.payment-method {
  min-width: 0;
  padding: 18rpx;
  border: 2rpx solid var(--theme-divider, #E8EEF4);
  border-radius: 20rpx;
  background: var(--theme-surface-muted, #F5F9FC);
  box-sizing: border-box;
}
.payment-method.active {
  border-color: var(--theme-primary, #5BA7D8);
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
  box-shadow: 0 8rpx 20rpx rgba(var(--theme-primary-rgb, 91,167,216), .12);
}
.payment-method-title { display: block; color: var(--theme-text, #243044); font-size: 23rpx; font-weight: 900; }
.payment-method-desc { display: block; margin-top: 6rpx; color: var(--theme-text-secondary, #6E7A8A); font-size: 19rpx; line-height: 1.4; }
.payment-method.active .payment-method-title { color: var(--theme-primary-deep, #2F8DB8); }

.redeem-cost {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.cost-num {
  color: #FF6B00;
  font-weight: 700;
  font-size: 36rpx;
}

.redeem-tip {
  font-size: 24rpx;
  color: #999;
  padding: 16rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
}

.redeem-tip.insufficient {
  color: #e74c3c;
  background: #fef0f0;
}

.sheet-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.s-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.s-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.s-btn.confirm {
  background: var(--theme-primary, #5BA7D8);
  color: #fff;
}

.s-btn.confirm.disabled {
  background: #a0c4e8;
  color: #fff;
}

/* ── 空状态 ── */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  font-size: 28rpx;
}

/* ── 数量选择器 ── */
.qty-section {
  margin: 20rpx 0;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}
.qty-label {
  display: block; font-size: 26rpx; color: #666;
  text-align: center; margin-bottom: 18rpx;
}
.qty-stepper {
  display: flex; align-items: center; justify-content: center; gap: 32rpx;
}
.step-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #fff; display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: #333; font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.06);
}
.step-btn.disabled { color: #ccc; background: #f5f5f5; box-shadow: none; }
.step-val {
  font-size: 44rpx; font-weight: 700; color: #333;
  min-width: 60rpx; text-align: center;
}
.qty-shortcuts {
  display: flex; justify-content: center; margin-top: 16rpx; gap: 12rpx;
}
.qs {
  padding: 8rpx 22rpx; border-radius: 20rpx;
  font-size: 24rpx; color: #888; background: #fff;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,.04);
}
.qs.active { background: var(--theme-primary, #5BA7D8); color: #fff; }

.center-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.info-modal {
  width: 100%;
  max-height: 78vh;
  padding: 30rpx;
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .16);
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.98), var(--theme-primary-soft, #EAF4FB));
  box-shadow: 0 24rpx 60rpx rgba(25, 48, 72, .20);
  box-sizing: border-box;
}

.info-modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.info-modal-kicker,
.info-modal-title,
.rule-title,
.rule-desc,
.record-name,
.record-time,
.record-cost,
.record-status {
  display: block;
}

.info-modal-kicker {
  color: var(--theme-primary-deep, #2F8DB8);
  font-size: 20rpx;
  font-weight: 900;
}

.info-modal-title {
  margin-top: 3rpx;
  color: var(--theme-text, #243044);
  font-size: 34rpx;
  font-weight: 900;
}

.info-modal-close {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.82);
}

.info-modal-close::before,
.info-modal-close::after {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 25rpx;
  width: 22rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: var(--theme-text-secondary, #6E7A8A);
}

.info-modal-close::before { transform: rotate(45deg); }
.info-modal-close::after { transform: rotate(-45deg); }

.rule-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.rule-row {
  display: flex;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,.80);
}

.rule-number {
  flex-shrink: 0;
  color: var(--theme-primary, #5BA7D8);
  font-size: 24rpx;
  font-weight: 900;
}

.rule-title {
  color: var(--theme-text, #243044);
  font-size: 26rpx;
  font-weight: 900;
}

.rule-desc {
  margin-top: 6rpx;
  color: var(--theme-text-secondary, #6E7A8A);
  font-size: 23rpx;
  line-height: 1.55;
}

.records-modal {
  height: 70vh;
  display: flex;
  flex-direction: column;
}

.record-list {
  flex: 1;
  min-height: 0;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,.82);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-name {
  color: var(--theme-text, #243044);
  font-size: 26rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time,
.record-status {
  margin-top: 5rpx;
  color: var(--theme-text-muted, #A5AFBC);
  font-size: 21rpx;
}

.record-side {
  flex-shrink: 0;
  text-align: right;
}

.record-cost {
  color: #D9822B;
  font-size: 25rpx;
  font-weight: 900;
}

.record-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--theme-text-secondary, #6E7A8A);
  font-size: 26rpx;
}

/* ── 蓝绿产品化收口 ── */
.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background:
    linear-gradient(180deg, var(--theme-secondary-soft, #EAF7F5) 0%, rgba(247,249,251,0) 360rpx),
    var(--theme-bg, #F7F9FB) !important;
}

.page .ui-hero-card {
  margin: 24rpx 24rpx 18rpx;
}

.points-banner {
  margin: 0 24rpx 22rpx;
  padding: 30rpx 32rpx;
  border-radius: 28rpx;
  background-color: var(--theme-primary, #5BA7D8) !important;
  background-image: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486)) !important;
  box-shadow: 0 16rpx 34rpx rgba(var(--theme-primary-rgb, 91, 167, 216), .22) !important;
  gap: 14rpx;
}

.balance-label {
  color: rgba(255,255,255,.86);
  font-size: 24rpx;
}

.balance-num {
  color: #fff !important;
  font-size: 56rpx;
  line-height: 1.05;
}

.banner-action {
  min-height: 64rpx;
  padding: 0 22rpx;
  color: #fff;
  background: rgba(255,255,255,.18);
  border: 1rpx solid rgba(255,255,255,.28);
  border-radius: 34rpx;
  flex-shrink: 0;
}

.voucher-mini { flex-shrink: 0; }

.banner-action text {
  color: #fff;
  font-size: 25rpx;
}

.banner-action .arrow {
  font-size: 32rpx;
  line-height: 1;
  opacity: .86;
}

.filter-bar {
  margin: 0 24rpx 22rpx;
  padding: 6rpx;
  gap: 0;
  border-radius: 28rpx !important;
  background: var(--theme-card, #FFFFFF) !important;
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .12);
  box-shadow: 0 10rpx 26rpx rgba(68, 92, 120, .06) !important;
}

.filter-tag {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  color: var(--theme-text-secondary, #6E7A8A);
  background: transparent;
  border-radius: 24rpx;
}

.filter-tag.active {
  background-color: var(--theme-primary, #5BA7D8) !important;
  background-image: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486)) !important;
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(var(--theme-primary-rgb, 91, 167, 216), .2);
}

.item-list {
  padding: 10rpx 24rpx 68rpx;
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: wrap !important;
  justify-content: space-between;
  align-items: stretch;
  column-gap: 0 !important;
  row-gap: 36rpx !important;
  box-sizing: border-box;
}

.page .item-card {
  width: 340rpx !important;
  flex: 0 0 340rpx !important;
  margin: 0 !important;
  border-radius: 24rpx !important;
  background: var(--theme-card, #FFFFFF) !important;
  box-shadow: 0 12rpx 30rpx rgba(68, 92, 120, .08) !important;
  border: 1rpx solid rgba(var(--theme-primary-rgb, 91, 167, 216), .08) !important;
  box-sizing: border-box;
  overflow: hidden;
}

.item-card:active {
  transform: scale(.985);
}

.item-img-wrap {
  height: 208rpx;
  background: linear-gradient(135deg, var(--theme-primary-soft, #EAF4FB), var(--theme-secondary-soft, #EAF7F5));
}

.item-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-badge {
  top: 14rpx;
  right: 14rpx;
  color: var(--theme-text, #243044);
  font-weight: 700;
  border-radius: 999rpx;
  padding: 5rpx 14rpx;
  background: var(--theme-card, #FFFFFF);
  box-shadow: 0 4rpx 12rpx rgba(36,48,68,.08);
}

.item-badge.virtual {
  color: #4BAA9C;
  background: var(--theme-secondary-soft, #EAF7F5);
}

.item-badge.physical {
  color: #B36B1A;
  background: #FFF3E1;
}

.item-body {
  padding: 18rpx 20rpx 22rpx;
}

.item-name {
  color: var(--theme-text, #243044);
  font-weight: 700;
  line-height: 1.35;
}

.item-desc {
  color: var(--theme-text-secondary, #6E7A8A);
  margin-bottom: 16rpx;
}

.item-points {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #FFF3E1;
}

.points-num,
.cost-num {
  color: #D9822B;
}

.item-stock {
  color: var(--theme-text-muted, #A5AFBC);
}

.empty-tip {
  color: var(--theme-text-secondary, #6E7A8A);
  padding: 96rpx 24rpx;
}

.mask {
  background: rgba(36,48,68,.48);
}

.redeem-sheet {
  background: var(--theme-bg, #F7F9FB);
  border-radius: 32rpx 32rpx 0 0;
}

.sheet-title,
.redeem-name {
  color: var(--theme-text, #243044) !important;
}

.redeem-desc,
.redeem-cost,
.qty-label {
  color: var(--theme-text-secondary, #6E7A8A);
}

.redeem-tip,
.qty-section {
  background: var(--theme-card, #FFFFFF);
  border: 1rpx solid var(--theme-divider, #E8EEF4);
}

.step-btn,
.qs {
  background: var(--theme-primary-soft, #EAF4FB);
  color: var(--theme-primary, #5BA7D8);
  box-shadow: none;
}

.qs.active,
.s-btn.confirm {
  background-color: var(--theme-primary, #5BA7D8) !important;
  background-image: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486)) !important;
  color: #fff;
}

.s-btn.cancel {
  background: var(--theme-surface-muted, #F5F9FC);
  color: var(--theme-text-secondary, #6E7A8A);
}

@media (max-width: 340px) {
  .points-banner { gap: 8rpx; padding-left: 22rpx; padding-right: 22rpx; }
  .balance-num { font-size: 48rpx; }
  .voucher-mini { gap: 5rpx; padding: 8rpx 10rpx; }
  .voucher-mini image { width: 28rpx; height: 28rpx; }
  .voucher-mini text { font-size: 16rpx; }
  .voucher-mini text:last-child { font-size: 19rpx; }
  .banner-action { min-height: 58rpx; padding: 0 13rpx; gap: 4rpx; }
  .banner-action text { font-size: 21rpx; }
  .payment-methods { grid-template-columns: 1fr; }
}

/* 主题中性色：商品类型与积分橙保留语义 */
.filter-bar,
.mall-guide,
.page .item-card,
.redeem-tip,
.qty-section {
  background: var(--theme-card, #FFFFFF);
  border-color: var(--theme-divider, #E8EEF4);
}

.filter-tag {
  color: var(--theme-text-secondary, #6E7A8A);
  background: var(--theme-surface-muted, #F5F9FC);
}

.filter-tag.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--theme-action-start, #2F8DB8), var(--theme-action-end, #3F9486));
}

.sheet-bar {
  background: var(--theme-divider, #E8EEF4);
}
