<view class="page benefit-page {{themeClass}}">
  <view class="benefit-hero">
    <view class="benefit-hero-art">
      <view class="ticket ticket-back"></view>
      <view class="ticket ticket-front"><image src="/assets/icons/ui/ticket.png" mode="aspectFit" /></view>
      <view class="benefit-spark spark-one"></view><view class="benefit-spark spark-two"></view>
    </view>
    <view class="benefit-hero-copy">
      <text class="benefit-kicker">PET BENEFITS</text>
      <text class="benefit-title">福利中心</text>
      <text class="benefit-desc">版本礼遇、节日惊喜和补偿礼包，都会安静地收在这里。</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="ui-loading-state">
    <view class="ui-loading-mark"></view><text class="ui-loading-text">正在打开福利</text>
  </view>
  <view wx:elif="{{loadError}}" class="benefit-error">
    <image src="/assets/icons/ui/cloud.png" mode="aspectFit" />
    <text class="benefit-error-title">福利加载失败</text>
    <text class="benefit-error-desc">已有奖励不会丢失，请稍后重新加载</text>
    <button bindtap="loadBenefit">重新加载</button>
  </view>

  <block wx:else>
    <view class="voucher-balance">
      <view>
        <text class="voucher-balance-label">我的主题兑换券</text>
        <text class="voucher-balance-desc">{{pendingClaims > 0 ? '还有 ' + pendingClaims + ' 份福利待领取' : (pendingUses > 0 ? '可直接兑换符合条件的主题' : '新福利会在这里提醒你')}}</text>
      </view>
      <view class="voucher-balance-side">
        <view class="voucher-balance-count"><text>{{themeVouchers}}</text><text>张</text></view>
      </view>
    </view>
    <view class="voucher-redeem-entry" bindtap="goThemeMall">
      <view>
        <text class="voucher-entry-title">{{themeVouchers > 0 ? '使用主题兑换券' : '查看可兑换主题'}}</text>
        <text class="voucher-entry-desc">{{themeVouchers > 0 ? '前往积分小铺，兑换喜欢的主题' : '有兑换券后可在这里直接使用'}}</text>
      </view>
      <view class="voucher-entry-arrow"></view>
    </view>

    <view class="benefit-section-head">
      <text>当前福利</text>
      <text>{{campaigns.length}} 项</text>
    </view>
    <view wx:if="{{campaigns.length === 0}}" class="benefit-empty">
      <image src="/assets/icons/ui/gift.png" mode="aspectFit" />
      <text>暂时没有可展示的福利</text>
    </view>

    <view wx:for="{{campaigns}}" wx:key="_id" class="benefit-card state-{{item._stateClass}}">
      <view class="benefit-card-top">
        <view class="benefit-card-icon"><image src="/assets/icons/ui/gift.png" mode="aspectFit" /></view>
        <view class="benefit-card-copy">
          <view class="benefit-card-title-row">
            <text class="benefit-card-title">{{item.title}}</text>
            <text class="benefit-state {{item._stateClass}}">{{item._stateText}}</text>
          </view>
          <text class="benefit-card-desc">{{item.desc}}</text>
        </view>
      </view>

      <view class="reward-summary">
        <text class="reward-label">本次奖励</text>
        <text class="reward-value">{{item._rewardText}}</text>
        <text wx:if="{{item.rewardType === 'theme_voucher'}}" class="reward-extra">适用于 ≤ {{item.maxThemePoints || 1000}} 积分主题</text>
      </view>

      <button
        wx:if="{{item.canClaim}}"
        class="benefit-primary-btn"
        loading="{{claimingId === item._id}}"
        disabled="{{!!claimingId}}"
        bindtap="claimBenefit"
        data-id="{{item._id}}"
      ><text>{{claimingId === item._id ? '领取中' : '立即领取'}}</text></button>
      <view wx:elif="{{item.state === 'claimed'}}" class="benefit-disabled-btn">已领取</view>
      <view wx:elif="{{item.state === 'used'}}" class="benefit-disabled-btn">已使用</view>
      <view wx:else class="benefit-disabled-btn">{{item._stateText}}</view>
    </view>

    <view class="benefit-section-head history-head">
      <text>领取记录</text><text>{{claims.length}} 条</text>
    </view>
    <view wx:if="{{claims.length === 0}}" class="claim-empty">还没有领取记录</view>
    <view wx:for="{{claims}}" wx:key="_id" class="benefit-history-row">
      <view>
        <text class="history-title">{{item.campaignTitle}}</text>
        <text class="history-time">{{item._timeText}}</text>
      </view>
      <view class="history-side">
        <text class="history-reward">{{item._rewardText}}</text>
        <text class="history-status">{{item._statusText}}</text>
      </view>
    </view>
  </block>
</view>
