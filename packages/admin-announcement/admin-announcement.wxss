page { background: var(--theme-bg, #F7F9FB); }
.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background: linear-gradient(180deg, var(--theme-secondary-soft, #EAF7F5) 0%, rgba(247,249,251,0) 360rpx), var(--theme-bg, #F7F9FB) !important;
}

.post-box {
  margin: 0 24rpx 22rpx;
  padding: 26rpx;
  background: var(--theme-card, #FFFFFF);
}
.post-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}
.post-title { display: block; color: var(--theme-text, #243044); font-size: 29rpx; font-weight: 900; }
.post-desc { display: block; margin-top: 4rpx; color: var(--theme-text-secondary, #6E7A8A); font-size: 23rpx; }
.post-count { color: var(--theme-text-muted, #A5AFBC); font-size: 22rpx; white-space: nowrap; }
.post-input {
  width: 100%;
  min-height: 150rpx;
  padding: 22rpx;
  border: 1rpx solid var(--theme-divider, #E8EEF4);
  background: var(--theme-surface-muted, #F5F9FC);
  border-radius: 18rpx;
  color: var(--theme-text, #243044);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.post-btn { width: 100%; height: 80rpx; line-height: 80rpx; margin-top: 18rpx; background: var(--theme-primary, #5BA7D8); color: #fff; font-size: 29rpx; font-weight: 800; border-radius: 999rpx; padding: 0; }
.post-btn::after { border: none; }
.post-btn.disabled { opacity: .5; }

.list { padding: 0 24rpx; }
.card { padding: 24rpx; margin-bottom: 16rpx; }
.card-top { display: flex; flex-direction: column; align-items: flex-start; gap: 14rpx; margin-bottom: 18rpx; }
.status-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  background: var(--theme-surface-muted, #F5F9FC);
  color: var(--theme-text-secondary, #6E7A8A);
  font-size: 21rpx;
  font-weight: 800;
}
.status-chip.active { background: #EAF7F0; color: #3F8F54; }
.status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: currentColor; flex-shrink: 0; }
.card-content { font-size: 28rpx; color: var(--theme-text, #243044); width: 100%; line-height: 1.65; font-weight: 600; }
.card-actions { display: flex; justify-content: flex-end; gap: 16rpx; padding-top: 16rpx; border-top: 1rpx solid var(--theme-divider, #E8EEF4); }
.act { padding: 8rpx 20rpx; border-radius: 999rpx; font-size: 24rpx; color: var(--theme-primary-deep, #2F8DB8); background: var(--theme-primary-soft, #EAF4FB); font-weight: 800; }
.act.danger { color: #D94C53; background: #FFF1F2; }

.loading-box, .empty-state { text-align: center; padding: 100rpx 0; color: var(--theme-text-secondary, #6E7A8A); }
.empty-text { font-size: 28rpx; margin-top: 16rpx; display: block; color: var(--theme-text-secondary, #6E7A8A); }
